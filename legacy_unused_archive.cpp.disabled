// Original path: cascade_fir/tests/legacy/test_quick.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  test_quick.cpp
//  Архивный ad-hoc scratch-тест.
//
//  Не входит в стандартную CMake-сборку и сохранён только как
//  ручная диагностическая заготовка для legacy baseline.
//
//  Строим полином как произведение 3 известных biquad'ов,
//  разлагаем нашим алгоритмом, пересобираем и проверяем ошибку.
//
//  Цель: отделить ошибку декомпозиции от ошибки пересборки.
//  Если полином ТОЧНО факторизуется на заданные biquad'ы,
//  то и пересборка должна быть точной.
//
//  Дополнительно: тестируем фильтры частотной выборки разных N
//  и печатаем ошибку пересборки vs ошибку фильтрации (SNR).
//
//  Компиляция (из build/):
//    g++ -std=c++17 -O2 -I../include ../tests/test_quick.cpp \
//        ../src/freq_sampling_design.cpp \
//        ../src/cascade_decompose.cpp \
//        ../src/cascade_filter.cpp \
//        ../src/direct_filter.cpp \
//        ../src/signal_generation.cpp \
//        -lfftw3 -lm -o test_quick
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"
#include <cstdlib>

// ─────────────────────────────────────────────────────────────
//  Тест A: ручная факторизация (заведомо точная)
//
//  Строим H(z) = (1 - γ₁z⁻¹ + z⁻²)(1 - γ₂z⁻¹ + z⁻²)(1 - γ₃z⁻¹ + z⁻²)
//  Разлагаем нашим алгоритмом (divide_by_biquad_half).
//  Пересобираем через poly_multiply.
//  Ожидание: ошибка ~ ε_mach.
// ─────────────────────────────────────────────────────────────

static void test_manual_factorization()
{
    std::cout << "╔══════════════════════════════════════════════╗\n"
              << "║  Тест A: ручная факторизация (3 biquad'а)   ║\n"
              << "╚══════════════════════════════════════════════╝\n\n";

    // Три γ-коэффициента (нули на единичной окружности)
    const real_t gammas[] = {1.5, -0.5, 0.8};
    const int num_factors = 3;

    // ── Построить полином-произведение ────────────────────────
    std::vector<real_t> h = {1.0};
    for (int i = 0; i < num_factors; ++i) {
        std::vector<real_t> d = {1.0, -gammas[i], 1.0};
        h = poly_multiply(h, d);
    }

    std::cout << "  Исходный полином длины " << h.size() << ":\n    ";
    for (size_t n = 0; n < h.size(); ++n) {
        std::cout << std::setprecision(10) << h[n];
        if (n + 1 < h.size()) std::cout << ", ";
    }
    std::cout << "\n\n";

    // Проверка симметрии
    double max_asym = 0.0;
    for (size_t n = 0; n < h.size() / 2; ++n) {
        double d = std::abs(h[n] - h[h.size() - 1 - n]);
        if (d > max_asym) max_asym = d;
    }
    std::cout << "  Симметрия: max|h[n]-h[N-1-n]| = "
              << std::scientific << max_asym << std::defaultfloat << "\n\n";

    // ── Последовательное деление (половинная рекурсия) ────────
    std::cout << "  Последовательное деление:\n";

    std::vector<real_t> current = h;

    for (int i = 0; i < num_factors; ++i) {
        real_t gamma = gammas[i];
        size_t len = current.size();
        size_t qlen = len - 2;

        if (len < 4) {
            std::cout << "    Полином слишком короткий!\n";
            break;
        }

        // Половинная рекурсия
        std::vector<real_t> q(qlen);
        size_t mid = (qlen - 1) / 2;

        q[0] = current[0];
        if (qlen >= 2)
            q[1] = current[1] + gamma * q[0];
        for (size_t n = 2; n <= mid; ++n)
            q[n] = current[n] + gamma * q[n - 1] - q[n - 2];

        // Чётное qlen — центральный элемент
        if (qlen % 2 == 0 && qlen >= 4) {
            size_t center = qlen / 2;
            if (center > mid)
                q[center] = current[center] + gamma * q[center - 1]
                          - q[center - 2];
        }

        // Симметрия второй половины
        for (size_t n = 0; n < qlen / 2; ++n)
            q[qlen - 1 - n] = q[n];

        // Проверка: умножить q × D и сравнить с current
        std::vector<real_t> d = {1.0, -gamma, 1.0};
        std::vector<real_t> check = poly_multiply(q, d);

        double max_err = 0.0;
        for (size_t n = 0; n < current.size(); ++n) {
            double diff = std::abs(current[n] -
                          (n < check.size() ? check[n] : 0.0));
            if (diff > max_err) max_err = diff;
        }

        std::cout << "    γ=" << std::setw(6) << std::setprecision(3) << gamma
                  << "  qlen=" << qlen
                  << "  max|q×D - h| = " << std::scientific
                  << std::setprecision(3) << max_err
                  << std::defaultfloat << "\n";

        std::cout << "    Частное: [";
        for (size_t n = 0; n < q.size(); ++n) {
            std::cout << std::setprecision(10) << q[n];
            if (n + 1 < q.size()) std::cout << ", ";
        }
        std::cout << "]\n";

        current = std::move(q);
    }

    std::cout << "\n  Остаток: [";
    for (size_t n = 0; n < current.size(); ++n) {
        std::cout << std::setprecision(10) << current[n];
        if (n + 1 < current.size()) std::cout << ", ";
    }
    std::cout << "]\n";

    // ── Пересборка ───────────────────────────────────────────
    std::vector<real_t> recomp = current;
    for (int i = num_factors - 1; i >= 0; --i) {
        std::vector<real_t> d = {1.0, -gammas[i], 1.0};
        recomp = poly_multiply(recomp, d);
    }

    double max_recomp_err = 0.0;
    for (size_t n = 0; n < h.size(); ++n) {
        double diff = std::abs(h[n] - (n < recomp.size() ? recomp[n] : 0.0));
        if (diff > max_recomp_err) max_recomp_err = diff;
    }

    std::cout << "\n  Пересборка: max|h - recomp| = "
              << std::scientific << max_recomp_err << std::defaultfloat << "\n";

    if (max_recomp_err < 1e-13) {
        std::cout << "  ✓ Ручная факторизация: ТОЧНО\n";
    } else {
        std::cout << "  ✗ Ручная факторизация: ОШИБКА " << max_recomp_err << "\n";
    }
}

// ─────────────────────────────────────────────────────────────
//  Тест B: фильтры частотной выборки разных N
//
//  Для каждого N:
//  - спроектировать ФНЧ
//  - разложить на каскад
//  - пересобрать (проверить ошибку коэффициентов)
//  - профильтровать импульс и шум (проверить SNR)
//
//  Ожидание: ошибка коэффициентов растёт с N,
//  но SNR фильтрации остаётся высоким (>100 дБ),
//  поскольку каскадная фильтрация не зависит от
//  качества пересборки — звенья задаются точно через γ_k.
// ─────────────────────────────────────────────────────────────

static void test_freq_sampling_sweep()
{
    std::cout << "\n╔══════════════════════════════════════════════╗\n"
              << "║  Тест B: фильтры частотной выборки, N=9..257 ║\n"
              << "╚══════════════════════════════════════════════╝\n\n";

    struct TestCase {
        unsigned N;
        real_t fs, f_pass, f_stop;
    };

    TestCase cases[] = {
        {   9, 18000.0,  4000.0,  6000.0},
        {  15, 32000.0,  4000.0,  6000.0},
        {  29, 32000.0,  4000.0,  6000.0},
        {  33, 32000.0,  4000.0,  6000.0},
        {  49, 32000.0,  4000.0,  6000.0},
        {  65, 48000.0,  8000.0, 12000.0},
        {  97, 48000.0,  8000.0, 12000.0},
        { 129, 48000.0,  8000.0, 12000.0},
        { 257, 96000.0, 16000.0, 24000.0},
    };

    std::cout << std::left
              << std::setw(6)  << "N"
              << std::setw(6)  << "P"
              << std::setw(8)  << "RemOrd"
              << std::setw(14) << "max|Δh|"
              << std::setw(14) << "rel_L2"
              << std::setw(12) << "SNR_imp,dB"
              << std::setw(12) << "SNR_noise,dB"
              << "\n";
    std::cout << std::string(72, '-') << "\n";

    for (const auto& tc : cases) {
        FilterSpec spec{tc.N, tc.fs, tc.f_pass, tc.f_stop};

        // Проектирование
        DirectFIR fir = design_freq_sampling(spec);

        // Декомпозиция
        CascadeDecomposition dec = decompose(fir, true);

        // Пересборка
        std::vector<real_t> h_recomp = recompose(dec, fir.length());
        CoeffMetrics cm = compare_coeffs(fir.h, h_recomp);

        // Фильтрация импульса
        const size_t ir_len = fir.length() * 2;
        std::vector<sample_t> impulse = generate_impulse(ir_len);
        std::vector<sample_t> y_dir = filter_direct(fir, impulse);
        std::vector<sample_t> y_cas = filter_cascade(dec, impulse);
        CompareMetrics cm_imp = compare_signals(y_dir, y_cas);

        // Фильтрация шума
        const size_t noise_len = 50000;
        std::vector<sample_t> noise = generate_white_noise(noise_len, 42);
        std::vector<sample_t> yn_dir = filter_direct(fir, noise);
        std::vector<sample_t> yn_cas = filter_cascade(dec, noise);
        CompareMetrics cm_noise = compare_signals(yn_dir, yn_cas);

        unsigned P = static_cast<unsigned>(dec.biquads.size() +
                                           dec.first_order.size());
        unsigned rem_ord = static_cast<unsigned>(dec.remainder.size()) - 1;

        std::cout << std::left
                  << std::setw(6)  << tc.N
                  << std::setw(6)  << P
                  << std::setw(8)  << rem_ord
                  << std::setw(14) << std::scientific << std::setprecision(3)
                  << cm.max_abs_err
                  << std::setw(14) << cm.rel_l2_err
                  << std::setw(12) << std::fixed << std::setprecision(1)
                  << cm_imp.snr_db
                  << std::setw(12) << cm_noise.snr_db
                  << std::defaultfloat << "\n";
    }

    std::cout << "\n"
              << "  Пояснение:\n"
              << "  - max|Δh|: ошибка ПЕРЕСБОРКИ (poly_multiply каскадов → полином).\n"
              << "    Растёт с N, потому что каждое деление вносит ошибку в частное,\n"
              << "    и при пересборке эти ошибки перемножаются.\n"
              << "\n"
              << "  - SNR_imp: ОСШ прямая vs каскадная фильтрация на импульсе.\n"
              << "  - SNR_noise: то же на белом шуме.\n"
              << "    Эти метрики показывают РЕАЛЬНОЕ качество каскадной фильтрации.\n"
              << "    Если SNR > 100 дБ — каскад работает правильно, даже если\n"
              << "    пересборка коэффициентов плохая.\n"
              << "\n"
              << "  КЛЮЧЕВОЕ НАБЛЮДЕНИЕ:\n"
              << "  Пересборка (max|Δh|) может быть плохой при больших N,\n"
              << "  но фильтрация (SNR) остаётся отличной, потому что каскадные\n"
              << "  звенья задаются ТОЧНО через γ_k = 2·cos(2πk/N), а не через\n"
              << "  восстановленные коэффициенты.\n";
}

// ─────────────────────────────────────────────────────────────
//  Тест C: диагностика ошибки деления по шагам
//
//  Для N=65 показать, как растёт невязка от деления к делению.
// ─────────────────────────────────────────────────────────────

static void test_step_by_step_n65()
{
    std::cout << "\n╔══════════════════════════════════════════════╗\n"
              << "║  Тест C: пошаговая диагностика N=65          ║\n"
              << "╚══════════════════════════════════════════════╝\n\n";

    FilterSpec spec{65, 48000.0, 8000.0, 12000.0};
    DirectFIR fir = design_freq_sampling(spec);

    unsigned k_stop = spec.k_stop();
    unsigned k_half = spec.N / 2;

    // Собрать нулевые выборки
    std::vector<unsigned> stopband_k;
    for (unsigned k = k_stop; k <= k_half; ++k) {
        stopband_k.push_back(k);
    }

    std::cout << "  N=65, k_stop=" << k_stop << ", k_half=" << k_half
              << ", нулевых выборок: " << stopband_k.size() << "\n\n";

    std::cout << std::left
              << std::setw(5)  << "Step"
              << std::setw(5)  << "k"
              << std::setw(12) << "γ"
              << std::setw(8)  << "len_h"
              << std::setw(8)  << "len_q"
              << std::setw(14) << "max|q×D-h|"
              << "\n";
    std::cout << std::string(52, '-') << "\n";

    std::vector<real_t> current = fir.h;
    int step = 0;

    for (unsigned k : stopband_k) {
        ++step;
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / spec.N);

        size_t len = current.size();
        if (len < 4) break;

        size_t qlen = len - 2;
        std::vector<real_t> q(qlen);
        size_t mid = (qlen - 1) / 2;

        q[0] = current[0];
        if (qlen >= 2)
            q[1] = current[1] + gamma * q[0];
        for (size_t n = 2; n <= mid; ++n)
            q[n] = current[n] + gamma * q[n - 1] - q[n - 2];
        if (qlen % 2 == 0 && qlen >= 4) {
            size_t center = qlen / 2;
            if (center > mid)
                q[center] = current[center] + gamma * q[center - 1]
                          - q[center - 2];
        }
        for (size_t n = 0; n < qlen / 2; ++n)
            q[qlen - 1 - n] = q[n];

        // Проверка: q × D vs current
        std::vector<real_t> d = {1.0, -gamma, 1.0};
        std::vector<real_t> check = poly_multiply(q, d);
        double max_err = 0.0;
        for (size_t n = 0; n < current.size(); ++n) {
            double diff = std::abs(current[n] -
                          (n < check.size() ? check[n] : 0.0));
            if (diff > max_err) max_err = diff;
        }

        std::cout << std::left
                  << std::setw(5)  << step
                  << std::setw(5)  << k
                  << std::setw(12) << std::setprecision(6) << gamma
                  << std::setw(8)  << len
                  << std::setw(8)  << qlen
                  << std::setw(14) << std::scientific << std::setprecision(3)
                  << max_err
                  << std::defaultfloat << "\n";

        current = std::move(q);
    }

    std::cout << "\n  Остаток: длина " << current.size()
              << ", порядок " << (current.size() - 1) << "\n";
}

// ═══════════════════════════════════════════════════════════════
//  main
// ═══════════════════════════════════════════════════════════════

int main()
{
    test_manual_factorization();
    test_freq_sampling_sweep();
    test_step_by_step_n65();

    return 0;
}



// ============================================================================
// Original path: cascade_fir/tests/legacy/test_single_division.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  test_single_division.cpp
//
//  Проверка гипотезы: однократное деление H(z) на полный делитель
//  D(z) = ∏(1 − γ_k z⁻¹ + z⁻²) × (1±z⁻¹)  работает без
//  каскадирования ошибок и позволяет выделить ВСЕ нули
//  полосы заграждения при любом N.
//
//  Сравнивается с текущим итеративным подходом (decompose).
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <cmath>
#include <cstdio>
#include <vector>
#include <string>
#include <algorithm>
#include <numeric>
#include <cassert>

// ─────────────────────────────────────────────────────────────
//  Структура результата однократного деления
// ─────────────────────────────────────────────────────────────

struct SingleDivResult {
    std::string label;
    unsigned N;

    // Спецификация нулей
    unsigned n_stopband_pairs;   // число пар нулей на единичной окружности
    bool     has_dc_zero;        // нуль в z=+1
    bool     has_nyq_zero;       // нуль в z=-1
    unsigned total_zeros;        // всего выделенных нулей

    // Делитель
    unsigned divisor_degree;     // степень D(z)

    // Результаты деления
    unsigned quotient_degree;    // степень Q(z) = H/D
    double   max_math_remainder; // max|r[n]| остатка poly_divide
    double   max_rebuild_err;    // max|h[n] - (Q*D)[n]|
    double   rel_rebuild_err;    // ||h - Q*D||_2 / ||h||_2
    double   quotient_symmetry;  // max|q[n] - q[M-1-n]| (проверка палиндрома)

    // Диагностика делителя D(z)
    double   D_max_coeff;        // max|D[n]|
    double   D_dynamic_range_db; // динамический диапазон коэфф. D в дБ

    // Блочное деление (альтернатива)
    double   block1_rebuild_err; // блок по 1 фактору
    double   block2_rebuild_err; // блок по 2 фактора
    double   block4_rebuild_err; // блок по 4 фактора
    double   block8_rebuild_err; // блок по 8 факторов

    // Progressive recompute: на каждом шаге делим ОРИГИНАЛ на
    // накопленное произведение всех уже выделенных факторов
    unsigned prog_factors_extracted;
    unsigned prog_factors_total;
    double   prog_rebuild_err;
    double   prog_remainder_order; // степень остатка

    // Hybrid: последовательное деление по одному фактору,
    // но каждые R шагов «обновляем» полином из оригинала
    unsigned hybrid_factors_extracted;
    double   hybrid_rebuild_err;
    double   hybrid_remainder_order;

    // Hybrid-biquad: как hybrid, но обновление через последовательные
    // biquad half-recurrence деления оригинала (а не poly_divide)
    unsigned hbq_factors_extracted;
    double   hbq_rebuild_err;
    double   hbq_remainder_order;

    // Сравнение с итеративным подходом
    unsigned old_P_fact;         // число звеньев, выделенных старым методом
    double   old_rebuild_err;    // ошибка пересборки старого метода
};

// ─────────────────────────────────────────────────────────────
//  Вспомогательное: собрать индексы нулевых выборок
// ─────────────────────────────────────────────────────────────

struct StopbandZeros {
    std::vector<unsigned> pair_indices;  // k для пар z=exp(±j2πk/N)
    bool has_dc_zero;    // k=0, нуль z=+1
    bool has_nyq_zero;   // k=N/2, нуль z=-1
};

static StopbandZeros find_stopband_zeros(const FilterSpec& spec)
{
    StopbandZeros sz;
    sz.has_dc_zero  = false;
    sz.has_nyq_zero = false;

    const unsigned N      = spec.N;
    const unsigned k_stop = spec.k_stop();
    const unsigned k_half = N / 2;

    for (unsigned k = k_stop; k <= k_half; ++k) {
        if (k == 0) {
            sz.has_dc_zero = true;
        } else if (N % 2 == 0 && k == k_half) {
            sz.has_nyq_zero = true;
        } else {
            sz.pair_indices.push_back(k);
        }
    }

    return sz;
}

// ─────────────────────────────────────────────────────────────
//  Построить полный делитель D(z) = ∏ всех каскадных звеньев
// ─────────────────────────────────────────────────────────────

static std::vector<real_t> build_full_divisor(unsigned N,
                                              const StopbandZeros& sz)
{
    std::vector<real_t> D = {1.0};

    // Звенья 1-го порядка
    if (sz.has_dc_zero) {
        // нуль z=+1 → (1 - z⁻¹)
        std::vector<real_t> f = {1.0, -1.0};
        D = poly_multiply(D, f);
    }
    if (sz.has_nyq_zero) {
        // нуль z=-1 → (1 + z⁻¹)
        std::vector<real_t> f = {1.0, 1.0};
        D = poly_multiply(D, f);
    }

    // Звенья 2-го порядка: (1 - γ_k z⁻¹ + z⁻²)
    for (unsigned k : sz.pair_indices) {
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
        std::vector<real_t> f = {1.0, -gamma, 1.0};
        D = poly_multiply(D, f);
    }

    return D;
}

// ─────────────────────────────────────────────────────────────
//  Проверка симметрии полинома: max|p[n] - p[M-1-n]|
// ─────────────────────────────────────────────────────────────

static double check_symmetry(const std::vector<real_t>& p)
{
    if (p.size() <= 1) return 0.0;
    double maxd = 0.0;
    for (size_t n = 0; n < p.size() / 2; ++n) {
        double d = std::abs(p[n] - p[p.size() - 1 - n]);
        if (d > maxd) maxd = d;
    }
    return maxd;
}

// ─────────────────────────────────────────────────────────────
//  Принудительная симметризация частного
// ─────────────────────────────────────────────────────────────

static void enforce_symmetry(std::vector<real_t>& p)
{
    for (size_t n = 0; n < p.size() / 2; ++n) {
        real_t avg = (p[n] + p[p.size() - 1 - n]) * 0.5;
        p[n] = avg;
        p[p.size() - 1 - n] = avg;
    }
}

// ─────────────────────────────────────────────────────────────
//  Диагностика коэффициентов полинома
// ─────────────────────────────────────────────────────────────

struct PolyStats {
    double max_abs;       // max|p[n]|
    double min_abs_nz;    // min|p[n]| среди ненулевых
    double l2_norm;       // ||p||_2
    double dynamic_range; // max/min (дБ)
};

static PolyStats compute_poly_stats(const std::vector<real_t>& p)
{
    PolyStats s{};
    s.max_abs    = 0.0;
    s.min_abs_nz = 1e300;
    s.l2_norm    = 0.0;

    for (const auto& v : p) {
        double av = std::abs(v);
        s.l2_norm += v * v;
        if (av > s.max_abs) s.max_abs = av;
        if (av > 1e-300 && av < s.min_abs_nz) s.min_abs_nz = av;
    }
    s.l2_norm = std::sqrt(s.l2_norm);
    s.dynamic_range = (s.min_abs_nz < 1e299)
                    ? 20.0 * std::log10(s.max_abs / s.min_abs_nz)
                    : 0.0;
    return s;
}

// ─────────────────────────────────────────────────────────────
//  Блочное деление: делим H на группы по block_size факторов
//  за раз, каждый раз от ОРИГИНАЛЬНОГО оставшегося полинома
// ─────────────────────────────────────────────────────────────

struct BlockDivResult {
    std::vector<real_t> quotient;
    double max_block_remainder;   // наибольший мат. остаток среди блоков
    double max_rebuild_err;       // |h - Q * D_full|
    unsigned num_blocks;
    bool     success;
};

static BlockDivResult block_division(const std::vector<real_t>& h,
                                     unsigned N,
                                     const StopbandZeros& sz,
                                     unsigned block_size)
{
    BlockDivResult br;
    br.max_block_remainder = 0.0;
    br.num_blocks = 0;
    br.success = true;

    // Собрать все делители: сначала first-order, потом biquads
    struct Factor {
        std::vector<real_t> poly;
    };
    std::vector<Factor> factors;

    if (sz.has_dc_zero)
        factors.push_back(Factor{{1.0, -1.0}});
    if (sz.has_nyq_zero)
        factors.push_back(Factor{{1.0, 1.0}});
    for (unsigned k : sz.pair_indices) {
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
        factors.push_back(Factor{{1.0, -gamma, 1.0}});
    }

    // Делим блоками
    std::vector<real_t> current = h;

    for (size_t i = 0; i < factors.size(); i += block_size) {
        // Построить произведение текущего блока
        size_t end = std::min(i + block_size, factors.size());
        std::vector<real_t> block_poly = {1.0};
        for (size_t j = i; j < end; ++j) {
            block_poly = poly_multiply(block_poly, factors[j].poly);
        }

        auto [Q, rem] = poly_divide(current, block_poly);

        double max_rem = 0.0;
        for (const auto& v : rem) {
            double av = std::abs(v);
            if (av > max_rem) max_rem = av;
        }
        if (max_rem > br.max_block_remainder)
            br.max_block_remainder = max_rem;

        // Принудить симметрию частного
        enforce_symmetry(Q);

        current = std::move(Q);
        br.num_blocks++;

        if (max_rem > 1.0) {
            br.success = false;
            // Продолжаем, чтобы посмотреть картину целиком
        }
    }

    br.quotient = std::move(current);

    // Пересборка для проверки
    std::vector<real_t> rebuilt = br.quotient;
    for (const auto& f : factors) {
        rebuilt = poly_multiply(rebuilt, f.poly);
    }
    br.max_rebuild_err = 0.0;
    for (size_t n = 0; n < h.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double diff = std::abs(h[n] - v);
        if (diff > br.max_rebuild_err)
            br.max_rebuild_err = diff;
    }

    return br;
}

// ─────────────────────────────────────────────────────────────
//  Progressive recompute: на каждом шаге делим H_orig на
//  растущее произведение ∏ factor[0..i], собранное из точных γ_k.
//  Ошибки НЕ каскадируются между шагами.
// ─────────────────────────────────────────────────────────────

struct ProgressiveResult {
    std::vector<real_t> quotient;
    unsigned factors_extracted;   // сколько факторов успешно выделено
    unsigned factors_total;       // сколько факторов доступно
    double   max_rebuild_err;     // |h - Q * ∏factors|_max
    double   last_remainder;      // мат. остаток на последнем шаге
};

static ProgressiveResult progressive_recompute_division(
    const std::vector<real_t>& h,
    unsigned N,
    const StopbandZeros& sz)
{
    ProgressiveResult pr;
    pr.factors_extracted = 0;
    pr.max_rebuild_err   = 0.0;
    pr.last_remainder    = 0.0;

    // ── Собрать все факторы ──────────────────────────────────
    struct Factor { std::vector<real_t> poly; };
    std::vector<Factor> factors;

    if (sz.has_dc_zero)
        factors.push_back(Factor{{1.0, -1.0}});
    if (sz.has_nyq_zero)
        factors.push_back(Factor{{1.0, 1.0}});

    // Чередующийся порядок (как в старом decompose):
    // сначала сортируем, потом берём попеременно с обоих концов
    {
        std::vector<unsigned> sorted = sz.pair_indices;
        std::sort(sorted.begin(), sorted.end());
        std::vector<unsigned> interleaved;
        size_t lo = 0, hi = sorted.size() - 1;
        bool take_lo = true;
        while (interleaved.size() < sorted.size()) {
            if (take_lo) {
                interleaved.push_back(sorted[lo++]);
            } else {
                interleaved.push_back(sorted[hi--]);
            }
            take_lo = !take_lo;
            if (lo > hi && interleaved.size() < sorted.size()) break;
        }
        for (unsigned k : interleaved) {
            real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
            factors.push_back(Factor{{1.0, -gamma, 1.0}});
        }
    }

    pr.factors_total = static_cast<unsigned>(factors.size());

    // ── max|h| для относительного порога ─────────────────────
    double max_h = 0.0;
    for (const auto& v : h)
        if (std::abs(v) > max_h) max_h = std::abs(v);

    static constexpr double QUALITY_THRESHOLD = 1e-6;

    // ── Прогрессивное извлечение ─────────────────────────────
    std::vector<real_t> accumulated = {1.0};
    std::vector<real_t> best_quotient = h;   // 0 факторов → остаток = h

    for (size_t i = 0; i < factors.size(); ++i) {
        // Нарастить произведение: accumulated *= factor[i]
        std::vector<real_t> new_accumulated =
            poly_multiply(accumulated, factors[i].poly);

        // Разделить ОРИГИНАЛ на накопленное произведение
        auto [Q, rem] = poly_divide(h, new_accumulated);

        // Проверить мат. остаток
        double max_rem = 0.0;
        for (const auto& v : rem) {
            double av = std::abs(v);
            if (av > max_rem) max_rem = av;
        }

        double rel_rem = (max_h > 1e-30) ? max_rem / max_h : max_rem;

        if (rel_rem > QUALITY_THRESHOLD) {
            // Качество деградировало — останавливаемся
            break;
        }

        // Принять этот фактор
        accumulated = std::move(new_accumulated);
        enforce_symmetry(Q);
        best_quotient = std::move(Q);
        pr.factors_extracted = static_cast<unsigned>(i + 1);
        pr.last_remainder = max_rem;
    }

    pr.quotient = std::move(best_quotient);

    // ── Пересборка для проверки ──────────────────────────────
    std::vector<real_t> rebuilt = pr.quotient;
    for (size_t i = 0; i < pr.factors_extracted; ++i) {
        rebuilt = poly_multiply(rebuilt, factors[i].poly);
    }
    pr.max_rebuild_err = 0.0;
    for (size_t n = 0; n < h.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double diff = std::abs(h[n] - v);
        if (diff > pr.max_rebuild_err) pr.max_rebuild_err = diff;
    }

    return pr;
}

// ─────────────────────────────────────────────────────────────
//  Hybrid: последовательное деление по 1 фактору с периодическим
//  обновлением текущего полинома из оригинала.
//
//  Каждые refresh_interval шагов:
//    current = poly_divide(H_orig, ∏ factor[0..i])
//  Между обновлениями:
//    current = poly_divide(current, factor[i])  (быстро, стабильно)
//
//  Обновление использует малое произведение (≤ refresh_interval
//  факторов), добавленное к уже проверенному накопленному продукту.
//  Это гибрид: стабильность однофакторного деления + контроль
//  ошибки через периодический пересчёт.
// ─────────────────────────────────────────────────────────────

struct HybridResult {
    std::vector<real_t> quotient;
    unsigned factors_extracted;
    unsigned factors_total;
    double   max_rebuild_err;
};

static HybridResult hybrid_division(
    const std::vector<real_t>& h,
    unsigned N,
    const StopbandZeros& sz,
    unsigned refresh_interval = 4)
{
    HybridResult hr;
    hr.factors_extracted = 0;
    hr.max_rebuild_err   = 0.0;

    // ── Собрать все факторы (чередующийся порядок) ────────────
    struct Factor { std::vector<real_t> poly; };
    std::vector<Factor> factors;

    if (sz.has_dc_zero)
        factors.push_back(Factor{{1.0, -1.0}});
    if (sz.has_nyq_zero)
        factors.push_back(Factor{{1.0, 1.0}});

    {
        std::vector<unsigned> sorted = sz.pair_indices;
        std::sort(sorted.begin(), sorted.end());
        std::vector<unsigned> interleaved;
        size_t lo = 0, hi = sorted.size() - 1;
        bool take_lo = true;
        while (interleaved.size() < sorted.size()) {
            if (take_lo) {
                interleaved.push_back(sorted[lo++]);
            } else {
                interleaved.push_back(sorted[hi--]);
            }
            take_lo = !take_lo;
            if (lo > hi && interleaved.size() < sorted.size()) break;
        }
        for (unsigned k : interleaved) {
            real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
            factors.push_back(Factor{{1.0, -gamma, 1.0}});
        }
    }

    hr.factors_total = static_cast<unsigned>(factors.size());

    double max_h = 0.0;
    for (const auto& v : h)
        if (std::abs(v) > max_h) max_h = std::abs(v);

    static constexpr double QUALITY_THRESHOLD = 1e-6;

    // ── Гибридное извлечение ─────────────────────────────────
    //
    //  confirmed_product = произведение факторов [0..confirmed_end),
    //    для которых качество деления уже проверено.
    //  current = текущий полином (результат последовательных делений).
    //
    //  Каждые refresh_interval шагов:
    //    1) Строим trial_product = confirmed_product × factors[confirmed_end..i]
    //    2) Q_fresh = poly_divide(H_orig, trial_product)
    //    3) Проверяем качество Q_fresh
    //    4) Если ОК → confirmed_product = trial_product, current = Q_fresh
    //       Если нет → откатываемся, останавливаемся

    std::vector<real_t> confirmed_product = {1.0};
    unsigned confirmed_end = 0;
    std::vector<real_t> current = h;
    std::vector<real_t> best_quotient = h;
    unsigned best_extracted = 0;

    for (size_t i = 0; i < factors.size(); ++i) {
        // Последовательное деление текущего полинома на один фактор
        auto [Q_seq, rem_seq] = poly_divide(current, factors[i].poly);
        enforce_symmetry(Q_seq);

        unsigned steps_since_refresh = static_cast<unsigned>(i) - confirmed_end;

        bool need_refresh = (steps_since_refresh + 1 >= refresh_interval)
                         || (i == factors.size() - 1);

        if (need_refresh) {
            // Построить trial_product = confirmed_product × factors[confirmed_end..i]
            std::vector<real_t> trial_product = confirmed_product;
            for (size_t j = confirmed_end; j <= i; ++j) {
                trial_product = poly_multiply(trial_product, factors[j].poly);
            }

            // Разделить ОРИГИНАЛ на trial_product
            auto [Q_fresh, rem_fresh] = poly_divide(h, trial_product);

            double max_rem = 0.0;
            for (const auto& v : rem_fresh) {
                double av = std::abs(v);
                if (av > max_rem) max_rem = av;
            }
            double rel_rem = (max_h > 1e-30) ? max_rem / max_h : max_rem;

            if (rel_rem > QUALITY_THRESHOLD) {
                // Деградация — попробуем меньший блок
                // Откатываемся: берём только то, что в confirmed
                break;
            }

            // Принять: обновить confirmed
            enforce_symmetry(Q_fresh);
            confirmed_product = std::move(trial_product);
            confirmed_end = static_cast<unsigned>(i + 1);
            current = Q_fresh;
            best_quotient = current;
            best_extracted = confirmed_end;
        } else {
            // Принять последовательное деление (без проверки от оригинала)
            current = std::move(Q_seq);
        }
    }

    hr.factors_extracted = best_extracted;
    hr.quotient = std::move(best_quotient);

    // ── Пересборка ───────────────────────────────────────────
    std::vector<real_t> rebuilt = hr.quotient;
    for (size_t i = 0; i < hr.factors_extracted; ++i) {
        rebuilt = poly_multiply(rebuilt, factors[i].poly);
    }
    hr.max_rebuild_err = 0.0;
    for (size_t n = 0; n < h.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double diff = std::abs(h[n] - v);
        if (diff > hr.max_rebuild_err) hr.max_rebuild_err = diff;
    }

    return hr;
}

// ─────────────────────────────────────────────────────────────
//  Рекуррентное деление на biquad (1 − γz⁻¹ + z⁻²)
//  с половинной рекурсией + зеркалирование (как в decompose)
// ─────────────────────────────────────────────────────────────

static bool biquad_half_divide(const std::vector<real_t>& h,
                               real_t gamma,
                               std::vector<real_t>& q)
{
    const size_t len = h.size();
    if (len < 4) return false;

    const size_t qlen = len - 2;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;

    q[0] = h[0];
    if (qlen >= 2)
        q[1] = h[1] + gamma * q[0];
    for (size_t n = 2; n <= mid; ++n)
        q[n] = h[n] + gamma * q[n - 1] - q[n - 2];

    // Чётная длина: доcчитать элемент за серединой
    if (qlen % 2 == 0 && qlen >= 4) {
        size_t center = qlen / 2;
        if (center > mid)
            q[center] = h[center] + gamma * q[center - 1] - q[center - 2];
    }

    // Зеркалирование второй половины
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];

    return true;
}

// ─────────────────────────────────────────────────────────────
//  Рекуррентное деление на (1 ± z⁻¹) + зеркалирование
// ─────────────────────────────────────────────────────────────

static bool first_order_half_divide(const std::vector<real_t>& h,
                                    int sign,  // +1 → (1+z⁻¹), −1 → (1−z⁻¹)
                                    std::vector<real_t>& q)
{
    const size_t len = h.size();
    if (len < 2) return false;

    const size_t qlen = len - 1;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;

    // (1 + s·z⁻¹): H = Q·(1 + s·z⁻¹) → h[n] = q[n] + s·q[n-1]
    //   → q[n] = h[n] − s·q[n-1]
    q[0] = h[0];
    for (size_t n = 1; n <= mid; ++n)
        q[n] = h[n] - static_cast<real_t>(sign) * q[n - 1];

    // Зеркалирование (палиндром / палиндром = палиндром,
    //  но (1−z⁻¹) антисимметричен → частное может менять симметрию;
    //  для фильтров частотной выборки результат всегда палиндром)
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];

    return true;
}

// ─────────────────────────────────────────────────────────────
//  Hybrid-biquad: последовательное деление по одному фактору
//  с использованием biquad_half_divide, с периодическим
//  обновлением полинома путём ПОВТОРНЫХ последовательных
//  делений оригинала (каждое — стабильная half-recurrence).
//
//  Ключевое отличие от hybrid_division:
//    hybrid_division обновляет через poly_divide(H, big_product),
//    где big_product имеет огромные коэффициенты → нестабильно.
//
//    hybrid_biquad_division обновляет через цепочку
//    biquad_half_divide, каждое из которых стабильно.
//    Мы никогда не строим big_product.
// ─────────────────────────────────────────────────────────────

struct HybridBiquadResult {
    std::vector<real_t> quotient;
    unsigned factors_extracted;
    unsigned factors_total;
    double   max_rebuild_err;
};

static HybridBiquadResult hybrid_biquad_division(
    const std::vector<real_t>& h_orig,
    unsigned N,
    const StopbandZeros& sz,
    unsigned refresh_interval = 5)
{
    HybridBiquadResult hbr;
    hbr.factors_extracted = 0;
    hbr.max_rebuild_err   = 0.0;

    // ── Собрать факторы (чередующийся порядок) ───────────────
    struct Factor {
        enum Type { FO, BQ } type;
        int    sign;     // для first-order
        real_t gamma;    // для biquad
    };
    std::vector<Factor> factors;

    if (sz.has_dc_zero)
        factors.push_back({Factor::FO, -1, 0.0});
    if (sz.has_nyq_zero)
        factors.push_back({Factor::FO, +1, 0.0});

    {
        std::vector<unsigned> sorted = sz.pair_indices;
        std::sort(sorted.begin(), sorted.end());
        std::vector<unsigned> interleaved;
        size_t lo = 0, hi = sorted.size() - 1;
        bool take_lo = true;
        while (interleaved.size() < sorted.size()) {
            if (take_lo) interleaved.push_back(sorted[lo++]);
            else         interleaved.push_back(sorted[hi--]);
            take_lo = !take_lo;
            if (lo > hi && interleaved.size() < sorted.size()) break;
        }
        for (unsigned k : interleaved) {
            real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
            factors.push_back({Factor::BQ, 0, gamma});
        }
    }

    hbr.factors_total = static_cast<unsigned>(factors.size());

    // ── Вспомогательные лямбды ───────────────────────────────

    // Применить одно деление на factor[idx]
    auto apply_one = [&](const std::vector<real_t>& poly, size_t idx)
        -> std::vector<real_t>
    {
        std::vector<real_t> q;
        if (factors[idx].type == Factor::FO)
            first_order_half_divide(poly, factors[idx].sign, q);
        else
            biquad_half_divide(poly, factors[idx].gamma, q);
        return q;
    };

    // Полином-множитель для factor[idx] (для пересборки)
    auto factor_poly = [&](size_t idx) -> std::vector<real_t> {
        if (factors[idx].type == Factor::FO)
            return {1.0, static_cast<real_t>(factors[idx].sign)};
        else
            return {1.0, -factors[idx].gamma, 1.0};
    };

    // Последовательно разделить poly на factors[from..to)
    auto seq_divide = [&](const std::vector<real_t>& poly,
                          unsigned from, unsigned to) -> std::vector<real_t>
    {
        std::vector<real_t> cur = poly;
        for (unsigned j = from; j < to; ++j)
            cur = apply_one(cur, j);
        return cur;
    };

    // Проверка качества: пересобрать и сравнить с оригиналом
    double max_h = 0.0;
    for (const auto& v : h_orig)
        if (std::abs(v) > max_h) max_h = std::abs(v);

    static constexpr double QUALITY_THRESHOLD = 1e-6;

    auto check_quality = [&](const std::vector<real_t>& quotient,
                             unsigned n_factors) -> double
    {
        std::vector<real_t> rebuilt = quotient;
        for (unsigned j = 0; j < n_factors; ++j)
            rebuilt = poly_multiply(rebuilt, factor_poly(j));
        double max_err = 0.0;
        for (size_t i = 0; i < h_orig.size(); ++i) {
            double v = (i < rebuilt.size()) ? rebuilt[i] : 0.0;
            double diff = std::abs(h_orig[i] - v);
            if (diff > max_err) max_err = diff;
        }
        return (max_h > 1e-30) ? max_err / max_h : max_err;
    };

    // ── Основной цикл ───────────────────────────────────────
    //
    //  Между обновлениями: последовательные деления (быстро).
    //  На обновлении: заново делим h_orig на все факторы [0..i]
    //  последовательно, каждый через biquad_half_divide.
    //  Если качество плохое — ищем максимальное допустимое число.

    unsigned last_good = 0;
    std::vector<real_t> current = h_orig;
    std::vector<real_t> best_quotient = h_orig;

    for (unsigned i = 0; i < static_cast<unsigned>(factors.size()); ++i) {
        // Последовательный шаг
        current = apply_one(current, i);

        unsigned steps_in_block = (i + 1) - last_good;
        bool do_refresh = (steps_in_block >= refresh_interval)
                       || (i + 1 == static_cast<unsigned>(factors.size()));

        if (do_refresh) {
            // Обновление: пересчитать от оригинала
            std::vector<real_t> fresh = seq_divide(h_orig, 0, i + 1);
            double rel_err = check_quality(fresh, i + 1);

            if (rel_err > QUALITY_THRESHOLD) {
                // Не получилось — ищем максимум между last_good+1 и i
                for (unsigned try_end = i; try_end > last_good; --try_end) {
                    std::vector<real_t> trial = seq_divide(h_orig, 0, try_end);
                    double trial_err = check_quality(trial, try_end);
                    if (trial_err <= QUALITY_THRESHOLD) {
                        best_quotient = std::move(trial);
                        hbr.factors_extracted = try_end;
                        goto done;  // нашли максимум, выходим
                    }
                }
                // Ничего нового не удалось добавить
                goto done;
            }

            // Принять обновление
            current = std::move(fresh);
            best_quotient = current;
            last_good = i + 1;
            hbr.factors_extracted = last_good;
        }
    }

done:
    hbr.quotient = std::move(best_quotient);

    // ── Финальная пересборка ─────────────────────────────────
    {
        std::vector<real_t> rebuilt = hbr.quotient;
        for (unsigned j = 0; j < hbr.factors_extracted; ++j)
            rebuilt = poly_multiply(rebuilt, factor_poly(j));
        hbr.max_rebuild_err = 0.0;
        for (size_t n = 0; n < h_orig.size(); ++n) {
            double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
            double diff = std::abs(h_orig[n] - v);
            if (diff > hbr.max_rebuild_err) hbr.max_rebuild_err = diff;
        }
    }

    return hbr;
}

// ─────────────────────────────────────────────────────────────
//  Однократное деление + полная диагностика
// ─────────────────────────────────────────────────────────────

static SingleDivResult test_single_division(const std::string& label,
                                            const FilterSpec& spec)
{
    SingleDivResult res;
    res.label = label;
    res.N     = spec.N;

    // 1. Спроектировать фильтр
    DirectFIR fir = design_freq_sampling(spec);
    const auto& h = fir.h;
    const unsigned N = spec.N;

    // 2. Найти нули заграждения
    StopbandZeros sz = find_stopband_zeros(spec);
    res.n_stopband_pairs = static_cast<unsigned>(sz.pair_indices.size());
    res.has_dc_zero      = sz.has_dc_zero;
    res.has_nyq_zero     = sz.has_nyq_zero;
    res.total_zeros      = res.n_stopband_pairs * 2
                         + (sz.has_dc_zero  ? 1 : 0)
                         + (sz.has_nyq_zero ? 1 : 0);

    // 3. Построить полный делитель D(z)
    std::vector<real_t> D = build_full_divisor(N, sz);
    res.divisor_degree = static_cast<unsigned>(D.size()) - 1;

    // 4. Однократное деление H(z) / D(z)
    auto [Q, remainder] = poly_divide(h, D);
    res.quotient_degree = (Q.empty()) ? 0 : static_cast<unsigned>(Q.size()) - 1;

    // 4b. Диагностика делителя D(z)
    {
        PolyStats ds = compute_poly_stats(D);
        res.D_max_coeff        = ds.max_abs;
        res.D_dynamic_range_db = ds.dynamic_range;
    }

    // 4c. Блочное деление (альтернатива)
    {
        auto br1 = block_division(h, N, sz, 1);
        res.block1_rebuild_err = br1.max_rebuild_err;

        auto br2 = block_division(h, N, sz, 2);
        res.block2_rebuild_err = br2.max_rebuild_err;

        auto br4 = block_division(h, N, sz, 4);
        res.block4_rebuild_err = br4.max_rebuild_err;

        auto br8 = block_division(h, N, sz, 8);
        res.block8_rebuild_err = br8.max_rebuild_err;
    }

    // 4d. Progressive recompute
    {
        auto pr = progressive_recompute_division(h, N, sz);
        res.prog_factors_extracted = pr.factors_extracted;
        res.prog_factors_total     = pr.factors_total;
        res.prog_rebuild_err       = pr.max_rebuild_err;
        res.prog_remainder_order   = (pr.quotient.empty())
                                   ? 0 : pr.quotient.size() - 1;
    }

    // 4e. Hybrid division (несколько вариантов refresh_interval)
    {
        // Пробуем R=3 — обновление каждые 3 шага
        auto h3 = hybrid_division(h, N, sz, 3);
        // Пробуем R=5
        auto h5 = hybrid_division(h, N, sz, 5);
        // Пробуем R=8
        auto h8 = hybrid_division(h, N, sz, 8);

        // Выбираем лучший по числу выделенных факторов, при
        // прочих равных — по ошибке пересборки
        auto* best = &h3;
        if (h5.factors_extracted > best->factors_extracted ||
            (h5.factors_extracted == best->factors_extracted &&
             h5.max_rebuild_err < best->max_rebuild_err))
            best = &h5;
        if (h8.factors_extracted > best->factors_extracted ||
            (h8.factors_extracted == best->factors_extracted &&
             h8.max_rebuild_err < best->max_rebuild_err))
            best = &h8;

        res.hybrid_factors_extracted = best->factors_extracted;
        res.hybrid_rebuild_err       = best->max_rebuild_err;
        res.hybrid_remainder_order   = (best->quotient.empty())
                                     ? 0 : best->quotient.size() - 1;
    }

    // 4f. Hybrid-biquad division (несколько вариантов refresh_interval)
    {
        auto b3 = hybrid_biquad_division(h, N, sz, 3);
        auto b5 = hybrid_biquad_division(h, N, sz, 5);
        auto b8 = hybrid_biquad_division(h, N, sz, 8);
        auto b12 = hybrid_biquad_division(h, N, sz, 12);

        auto* best = &b3;
        if (b5.factors_extracted > best->factors_extracted ||
            (b5.factors_extracted == best->factors_extracted &&
             b5.max_rebuild_err < best->max_rebuild_err))
            best = &b5;
        if (b8.factors_extracted > best->factors_extracted ||
            (b8.factors_extracted == best->factors_extracted &&
             b8.max_rebuild_err < best->max_rebuild_err))
            best = &b8;
        if (b12.factors_extracted > best->factors_extracted ||
            (b12.factors_extracted == best->factors_extracted &&
             b12.max_rebuild_err < best->max_rebuild_err))
            best = &b12;

        res.hbq_factors_extracted = best->factors_extracted;
        res.hbq_rebuild_err       = best->max_rebuild_err;
        res.hbq_remainder_order   = (best->quotient.empty())
                                  ? 0 : best->quotient.size() - 1;
    }

    // 5. Максимум математического остатка
    res.max_math_remainder = 0.0;
    for (const auto& v : remainder) {
        double av = std::abs(v);
        if (av > res.max_math_remainder)
            res.max_math_remainder = av;
    }

    // 6. Проверка симметрии частного (до принудительной)
    res.quotient_symmetry = check_symmetry(Q);

    // 7. Принудить симметрию частного
    enforce_symmetry(Q);

    // 8. Пересборка: Q * D и сравнение с h
    std::vector<real_t> rebuilt = poly_multiply(Q, D);
    res.max_rebuild_err = 0.0;
    double norm_h_sq = 0.0;
    double err_sq    = 0.0;

    for (size_t n = 0; n < h.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double diff = std::abs(h[n] - v);
        if (diff > res.max_rebuild_err)
            res.max_rebuild_err = diff;
        err_sq   += (h[n] - v) * (h[n] - v);
        norm_h_sq += h[n] * h[n];
    }
    res.rel_rebuild_err = (norm_h_sq > 1e-30)
                        ? std::sqrt(err_sq / norm_h_sq) : 0.0;

    // 9. Сравнить со старым итеративным методом
    CascadeDecomposition old_dec = decompose(fir, true);
    res.old_P_fact = static_cast<unsigned>(old_dec.biquads.size());

    std::vector<real_t> old_rebuilt = recompose(old_dec, N);
    res.old_rebuild_err = 0.0;
    for (size_t n = 0; n < h.size(); ++n) {
        double v = (n < old_rebuilt.size()) ? old_rebuilt[n] : 0.0;
        double diff = std::abs(h[n] - v);
        if (diff > res.old_rebuild_err)
            res.old_rebuild_err = diff;
    }

    return res;
}

// ─────────────────────────────────────────────────────────────
//  Формирование CascadeDecomposition из однократного деления
//  (для последующей фильтрации и сравнения с прямой формой)
// ─────────────────────────────────────────────────────────────

static CascadeDecomposition build_cascade_from_single_div(
    const FilterSpec& spec,
    const std::vector<real_t>& h)
{
    const unsigned N = spec.N;
    StopbandZeros sz = find_stopband_zeros(spec);

    // Полный делитель
    std::vector<real_t> D = build_full_divisor(N, sz);

    // Одно деление
    auto [Q, remainder] = poly_divide(h, D);
    enforce_symmetry(Q);

    // Собрать CascadeDecomposition
    CascadeDecomposition dec;
    dec.gain = 1.0;

    if (sz.has_dc_zero)
        dec.first_order.push_back(FirstOrder{-1});
    if (sz.has_nyq_zero)
        dec.first_order.push_back(FirstOrder{+1});

    for (unsigned k : sz.pair_indices) {
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
        dec.biquads.push_back(Biquad{gamma, k});
    }

    dec.remainder = std::move(Q);
    return dec;
}

// ─────────────────────────────────────────────────────────────
//  Тест фильтрации: каскад (новый) vs прямая свёртка
// ─────────────────────────────────────────────────────────────

struct FilterTestResult {
    std::string label;
    unsigned    N;
    double      snr_db;         // ОСШ каскад vs прямая
    double      max_abs_err;    // max|y_cascade - y_direct|
};

static FilterTestResult test_filtering(const std::string& label,
                                       const FilterSpec& spec)
{
    FilterTestResult ft;
    ft.label = label;
    ft.N     = spec.N;

    DirectFIR fir = design_freq_sampling(spec);

    // Новая декомпозиция через однократное деление
    CascadeDecomposition dec = build_cascade_from_single_div(spec, fir.h);

    // Фильтрация белого шума
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 12345);

    std::vector<sample_t> y_direct  = filter_direct(fir, noise);
    std::vector<sample_t> y_cascade = filter_cascade(dec, noise);

    CompareMetrics cm = compare_signals(y_direct, y_cascade);
    ft.snr_db      = cm.snr_db;
    ft.max_abs_err = cm.max_abs_err;

    return ft;
}

// ─────────────────────────────────────────────────────────────
//  Точка входа
// ─────────────────────────────────────────────────────────────

int main()
{
    std::printf(
        "╔══════════════════════════════════════════════════════════════╗\n"
        "║  Тест: однократное деление H / D_full                      ║\n"
        "║                                                            ║\n"
        "║  Гипотеза: одно деление оригинального H(z) на полный      ║\n"
        "║  делитель D(z) = ∏(каскады) не накапливает ошибок и       ║\n"
        "║  позволяет выделить ВСЕ нули заграждения при любом N.     ║\n"
        "╚══════════════════════════════════════════════════════════════╝\n\n");

    // ── Набор фильтров ──────────────────────────────────────

    struct TestCase {
        FilterSpec  spec;
        std::string label;
    };

    std::vector<TestCase> cases = {
        {{   9, 18000.0,  4000.0,  6000.0}, "ФНЧ-9"},
        {{  15, 32000.0,  4000.0,  6000.0}, "ФНЧ-15"},
        {{  29, 32000.0,  4000.0,  6000.0}, "ФНЧ-29"},
        {{  33, 32000.0,  4000.0,  6000.0}, "ФНЧ-33"},
        {{  49, 32000.0,  4000.0,  6000.0}, "ФНЧ-49"},
        {{  65, 48000.0,  8000.0, 12000.0}, "ФНЧ-65"},
        {{  97, 48000.0,  8000.0, 12000.0}, "ФНЧ-97"},
        {{ 129, 48000.0,  8000.0, 12000.0}, "ФНЧ-129"},
        {{ 257, 48000.0,  8000.0, 12000.0}, "ФНЧ-257"},
        {{ 513, 48000.0,  8000.0, 12000.0}, "ФНЧ-513"},

        // Узкополосные (больше нулей заграждения)
        {{  33, 32000.0,  2000.0,  4000.0}, "узк-33"},
        {{  65, 48000.0,  4000.0,  8000.0}, "узк-65"},
        {{ 129, 48000.0,  4000.0,  8000.0}, "узк-129"},
    };

    // ══════════════════════════════════════════════════════════
    //  Часть 1: Диагностика деления
    // ══════════════════════════════════════════════════════════

    std::printf("═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 1: Диагностика однократного деления\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    std::vector<SingleDivResult> results;
    results.reserve(cases.size());

    for (const auto& tc : cases) {
        std::printf("── %s (N=%u) ", tc.label.c_str(), tc.spec.N);
        std::fflush(stdout);

        SingleDivResult r = test_single_division(tc.label, tc.spec);
        results.push_back(r);

        std::printf("──────────────────────────────────────────\n");
        std::printf("  Нулей заграждения:     %u (пар: %u, dc: %d, nyq: %d)\n",
                    r.total_zeros, r.n_stopband_pairs,
                    r.has_dc_zero ? 1 : 0, r.has_nyq_zero ? 1 : 0);
        std::printf("  Степень делителя D:    %u\n", r.divisor_degree);
        std::printf("  Степень частного Q:    %u\n", r.quotient_degree);
        std::printf("  |мат. остаток|_max:    %.3e\n", r.max_math_remainder);
        std::printf("  |h - Q*D|_max:         %.3e\n", r.max_rebuild_err);
        std::printf("  ||h - Q*D||/||h||:     %.3e\n", r.rel_rebuild_err);
        std::printf("  Симметрия Q до fix:    %.3e\n", r.quotient_symmetry);
        std::printf("  --- делитель D(z) ---\n");
        std::printf("  max|D[n]|:             %.3e\n", r.D_max_coeff);
        std::printf("  Дин. диап. D, дБ:      %.1f\n", r.D_dynamic_range_db);
        std::printf("  --- блочное деление ---\n");
        std::printf("  |err| блок=1:          %.3e\n", r.block1_rebuild_err);
        std::printf("  |err| блок=2:          %.3e\n", r.block2_rebuild_err);
        std::printf("  |err| блок=4:          %.3e\n", r.block4_rebuild_err);
        std::printf("  |err| блок=8:          %.3e\n", r.block8_rebuild_err);
        std::printf("  --- progressive recompute ---\n");
        std::printf("  Факторов выделено:     %u / %u\n",
                    r.prog_factors_extracted, r.prog_factors_total);
        std::printf("  Степень остатка:       %.0f\n", r.prog_remainder_order);
        std::printf("  |h - ĥ|_max (prog):    %.3e\n", r.prog_rebuild_err);
        std::printf("  --- hybrid (poly_divide) ---\n");
        std::printf("  Факторов выделено:     %u / %u\n",
                    r.hybrid_factors_extracted, r.n_stopband_pairs
                    + (r.has_dc_zero ? 1u : 0u) + (r.has_nyq_zero ? 1u : 0u));
        std::printf("  Степень остатка:       %.0f\n", r.hybrid_remainder_order);
        std::printf("  |h - ĥ|_max (hybrid):  %.3e\n", r.hybrid_rebuild_err);
        std::printf("  --- hybrid-biquad (half-recurrence refresh) ---\n");
        std::printf("  Факторов выделено:     %u / %u\n",
                    r.hbq_factors_extracted, r.n_stopband_pairs
                    + (r.has_dc_zero ? 1u : 0u) + (r.has_nyq_zero ? 1u : 0u));
        std::printf("  Степень остатка:       %.0f\n", r.hbq_remainder_order);
        std::printf("  |h - ĥ|_max (hbq):     %.3e\n", r.hbq_rebuild_err);
        std::printf("  --- старый метод ---\n");
        std::printf("  Выделено звеньев:      %u из %u\n",
                    r.old_P_fact, r.n_stopband_pairs);
        std::printf("  |h - ĥ|_max (старый):  %.3e\n", r.old_rebuild_err);
        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Сводная таблица Часть 1
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  СВОДНАЯ ТАБЛИЦА: однократное деление vs итеративное\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    std::printf("%-10s %5s %5s  %5s %5s %5s %12s %12s %12s %6s\n",
                "Фильтр", "N", "P_all",
                "P_hbq", "P_old", "P_hyb",
                "|err|hbq", "|err|old", "|err|hyb", "dQ_hbq");
    std::printf("---------- ----- -----  ----- ----- ----- ------------ ------------ ------------ ------\n");

    for (const auto& r : results) {
        std::printf("%-10s %5u %5u  %5u %5u %5u %12.2e %12.2e %12.2e %6.0f",
                    r.label.c_str(), r.N,
                    r.n_stopband_pairs,
                    r.hbq_factors_extracted,
                    r.old_P_fact,
                    r.hybrid_factors_extracted,
                    r.hbq_rebuild_err,
                    r.old_rebuild_err,
                    r.hybrid_rebuild_err,
                    r.hbq_remainder_order);

        // Отметить лучший метод по числу факторов
        unsigned best_p = std::max({r.hbq_factors_extracted,
                                    r.old_P_fact,
                                    r.hybrid_factors_extracted});
        if (r.hbq_factors_extracted == best_p &&
            r.hbq_factors_extracted > r.old_P_fact)
            std::printf("  ★hbq");
        else if (r.old_P_fact == best_p &&
                 r.old_P_fact > r.hbq_factors_extracted)
            std::printf("  old");
        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Часть 2: Тест фильтрации (новый каскад vs прямая)
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 2: Фильтрация (новый каскад vs прямая свёртка)\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    std::printf("%-10s %5s %12s %12s\n",
                "Фильтр", "N", "|Δy|_max", "ОСШ, дБ");
    std::printf("%-10s %5s %12s %12s\n",
                "------", "---", "-----------", "-----------");

    for (const auto& tc : cases) {
        FilterTestResult ft = test_filtering(tc.label, tc.spec);
        std::printf("%-10s %5u %12.3e %12.1f\n",
                    ft.label.c_str(), ft.N,
                    ft.max_abs_err, ft.snr_db);
    }

    // ══════════════════════════════════════════════════════════
    //  Часть 3: Детальная проверка для N=65 (ключевой случай)
    //  N=65 — первый N, где старый метод ощутимо теряет звенья
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 3: Детальная проверка N=65\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    {
        FilterSpec spec65 = {65, 48000.0, 8000.0, 12000.0};
        DirectFIR fir65 = design_freq_sampling(spec65);

        StopbandZeros sz = find_stopband_zeros(spec65);
        std::vector<real_t> D = build_full_divisor(65, sz);
        auto [Q, rem] = poly_divide(fir65.h, D);

        std::printf("  H(z): степень %zu, h[0]=%.6e, h[%zu]=%.6e\n",
                    fir65.h.size()-1, fir65.h[0], fir65.h.size()-1,
                    fir65.h[fir65.h.size()-1]);
        std::printf("  D(z): степень %zu\n", D.size()-1);
        std::printf("  Q(z): степень %zu\n", Q.size()-1);

        // Печать коэффициентов остатка деления (должны быть ≈ 0)
        std::printf("\n  Математический остаток (должен быть ≈ 0):\n");
        double max_rem = 0.0;
        for (size_t i = 0; i < rem.size(); ++i) {
            if (std::abs(rem[i]) > max_rem)
                max_rem = std::abs(rem[i]);
            if (i < 10 || i >= rem.size() - 3) {
                std::printf("    rem[%2zu] = %+.6e\n", i, rem[i]);
            } else if (i == 10) {
                std::printf("    ... (ещё %zu элементов) ...\n",
                            rem.size() - 13);
            }
        }
        std::printf("  max|rem| = %.3e\n", max_rem);

        // Печать первых/последних коэффициентов частного
        std::printf("\n  Частное Q(z) (первые и последние коэффициенты):\n");
        for (size_t i = 0; i < std::min<size_t>(5, Q.size()); ++i)
            std::printf("    Q[%2zu] = %+.10e\n", i, Q[i]);
        if (Q.size() > 10) {
            std::printf("    ...\n");
            for (size_t i = Q.size()-5; i < Q.size(); ++i)
                std::printf("    Q[%2zu] = %+.10e\n", i, Q[i]);
        }

        // Проверка симметрии
        double sym = check_symmetry(Q);
        std::printf("\n  Симметрия Q до fix:  %.3e\n", sym);
        enforce_symmetry(Q);
        std::printf("  Симметрия Q после:   %.3e\n", check_symmetry(Q));

        // Пересборка
        std::vector<real_t> rebuilt = poly_multiply(Q, D);
        double max_err = 0.0;
        for (size_t n = 0; n < fir65.h.size(); ++n) {
            double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
            double diff = std::abs(fir65.h[n] - v);
            if (diff > max_err) max_err = diff;
        }
        std::printf("  |h - Q*D|_max:       %.3e\n", max_err);

        // Сравнить со старым
        CascadeDecomposition old65 = decompose(fir65, true);
        std::printf("\n  Старый метод: выделено %zu из %zu пар\n",
                    old65.biquads.size(), sz.pair_indices.size());
        std::printf("  Старый остаток: степень %zu\n",
                    old65.remainder.empty() ? 0 : old65.remainder.size()-1);

        std::vector<real_t> old_rebuilt = recompose(old65, 65);
        double old_err = 0.0;
        for (size_t n = 0; n < fir65.h.size(); ++n) {
            double v = (n < old_rebuilt.size()) ? old_rebuilt[n] : 0.0;
            double diff = std::abs(fir65.h[n] - v);
            if (diff > old_err) old_err = diff;
        }
        std::printf("  Старый |h - ĥ|_max:  %.3e\n", old_err);
    }

    // ══════════════════════════════════════════════════════════
    //  Часть 4: Стресс-тест больших N
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 4: Стресс-тест больших N\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    unsigned big_Ns[] = {257, 513, 1025};
    for (unsigned N : big_Ns) {
        FilterSpec spec = {N, 48000.0, 8000.0, 12000.0};
        std::printf("── N=%u ", N);
        std::fflush(stdout);

        DirectFIR fir = design_freq_sampling(spec);
        StopbandZeros sz = find_stopband_zeros(spec);
        std::vector<real_t> D = build_full_divisor(N, sz);
        auto [Q, rem] = poly_divide(fir.h, D);

        double max_rem = 0.0;
        for (const auto& v : rem) {
            double av = std::abs(v);
            if (av > max_rem) max_rem = av;
        }

        enforce_symmetry(Q);
        std::vector<real_t> rebuilt = poly_multiply(Q, D);
        double max_err = 0.0;
        double max_h   = 0.0;
        for (size_t n = 0; n < fir.h.size(); ++n) {
            double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
            double diff = std::abs(fir.h[n] - v);
            if (diff > max_err) max_err = diff;
            if (std::abs(fir.h[n]) > max_h) max_h = std::abs(fir.h[n]);
        }
        double rel_err = (max_h > 1e-30) ? max_err / max_h : max_err;

        std::printf("──────────────────────────────────────────────\n");
        std::printf("  Нулей заграждения (пар): %zu\n", sz.pair_indices.size());
        std::printf("  deg D = %zu, deg Q = %zu\n", D.size()-1, Q.size()-1);
        std::printf("  |мат. остаток|_max:  %.3e\n", max_rem);
        std::printf("  |h - Q*D|_max:       %.3e\n", max_err);
        std::printf("  |h - Q*D|/|h|_max:   %.3e\n", rel_err);
        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Итоговый вердикт
    // ══════════════════════════════════════════════════════════

    std::printf("═══════════════════════════════════════════════════════════════\n");
    std::printf("  ВЕРДИКТ\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    bool all_good = true;
    for (const auto& r : results) {
        if (r.max_math_remainder > 1e-6) {
            std::printf("  ПРОБЛЕМА: %s N=%u — мат. остаток %.3e > 1e-6\n",
                        r.label.c_str(), r.N, r.max_math_remainder);
            all_good = false;
        }
        if (r.max_rebuild_err > 1e-6) {
            std::printf("  ПРОБЛЕМА: %s N=%u — ошибка пересборки %.3e > 1e-6\n",
                        r.label.c_str(), r.N, r.max_rebuild_err);
            all_good = false;
        }
    }

    if (all_good) {
        std::printf("  ✓ Гипотеза ПОДТВЕРЖДЕНА: однократное деление работает\n"
                    "    для всех протестированных N с ошибкой < 1e-6.\n"
                    "    Итеративный подход с адаптивным лимитом ИЗБЫТОЧЕН.\n");
    } else {
        std::printf("  ✗ Гипотеза НЕ подтверждена для всех случаев.\n"
                    "    См. подробности выше.\n");
    }

    std::printf("\n");
    return 0;
}


// ============================================================================
// Original path: cascade_fir/tests/legacy/test_v2.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  test_v2.cpp — Full test of the decompose_v2 pipeline
//
//  Tests:
//    1. Decomposition quality (rebuild error) for all N
//    2. Comparison with old decompose() method
//    3. Filtering accuracy: cascade (v2) vs direct convolution
//    4. Detailed diagnostics for key cases
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <cmath>
#include <cstdio>
#include <vector>
#include <string>
#include <algorithm>
#include <numeric>
#include <cassert>

// ─────────────────────────────────────────────────────────────
//  Summary row for the comparison table
// ─────────────────────────────────────────────────────────────

struct SummaryRow {
    std::string label;
    unsigned    N;

    // Old method (decompose)
    unsigned old_biquads;
    unsigned old_first_order;
    unsigned old_remainder_deg;
    double   old_rebuild_err;

    // New method (decompose_v2)
    unsigned v2_biquads;
    unsigned v2_first_order;
    unsigned v2_remainder_deg;
    double   v2_rebuild_err;

    // Total zeros in filter
    unsigned total_zeros;           // N - 1

    // Filtering comparison (white noise, 100k samples)
    double   snr_old_vs_direct;     // old cascade vs direct
    double   snr_v2_vs_direct;      // v2 cascade vs direct
    double   max_err_v2_vs_direct;
};

// ─────────────────────────────────────────────────────────────
//  Compute rebuild error: recompose cascade → compare with h
// ─────────────────────────────────────────────────────────────

static double compute_rebuild_err(const CascadeDecomposition& dec,
                                  const std::vector<real_t>& h_orig,
                                  unsigned N)
{
    std::vector<real_t> rebuilt = recompose(dec, N);
    double max_err = 0.0;
    for (size_t n = 0; n < h_orig.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double d = std::abs(h_orig[n] - v);
        if (d > max_err) max_err = d;
    }
    return max_err;
}

// ─────────────────────────────────────────────────────────────
//  Run a single test case
// ─────────────────────────────────────────────────────────────

static SummaryRow run_test(const std::string& label,
                           const FilterSpec& spec)
{
    SummaryRow row;
    row.label       = label;
    row.N           = spec.N;
    row.total_zeros = spec.N - 1;

    // ── Design filter ────────────────────────────────────────
    DirectFIR fir = design_freq_sampling(spec);

    // ── Old decomposition ────────────────────────────────────
    CascadeDecomposition dec_old = decompose(fir, true);
    row.old_biquads       = static_cast<unsigned>(dec_old.biquads.size());
    row.old_first_order   = static_cast<unsigned>(dec_old.first_order.size());
    row.old_remainder_deg = dec_old.remainder.empty()
                          ? 0 : static_cast<unsigned>(dec_old.remainder.size()) - 1;
    row.old_rebuild_err   = compute_rebuild_err(dec_old, fir.h, spec.N);

    // ── New decomposition (v2) ───────────────────────────────
    std::fprintf(stderr, "\n── %s (N=%u) ──\n", label.c_str(), spec.N);
    CascadeDecomposition dec_v2 = decompose_v2(fir, true);
    row.v2_biquads       = static_cast<unsigned>(dec_v2.biquads.size());
    row.v2_first_order   = static_cast<unsigned>(dec_v2.first_order.size());
    row.v2_remainder_deg = dec_v2.remainder.empty()
                         ? 0 : static_cast<unsigned>(dec_v2.remainder.size()) - 1;
    row.v2_rebuild_err   = compute_rebuild_err(dec_v2, fir.h, spec.N);

    // ── Filtering comparison ─────────────────────────────────
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);

    std::vector<sample_t> y_direct  = filter_direct(fir, noise);
    std::vector<sample_t> y_old     = filter_cascade(dec_old, noise);
    std::vector<sample_t> y_v2      = filter_cascade(dec_v2, noise);

    CompareMetrics cm_old = compare_signals(y_direct, y_old);
    CompareMetrics cm_v2  = compare_signals(y_direct, y_v2);

    row.snr_old_vs_direct    = cm_old.snr_db;
    row.snr_v2_vs_direct     = cm_v2.snr_db;
    row.max_err_v2_vs_direct = cm_v2.max_abs_err;

    return row;
}

// ─────────────────────────────────────────────────────────────
//  Print detailed decomposition info
// ─────────────────────────────────────────────────────────────

static void print_detail(const std::string& label,
                         const FilterSpec& spec)
{
    DirectFIR fir = design_freq_sampling(spec);

    std::printf("\n════════════════════════════════════════════════════\n");
    std::printf("  Детальный анализ: %s  (N=%u)\n", label.c_str(), spec.N);
    std::printf("════════════════════════════════════════════════════\n");

    // ── h[n] info ────────────────────────────────────────────
    std::printf("\n  Коэффициенты h[n] (первые 5 / последние 5):\n");
    for (unsigned n = 0; n < std::min<unsigned>(5, spec.N); ++n)
        std::printf("    h[%2u] = %+.10e\n", n, fir.h[n]);
    if (spec.N > 10) {
        std::printf("    ...\n");
        for (unsigned n = spec.N - 5; n < spec.N; ++n)
            std::printf("    h[%2u] = %+.10e\n", n, fir.h[n]);
    }

    // ── Check symmetry ───────────────────────────────────────
    double max_asym = 0.0;
    for (unsigned n = 0; n < spec.N / 2; ++n) {
        double d = std::abs(fir.h[n] - fir.h[spec.N - 1 - n]);
        if (d > max_asym) max_asym = d;
    }
    std::printf("\n  Симметрия h: max|h[n] - h[N-1-n]| = %.3e\n", max_asym);

    // ── Old decomposition ────────────────────────────────────
    CascadeDecomposition dec_old = decompose(fir, true);
    double err_old = compute_rebuild_err(dec_old, fir.h, spec.N);

    std::printf("\n  ─── Старый метод (decompose) ───\n");
    std::printf("    Звеньев 1-го порядка: %zu\n", dec_old.first_order.size());
    std::printf("    Звеньев 2-го порядка: %zu\n", dec_old.biquads.size());
    std::printf("    Степень остатка:      %zu\n",
                dec_old.remainder.empty() ? 0 : dec_old.remainder.size() - 1);
    std::printf("    Всего нулей выделено: %u / %u\n",
                dec_old.zeros_extracted(), spec.N - 1);
    std::printf("    Ошибка пересборки:    %.3e\n", err_old);

    // ── New decomposition (v2) ───────────────────────────────
    std::fprintf(stderr, "\n── detail %s (N=%u) ──\n", label.c_str(), spec.N);
    CascadeDecomposition dec_v2 = decompose_v2(fir, true);
    double err_v2 = compute_rebuild_err(dec_v2, fir.h, spec.N);

    std::printf("\n  ─── Новый метод (decompose_v2) ───\n");
    std::printf("    Звеньев 1-го порядка: %zu\n", dec_v2.first_order.size());
    std::printf("    Звеньев 2-го порядка: %zu\n", dec_v2.biquads.size());
    std::printf("    Степень остатка:      %zu\n",
                dec_v2.remainder.empty() ? 0 : dec_v2.remainder.size() - 1);
    std::printf("    Всего нулей выделено: %u / %u\n",
                dec_v2.zeros_extracted(), spec.N - 1);
    std::printf("    Ошибка пересборки:    %.3e\n", err_v2);

    // Print biquad sections
    std::printf("\n    Звенья 2-го порядка:\n");
    std::printf("    %4s  %5s  %+14s  %12s\n", "#", "k", "γ", "f/fs");
    std::printf("    ───── ───── ────────────── ────────────\n");
    for (size_t i = 0; i < dec_v2.biquads.size(); ++i) {
        const auto& bq = dec_v2.biquads[i];
        double f_norm = (bq.k_index > 0)
            ? static_cast<double>(bq.k_index) / spec.N
            : std::acos(bq.gamma / 2.0) / (2.0 * PI);
        const char* src = (bq.k_index > 0) ? "anal" : "num";
        std::printf("    %4zu  %5u  %+14.8f  %12.6f  %s\n",
                    i + 1, bq.k_index, bq.gamma, f_norm, src);
    }

    // Print remainder polynomial
    std::printf("\n    Полином-остаток (степень %zu):\n",
                dec_v2.remainder.size() - 1);
    if (dec_v2.remainder.size() <= 10) {
        for (size_t i = 0; i < dec_v2.remainder.size(); ++i)
            std::printf("      rem[%zu] = %+.10e\n", i, dec_v2.remainder[i]);
    } else {
        for (size_t i = 0; i < 5; ++i)
            std::printf("      rem[%zu] = %+.10e\n", i, dec_v2.remainder[i]);
        std::printf("      ...\n");
        for (size_t i = dec_v2.remainder.size() - 5; i < dec_v2.remainder.size(); ++i)
            std::printf("      rem[%zu] = %+.10e\n", i, dec_v2.remainder[i]);
    }

    // ── Filtering comparison ─────────────────────────────────
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);

    std::vector<sample_t> y_direct  = filter_direct(fir, noise);
    std::vector<sample_t> y_old     = filter_cascade(dec_old, noise);
    std::vector<sample_t> y_v2      = filter_cascade(dec_v2, noise);

    CompareMetrics cm_old = compare_signals(y_direct, y_old);
    CompareMetrics cm_v2  = compare_signals(y_direct, y_v2);

    std::printf("\n  ─── Фильтрация (белый шум, %zu отсчётов) ───\n", noise_len);
    std::printf("    Прямая vs старый каскад:   ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_old.snr_db, cm_old.max_abs_err);
    std::printf("    Прямая vs новый каскад v2: ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_v2.snr_db, cm_v2.max_abs_err);

    // Compare old and v2 outputs directly
    CompareMetrics cm_old_v2 = compare_signals(y_old, y_v2);
    std::printf("    Старый vs новый каскад:    ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_old_v2.snr_db, cm_old_v2.max_abs_err);
}


// ─────────────────────────────────────────────────────────────
//  Main
// ─────────────────────────────────────────────────────────────

int main()
{
    std::printf(
        "╔══════════════════════════════════════════════════════════════╗\n"
        "║  Тест decompose_v2: аналитическое извлечение +             ║\n"
        "║  численный поиск корней остатка                            ║\n"
        "╚══════════════════════════════════════════════════════════════╝\n\n");

    // ── Test cases ───────────────────────────────────────────
    struct TestCase {
        FilterSpec  spec;
        std::string label;
    };

    std::vector<TestCase> cases = {
        {{   9, 18000.0,  4000.0,  6000.0}, "ФНЧ-9"},
        {{  15, 32000.0,  4000.0,  6000.0}, "ФНЧ-15"},
        {{  29, 32000.0,  4000.0,  6000.0}, "ФНЧ-29"},
        {{  33, 32000.0,  4000.0,  6000.0}, "ФНЧ-33"},
        {{  49, 32000.0,  4000.0,  6000.0}, "ФНЧ-49"},
        {{  65, 48000.0,  8000.0, 12000.0}, "ФНЧ-65"},
        {{  97, 48000.0,  8000.0, 12000.0}, "ФНЧ-97"},
        {{ 129, 48000.0,  8000.0, 12000.0}, "ФНЧ-129"},
        {{ 257, 48000.0,  8000.0, 12000.0}, "ФНЧ-257"},

        // Narrow-band (more stopband zeros)
        {{  33, 32000.0,  2000.0,  4000.0}, "узк-33"},
        {{  65, 48000.0,  4000.0,  8000.0}, "узк-65"},

        // Wide-band (fewer stopband zeros)
        {{  33, 32000.0, 12000.0, 14000.0}, "шир-33"},
    };

    // ══════════════════════════════════════════════════════════
    //  Part 1: Summary table
    // ══════════════════════════════════════════════════════════

    std::printf("═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 1: Сводная таблица\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    std::vector<SummaryRow> rows;
    rows.reserve(cases.size());

    for (const auto& tc : cases) {
        rows.push_back(run_test(tc.label, tc.spec));
    }

    // Print summary table
    std::printf("\n");
    std::printf("%-8s %4s │ %5s %4s %12s │ %5s %4s %12s │ %8s %8s\n",
                "", "",
                "P_old", "dQ", "err_old",
                "P_v2", "dQ", "err_v2",
                "SNR_old", "SNR_v2");
    std::printf("%-8s %4s │ %5s %4s %12s │ %5s %4s %12s │ %8s %8s\n",
                "Фильтр", "N",
                "bq", "rem", "",
                "bq", "rem", "",
                "дБ", "дБ");
    std::printf("──────── ──── │ ───── ──── ──────────── │ ───── ──── ──────────── │ ──────── ────────\n");

    for (const auto& r : rows) {
        std::printf("%-8s %4u │ %5u %4u %12.2e │ %5u %4u %12.2e │ %8.1f %8.1f",
                    r.label.c_str(), r.N,
                    r.old_biquads, r.old_remainder_deg, r.old_rebuild_err,
                    r.v2_biquads, r.v2_remainder_deg, r.v2_rebuild_err,
                    r.snr_old_vs_direct, r.snr_v2_vs_direct);

        // Highlight improvements
        if (r.v2_biquads > r.old_biquads)
            std::printf("  ★+%u bq", r.v2_biquads - r.old_biquads);
        else if (r.v2_biquads == r.old_biquads &&
                 r.v2_remainder_deg < r.old_remainder_deg)
            std::printf("  ★rem↓");

        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Part 2: Zeros extracted summary
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 2: Покрытие нулей\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %6s %6s │ %6s %6s │ %4s\n",
                "Фильтр", "N",
                "Z_old", "Z_tot",
                "Z_v2", "Z_tot",
                "Δ");
    std::printf("──────── ──── │ ────── ────── │ ────── ────── │ ────\n");

    for (const auto& r : rows) {
        unsigned z_old = r.old_biquads * 2 + r.old_first_order;
        unsigned z_v2  = r.v2_biquads * 2 + r.v2_first_order;
        int delta = static_cast<int>(z_v2) - static_cast<int>(z_old);

        std::printf("%-8s %4u │ %6u %6u │ %6u %6u │ %+4d",
                    r.label.c_str(), r.N,
                    z_old, r.total_zeros,
                    z_v2, r.total_zeros,
                    delta);

        if (z_v2 == r.total_zeros)
            std::printf("  ПОЛНЫЙ");
        else if (z_v2 > z_old)
            std::printf("  ↑");

        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Part 3: Detailed analysis for key cases
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 3: Детальный анализ ключевых случаев\n");
    std::printf("═══════════════════════════════════════════════════════════════\n");

    // N=33 — the reference case from the thesis
    print_detail("ФНЧ-33", {33, 32000.0, 4000.0, 6000.0});

    // N=65 — first case where old method loses significant zeros
    print_detail("ФНЧ-65", {65, 48000.0, 8000.0, 12000.0});

    // N=129 — stress test
    print_detail("ФНЧ-129", {129, 48000.0, 8000.0, 12000.0});

    // ══════════════════════════════════════════════════════════
    //  Part 4: Verification — impulse response comparison
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 4: Проверка импульсной характеристики\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    // For each filter, pass an impulse through direct and v2 cascade,
    // then compare outputs (should match h[n] for direct, and be close for v2)

    std::printf("%-8s %4s │ %12s %12s │ %12s %12s\n",
                "Фильтр", "N",
                "|Δ_imp|old", "|Δ_imp|v2",
                "ОСШ_old", "ОСШ_v2");
    std::printf("──────── ──── │ ──────────── ──────────── │ ──────────── ────────────\n");

    for (const auto& tc : cases) {
        const FilterSpec& spec = tc.spec;
        DirectFIR fir = design_freq_sampling(spec);

        // Suppress stderr for batch run
        CascadeDecomposition dec_old = decompose(fir, true);
        CascadeDecomposition dec_v2  = decompose_v2(fir, true);

        // Impulse response: length = 2*N to capture full response + tail
        size_t ir_len = spec.N * 2;
        std::vector<sample_t> impulse = generate_impulse(ir_len);

        std::vector<sample_t> y_direct  = filter_direct(fir, impulse);
        std::vector<sample_t> y_old     = filter_cascade(dec_old, impulse);
        std::vector<sample_t> y_v2      = filter_cascade(dec_v2, impulse);

        CompareMetrics cm_old = compare_signals(y_direct, y_old);
        CompareMetrics cm_v2  = compare_signals(y_direct, y_v2);

        std::printf("%-8s %4u │ %12.3e %12.3e │ %12.1f %12.1f\n",
                    tc.label.c_str(), spec.N,
                    cm_old.max_abs_err, cm_v2.max_abs_err,
                    cm_old.snr_db, cm_v2.snr_db);
    }

    // ══════════════════════════════════════════════════════════
    //  Part 5: Computational cost comparison
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 5: Вычислительная стоимость (оценка)\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %5s %5s %5s │ %5s %5s %5s │ %5s\n",
                "Фильтр", "N",
                "M_dir", "M_sym", "M_old",
                "M_v2", "A_v2", "R_v2",
                "экон");
    std::printf("──────── ──── │ ───── ───── ───── │ ───── ───── ───── │ ─────\n");

    for (const auto& tc : cases) {
        const FilterSpec& spec = tc.spec;
        DirectFIR fir = design_freq_sampling(spec);
        CascadeDecomposition dec_old = decompose(fir, true);
        CascadeDecomposition dec_v2  = decompose_v2(fir, true);

        unsigned N = spec.N;

        // Direct form: N multiplications
        unsigned M_direct = N;
        // Symmetric direct: ceil(N/2) multiplications
        unsigned M_sym = (N + 1) / 2;

        // Old cascade: biquads × 1 mult + remainder with symmetry
        unsigned M_old = static_cast<unsigned>(dec_old.biquads.size());
        unsigned rem_old_mults = (static_cast<unsigned>(dec_old.remainder.size()) + 1) / 2;
        M_old += rem_old_mults;

        // V2 cascade: biquads × 1 mult + remainder with symmetry
        unsigned bq_v2 = static_cast<unsigned>(dec_v2.biquads.size());
        unsigned rem_v2_deg = dec_v2.remainder.empty()
                            ? 0 : static_cast<unsigned>(dec_v2.remainder.size()) - 1;
        unsigned rem_v2_mults = (static_cast<unsigned>(dec_v2.remainder.size()) + 1) / 2;
        unsigned M_v2 = bq_v2 + rem_v2_mults;

        // Additions: biquads × 2 + remainder - 1
        unsigned A_v2 = bq_v2 * 2
                      + static_cast<unsigned>(dec_v2.first_order.size())
                      + (dec_v2.remainder.empty() ? 0
                         : static_cast<unsigned>(dec_v2.remainder.size()) - 1);

        // Registers: biquads × 2 + first-order × 1 + remainder
        unsigned R_v2 = bq_v2 * 2
                      + static_cast<unsigned>(dec_v2.first_order.size())
                      + (dec_v2.remainder.empty() ? 0
                         : static_cast<unsigned>(dec_v2.remainder.size()));

        // Savings vs symmetric direct
        double savings = (M_sym > 0)
                       ? 100.0 * (1.0 - static_cast<double>(M_v2) / M_sym)
                       : 0.0;

        std::printf("%-8s %4u │ %5u %5u %5u │ %5u %5u %5u │ %+4.0f%%\n",
                    tc.label.c_str(), N,
                    M_direct, M_sym, M_old,
                    M_v2, A_v2, R_v2,
                    savings);
    }

    // ══════════════════════════════════════════════════════════
    //  Verdict
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════\n");
    std::printf("  ВЕРДИКТ\n");
    std::printf("═══════════════════════════════════════════════════════════════\n\n");

    unsigned total_improved = 0;
    unsigned total_full     = 0;
    unsigned total_degraded = 0;
    unsigned total_cases    = static_cast<unsigned>(rows.size());

    for (const auto& r : rows) {
        unsigned z_old = r.old_biquads * 2 + r.old_first_order;
        unsigned z_v2  = r.v2_biquads * 2 + r.v2_first_order;

        if (z_v2 > z_old) ++total_improved;
        if (z_v2 == r.total_zeros) ++total_full;

        // Check for degradation: v2 rebuild error much worse than old
        if (r.v2_rebuild_err > r.old_rebuild_err * 100.0 &&
            r.v2_rebuild_err > 1e-6) {
            ++total_degraded;
            std::printf("  ⚠ %s: ошибка v2 (%.2e) >> ошибка old (%.2e)\n",
                        r.label.c_str(), r.v2_rebuild_err, r.old_rebuild_err);
        }
    }

    std::printf("\n  Результат:\n");
    std::printf("    Всего случаев:                %u\n", total_cases);
    std::printf("    v2 выделил больше нулей:      %u\n", total_improved);
    std::printf("    v2 полная декомпозиция:       %u\n", total_full);
    std::printf("    Деградация качества (v2>>old):%u\n", total_degraded);

    if (total_improved > 0 && total_degraded == 0) {
        std::printf("\n  ✓ decompose_v2 улучшает декомпозицию без деградации.\n");
    } else if (total_improved > 0) {
        std::printf("\n  ◑ decompose_v2 улучшает декомпозицию, но есть %u случаев\n"
                    "    с повышенной ошибкой. Требуется дополнительная настройка.\n",
                    total_degraded);
    } else {
        std::printf("\n  ✗ decompose_v2 не показал улучшений.\n");
    }

    std::printf("\n");
    return 0;
}


// ============================================================================
// Original path: cascade_fir/tests/legacy/test_v3.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  test_v3.cpp — Full test of the decompose_v3 pipeline
//
//  Tests:
//    1. Summary table: old decompose() vs v2 vs v3
//    2. Zeros coverage: how many zeros extracted by each method
//    3. Detailed analysis for key cases (N=33, 65, 129, 257)
//    4. Impulse response verification
//    5. Computational cost comparison
//    6. Filtering accuracy: cascade (v3) vs direct convolution
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <cmath>
#include <cstdio>
#include <vector>
#include <string>
#include <algorithm>
#include <numeric>
#include <cassert>

// ─────────────────────────────────────────────────────────────
//  Summary row for the comparison table
// ─────────────────────────────────────────────────────────────

struct V3SummaryRow {
    std::string label;
    unsigned    N;

    // Old method (decompose)
    unsigned old_biquads;
    unsigned old_first_order;
    unsigned old_remainder_deg;
    double   old_rebuild_err;

    // V2 method (decompose_v2)
    unsigned v2_biquads;
    unsigned v2_first_order;
    unsigned v2_remainder_deg;
    double   v2_rebuild_err;

    // V3 method (decompose_v3)
    unsigned v3_biquads;
    unsigned v3_first_order;
    unsigned v3_remainder_deg;
    double   v3_rebuild_err;

    // Total zeros in filter
    unsigned total_zeros;           // N - 1

    // Filtering comparison (white noise, 100k samples)
    double   snr_old_vs_direct;
    double   snr_v2_vs_direct;
    double   snr_v3_vs_direct;
    double   max_err_v3_vs_direct;
};

// ─────────────────────────────────────────────────────────────
//  Compute rebuild error: recompose cascade → compare with h
// ─────────────────────────────────────────────────────────────

static double compute_rebuild_err(const CascadeDecomposition& dec,
                                  const std::vector<real_t>& h_orig,
                                  unsigned N)
{
    std::vector<real_t> rebuilt = recompose(dec, N);
    double max_err = 0.0;
    for (size_t n = 0; n < h_orig.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double d = std::abs(h_orig[n] - v);
        if (d > max_err) max_err = d;
    }
    return max_err;
}

// ─────────────────────────────────────────────────────────────
//  Run a single test case
// ─────────────────────────────────────────────────────────────

static V3SummaryRow run_test(const std::string& label,
                             const FilterSpec& spec)
{
    V3SummaryRow row;
    row.label       = label;
    row.N           = spec.N;
    row.total_zeros = spec.N - 1;

    // ── Design filter ────────────────────────────────────────
    DirectFIR fir = design_freq_sampling(spec);

    // ── Old decomposition ────────────────────────────────────
    CascadeDecomposition dec_old = decompose(fir, true);
    row.old_biquads       = static_cast<unsigned>(dec_old.biquads.size());
    row.old_first_order   = static_cast<unsigned>(dec_old.first_order.size());
    row.old_remainder_deg = dec_old.remainder.empty()
                          ? 0 : static_cast<unsigned>(dec_old.remainder.size()) - 1;
    row.old_rebuild_err   = compute_rebuild_err(dec_old, fir.h, spec.N);

    // ── V2 decomposition ─────────────────────────────────────
    std::fprintf(stderr, "\n── v2 %s (N=%u) ──\n", label.c_str(), spec.N);
    CascadeDecomposition dec_v2 = decompose_v2(fir, true);
    row.v2_biquads       = static_cast<unsigned>(dec_v2.biquads.size());
    row.v2_first_order   = static_cast<unsigned>(dec_v2.first_order.size());
    row.v2_remainder_deg = dec_v2.remainder.empty()
                         ? 0 : static_cast<unsigned>(dec_v2.remainder.size()) - 1;
    row.v2_rebuild_err   = compute_rebuild_err(dec_v2, fir.h, spec.N);

    // ── V3 decomposition (NEW) ───────────────────────────────
    std::fprintf(stderr, "\n── v3 %s (N=%u) ──\n", label.c_str(), spec.N);
    CascadeDecomposition dec_v3 = decompose_v3(fir, true);
    row.v3_biquads       = static_cast<unsigned>(dec_v3.biquads.size());
    row.v3_first_order   = static_cast<unsigned>(dec_v3.first_order.size());
    row.v3_remainder_deg = dec_v3.remainder.empty()
                         ? 0 : static_cast<unsigned>(dec_v3.remainder.size()) - 1;
    row.v3_rebuild_err   = compute_rebuild_err(dec_v3, fir.h, spec.N);

    // ── Filtering comparison ─────────────────────────────────
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);

    std::vector<sample_t> y_direct = filter_direct(fir, noise);
    std::vector<sample_t> y_old    = filter_cascade(dec_old, noise);
    std::vector<sample_t> y_v2     = filter_cascade(dec_v2, noise);
    std::vector<sample_t> y_v3     = filter_cascade(dec_v3, noise);

    CompareMetrics cm_old = compare_signals(y_direct, y_old);
    CompareMetrics cm_v2  = compare_signals(y_direct, y_v2);
    CompareMetrics cm_v3  = compare_signals(y_direct, y_v3);

    row.snr_old_vs_direct    = cm_old.snr_db;
    row.snr_v2_vs_direct     = cm_v2.snr_db;
    row.snr_v3_vs_direct     = cm_v3.snr_db;
    row.max_err_v3_vs_direct = cm_v3.max_abs_err;

    return row;
}

// ─────────────────────────────────────────────────────────────
//  Print detailed decomposition info for v3
// ─────────────────────────────────────────────────────────────

static void print_detail(const std::string& label,
                         const FilterSpec& spec)
{
    DirectFIR fir = design_freq_sampling(spec);

    std::printf("\n════════════════════════════════════════════════════\n");
    std::printf("  Детальный анализ: %s  (N=%u)\n", label.c_str(), spec.N);
    std::printf("════════════════════════════════════════════════════\n");

    // ── h[n] info ────────────────────────────────────────────
    std::printf("\n  Коэффициенты h[n] (первые 5 / последние 5):\n");
    for (unsigned n = 0; n < std::min<unsigned>(5, spec.N); ++n)
        std::printf("    h[%2u] = %+.10e\n", n, fir.h[n]);
    if (spec.N > 10) {
        std::printf("    ...\n");
        for (unsigned n = spec.N - 5; n < spec.N; ++n)
            std::printf("    h[%2u] = %+.10e\n", n, fir.h[n]);
    }

    // ── Check symmetry ───────────────────────────────────────
    double max_asym = 0.0;
    for (unsigned n = 0; n < spec.N / 2; ++n) {
        double d = std::abs(fir.h[n] - fir.h[spec.N - 1 - n]);
        if (d > max_asym) max_asym = d;
    }
    std::printf("\n  Симметрия h: max|h[n] - h[N-1-n]| = %.3e\n", max_asym);

    // ── Old decomposition ────────────────────────────────────
    CascadeDecomposition dec_old = decompose(fir, true);
    double err_old = compute_rebuild_err(dec_old, fir.h, spec.N);

    std::printf("\n  ─── Старый метод (decompose) ───\n");
    std::printf("    Звеньев 1-го порядка: %zu\n", dec_old.first_order.size());
    std::printf("    Звеньев 2-го порядка: %zu\n", dec_old.biquads.size());
    std::printf("    Степень остатка:      %zu\n",
                dec_old.remainder.empty() ? size_t(0) : dec_old.remainder.size() - 1);
    std::printf("    Всего нулей выделено: %u / %u\n",
                dec_old.zeros_extracted(), spec.N - 1);
    std::printf("    Ошибка пересборки:    %.3e\n", err_old);

    // ── V2 decomposition ─────────────────────────────────────
    std::fprintf(stderr, "\n── detail v2 %s (N=%u) ──\n", label.c_str(), spec.N);
    CascadeDecomposition dec_v2 = decompose_v2(fir, true);
    double err_v2 = compute_rebuild_err(dec_v2, fir.h, spec.N);

    std::printf("\n  ─── Метод v2 (decompose_v2) ───\n");
    std::printf("    Звеньев 1-го порядка: %zu\n", dec_v2.first_order.size());
    std::printf("    Звеньев 2-го порядка: %zu\n", dec_v2.biquads.size());
    std::printf("    Степень остатка:      %zu\n",
                dec_v2.remainder.empty() ? size_t(0) : dec_v2.remainder.size() - 1);
    std::printf("    Всего нулей выделено: %u / %u\n",
                dec_v2.zeros_extracted(), spec.N - 1);
    std::printf("    Ошибка пересборки:    %.3e\n", err_v2);

    // ── V3 decomposition ─────────────────────────────────────
    std::fprintf(stderr, "\n── detail v3 %s (N=%u) ──\n", label.c_str(), spec.N);
    CascadeDecomposition dec_v3 = decompose_v3(fir, true);
    double err_v3 = compute_rebuild_err(dec_v3, fir.h, spec.N);

    std::printf("\n  ─── Новый метод v3 (decompose_v3) ───\n");
    std::printf("    Звеньев 1-го порядка: %zu\n", dec_v3.first_order.size());
    std::printf("    Звеньев 2-го порядка: %zu\n", dec_v3.biquads.size());
    std::printf("    Степень остатка:      %zu\n",
                dec_v3.remainder.empty() ? size_t(0) : dec_v3.remainder.size() - 1);
    std::printf("    Всего нулей выделено: %u / %u\n",
                dec_v3.zeros_extracted(), spec.N - 1);
    std::printf("    Gain:                 %.10e\n", dec_v3.gain);
    std::printf("    Ошибка пересборки:    %.3e\n", err_v3);

    // Print biquad sections
    std::printf("\n    Звенья 2-го порядка:\n");
    std::printf("    %4s  %5s  %+16s  %14s  %s\n", "#", "k", "γ", "f/fs", "тип");
    std::printf("    ───── ───── ──────────────── ────────────── ────\n");
    for (size_t i = 0; i < dec_v3.biquads.size(); ++i) {
        const auto& bq = dec_v3.biquads[i];
        double f_norm = (bq.k_index > 0)
            ? static_cast<double>(bq.k_index) / spec.N
            : std::acos(std::min(1.0, std::max(-1.0, bq.gamma / 2.0))) / (2.0 * PI);
        const char* src = (bq.k_index > 0) ? "аналит" : "числ.";
        const char* loc = (std::abs(bq.gamma) <= 2.0 + 1e-9) ? "ед.окр" : "вещ.ось";
        std::printf("    %4zu  %5u  %+16.10f  %14.8f  %s (%s)\n",
                    i + 1, bq.k_index, bq.gamma, f_norm, src, loc);
    }

    // Print first-order sections
    if (!dec_v3.first_order.empty()) {
        std::printf("\n    Звенья 1-го порядка:\n");
        for (size_t i = 0; i < dec_v3.first_order.size(); ++i) {
            const char* desc = (dec_v3.first_order[i].sign > 0)
                ? "(1 + z⁻¹), нуль z = -1"
                : "(1 - z⁻¹), нуль z = +1";
            std::printf("    %4zu  sign=%+d  %s\n",
                        i + 1, dec_v3.first_order[i].sign, desc);
        }
    }

    // Print remainder polynomial
    std::printf("\n    Полином-остаток (степень %zu):\n",
                dec_v3.remainder.empty() ? size_t(0) : dec_v3.remainder.size() - 1);
    if (dec_v3.remainder.size() <= 20) {
        for (size_t i = 0; i < dec_v3.remainder.size(); ++i)
            std::printf("      rem[%zu] = %+.10e\n", i, dec_v3.remainder[i]);
    } else {
        for (size_t i = 0; i < 5; ++i)
            std::printf("      rem[%zu] = %+.10e\n", i, dec_v3.remainder[i]);
        std::printf("      ...\n");
        for (size_t i = dec_v3.remainder.size() - 5; i < dec_v3.remainder.size(); ++i)
            std::printf("      rem[%zu] = %+.10e\n", i, dec_v3.remainder[i]);
    }

    // ── Filtering comparison ─────────────────────────────────
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);

    std::vector<sample_t> y_direct = filter_direct(fir, noise);
    std::vector<sample_t> y_old    = filter_cascade(dec_old, noise);
    std::vector<sample_t> y_v2     = filter_cascade(dec_v2, noise);
    std::vector<sample_t> y_v3     = filter_cascade(dec_v3, noise);

    CompareMetrics cm_old    = compare_signals(y_direct, y_old);
    CompareMetrics cm_v2     = compare_signals(y_direct, y_v2);
    CompareMetrics cm_v3     = compare_signals(y_direct, y_v3);
    CompareMetrics cm_v2_v3  = compare_signals(y_v2, y_v3);

    std::printf("\n  ─── Фильтрация (белый шум, %zu отсчётов) ───\n", noise_len);
    std::printf("    Прямая vs старый каскад:    ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_old.snr_db, cm_old.max_abs_err);
    std::printf("    Прямая vs каскад v2:        ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_v2.snr_db, cm_v2.max_abs_err);
    std::printf("    Прямая vs каскад v3:        ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_v3.snr_db, cm_v3.max_abs_err);
    std::printf("    Каскад v2 vs каскад v3:     ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_v2_v3.snr_db, cm_v2_v3.max_abs_err);

    // ── Impulse response check ───────────────────────────────
    size_t ir_len = spec.N * 2;
    std::vector<sample_t> impulse = generate_impulse(ir_len);

    std::vector<sample_t> ir_direct = filter_direct(fir, impulse);
    std::vector<sample_t> ir_v3     = filter_cascade(dec_v3, impulse);

    CompareMetrics cm_ir = compare_signals(ir_direct, ir_v3);
    std::printf("\n    Импульсная: прямая vs v3:   ОСШ = %.1f дБ,  |Δy| = %.3e\n",
                cm_ir.snr_db, cm_ir.max_abs_err);
}


// ─────────────────────────────────────────────────────────────
//  Main
// ─────────────────────────────────────────────────────────────

int main()
{
    std::printf(
        "╔══════════════════════════════════════════════════════════════╗\n"
        "║  Тест decompose_v3: ПОЛНАЯ каскадная факторизация          ║\n"
        "║  (однократное деление + Аберта-Эрлиха без ограничений)     ║\n"
        "╚══════════════════════════════════════════════════════════════╝\n\n");

    // ── Test cases ───────────────────────────────────────────
    struct TestCase {
        FilterSpec  spec;
        std::string label;
    };

    std::vector<TestCase> cases = {
        {{   9, 18000.0,  4000.0,  6000.0}, "ФНЧ-9"},
        {{  15, 32000.0,  4000.0,  6000.0}, "ФНЧ-15"},
        {{  29, 32000.0,  4000.0,  6000.0}, "ФНЧ-29"},
        {{  33, 32000.0,  4000.0,  6000.0}, "ФНЧ-33"},
        {{  49, 32000.0,  4000.0,  6000.0}, "ФНЧ-49"},
        {{  65, 48000.0,  8000.0, 12000.0}, "ФНЧ-65"},
        {{  97, 48000.0,  8000.0, 12000.0}, "ФНЧ-97"},
        {{ 129, 48000.0,  8000.0, 12000.0}, "ФНЧ-129"},
        {{ 257, 48000.0,  8000.0, 12000.0}, "ФНЧ-257"},

        // Narrow-band (more stopband zeros)
        {{  33, 32000.0,  2000.0,  4000.0}, "узк-33"},
        {{  65, 48000.0,  4000.0,  8000.0}, "узк-65"},

        // Wide-band (fewer stopband zeros)
        {{  33, 32000.0, 12000.0, 14000.0}, "шир-33"},
    };

    // ══════════════════════════════════════════════════════════
    //  Part 1: Summary table (old vs v2 vs v3)
    // ══════════════════════════════════════════════════════════

    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 1: Сводная таблица (old / v2 / v3)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::vector<V3SummaryRow> rows;
    rows.reserve(cases.size());

    for (const auto& tc : cases) {
        rows.push_back(run_test(tc.label, tc.spec));
    }

    // Print summary table header
    std::printf("\n");
    std::printf("%-8s %4s │ %4s %4s %10s │ %4s %4s %10s │ %4s %4s %10s │ %8s %8s %8s\n",
                "", "",
                "Bq", "dR", "err",
                "Bq", "dR", "err",
                "Bq", "dR", "err",
                "SNR_old", "SNR_v2", "SNR_v3");
    std::printf("%-8s %4s │ %4s %4s %10s │ %4s %4s %10s │ %4s %4s %10s │ %8s %8s %8s\n",
                "Фильтр", "N",
                "", "", "OLD",
                "", "", "V2",
                "", "", "V3",
                "дБ", "дБ", "дБ");
    std::printf("──────── ──── │ ──── ──── ────────── │ ──── ──── ────────── │ ──── ──── ────────── │ ──────── ──────── ────────\n");

    for (const auto& r : rows) {
        std::printf("%-8s %4u │ %4u %4u %10.2e │ %4u %4u %10.2e │ %4u %4u %10.2e │ %8.1f %8.1f %8.1f",
                    r.label.c_str(), r.N,
                    r.old_biquads, r.old_remainder_deg, r.old_rebuild_err,
                    r.v2_biquads, r.v2_remainder_deg, r.v2_rebuild_err,
                    r.v3_biquads, r.v3_remainder_deg, r.v3_rebuild_err,
                    r.snr_old_vs_direct, r.snr_v2_vs_direct, r.snr_v3_vs_direct);

        // Highlight full decomposition
        unsigned z_v3 = r.v3_biquads * 2 + r.v3_first_order;
        if (z_v3 == r.total_zeros)
            std::printf("  ★ПОЛНЫЙ");
        else if (r.v3_remainder_deg <= 4)
            std::printf("  ◆почти");

        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Part 2: Zeros coverage comparison
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 2: Покрытие нулей (old / v2 / v3)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %6s %6s │ %6s %6s │ %6s %6s │ %6s %6s\n",
                "Фильтр", "N",
                "Z_old", "Z_tot",
                "Z_v2", "Z_tot",
                "Z_v3", "Z_tot",
                "Δ_v3", "Rem_v3");
    std::printf("──────── ──── │ ────── ────── │ ────── ────── │ ────── ────── │ ────── ──────\n");

    for (const auto& r : rows) {
        unsigned z_old = r.old_biquads * 2 + r.old_first_order;
        unsigned z_v2  = r.v2_biquads * 2 + r.v2_first_order;
        unsigned z_v3  = r.v3_biquads * 2 + r.v3_first_order;
        int delta_v3 = static_cast<int>(z_v3) - static_cast<int>(z_old);

        std::printf("%-8s %4u │ %6u %6u │ %6u %6u │ %6u %6u │ %+6d %6u",
                    r.label.c_str(), r.N,
                    z_old, r.total_zeros,
                    z_v2, r.total_zeros,
                    z_v3, r.total_zeros,
                    delta_v3, r.v3_remainder_deg);

        if (z_v3 == r.total_zeros)
            std::printf("  ПОЛНЫЙ");
        else {
            double pct = 100.0 * z_v3 / r.total_zeros;
            std::printf("  %.0f%%", pct);
        }

        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Part 3: Detailed analysis for key cases
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 3: Детальный анализ ключевых случаев\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n");

    // N=33 — the reference case from the thesis
    print_detail("ФНЧ-33", {33, 32000.0, 4000.0, 6000.0});

    // N=65 — critical: v2 had remainder degree 42 here!
    print_detail("ФНЧ-65", {65, 48000.0, 8000.0, 12000.0});

    // N=129 — stress test
    print_detail("ФНЧ-129", {129, 48000.0, 8000.0, 12000.0});

    // N=257 — big stress test
    print_detail("ФНЧ-257", {257, 48000.0, 8000.0, 12000.0});

    // ══════════════════════════════════════════════════════════
    //  Part 4: Impulse response verification
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 4: Проверка импульсной характеристики (direct vs v3)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %12s %12s │ %12s %12s │ %12s %12s\n",
                "Фильтр", "N",
                "|Δ_imp|old", "ОСШ_old",
                "|Δ_imp|v2", "ОСШ_v2",
                "|Δ_imp|v3", "ОСШ_v3");
    std::printf("──────── ──── │ ──────────── ──────────── │ ──────────── ──────────── │ ──────────── ────────────\n");

    for (const auto& tc : cases) {
        const FilterSpec& spec = tc.spec;
        DirectFIR fir = design_freq_sampling(spec);

        CascadeDecomposition dec_old = decompose(fir, true);
        CascadeDecomposition dec_v2  = decompose_v2(fir, true);
        CascadeDecomposition dec_v3  = decompose_v3(fir, true);

        size_t ir_len = spec.N * 2;
        std::vector<sample_t> impulse = generate_impulse(ir_len);

        std::vector<sample_t> y_direct = filter_direct(fir, impulse);
        std::vector<sample_t> y_old    = filter_cascade(dec_old, impulse);
        std::vector<sample_t> y_v2     = filter_cascade(dec_v2, impulse);
        std::vector<sample_t> y_v3     = filter_cascade(dec_v3, impulse);

        CompareMetrics cm_old = compare_signals(y_direct, y_old);
        CompareMetrics cm_v2  = compare_signals(y_direct, y_v2);
        CompareMetrics cm_v3  = compare_signals(y_direct, y_v3);

        std::printf("%-8s %4u │ %12.3e %12.1f │ %12.3e %12.1f │ %12.3e %12.1f\n",
                    tc.label.c_str(), spec.N,
                    cm_old.max_abs_err, cm_old.snr_db,
                    cm_v2.max_abs_err, cm_v2.snr_db,
                    cm_v3.max_abs_err, cm_v3.snr_db);
    }

    // ══════════════════════════════════════════════════════════
    //  Part 5: Computational cost comparison
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 5: Вычислительная стоимость (оценка)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %5s %5s │ %5s %5s │ %5s %5s │ %6s %6s\n",
                "Фильтр", "N",
                "M_dir", "M_sym",
                "M_old", "R_old",
                "M_v3", "R_v3",
                "э_old%", "э_v3%");
    std::printf("──────── ──── │ ───── ───── │ ───── ───── │ ───── ───── │ ────── ──────\n");

    for (const auto& tc : cases) {
        const FilterSpec& spec = tc.spec;
        DirectFIR fir = design_freq_sampling(spec);
        CascadeDecomposition dec_old = decompose(fir, true);
        CascadeDecomposition dec_v3  = decompose_v3(fir, true);

        unsigned N = spec.N;

        // Direct form: N multiplications
        unsigned M_direct = N;
        // Symmetric direct: ceil(N/2) multiplications
        unsigned M_sym = (N + 1) / 2;

        // Old cascade: biquads × 1 mult + remainder with symmetry
        unsigned M_old = static_cast<unsigned>(dec_old.biquads.size());
        unsigned rem_old_mults = (static_cast<unsigned>(dec_old.remainder.size()) + 1) / 2;
        M_old += rem_old_mults;
        unsigned R_old = static_cast<unsigned>(dec_old.biquads.size()) * 2
                       + static_cast<unsigned>(dec_old.first_order.size())
                       + static_cast<unsigned>(dec_old.remainder.size());

        // V3 cascade: biquads × 1 mult + remainder with symmetry
        unsigned bq_v3 = static_cast<unsigned>(dec_v3.biquads.size());
        unsigned rem_v3_mults = (static_cast<unsigned>(dec_v3.remainder.size()) + 1) / 2;
        unsigned M_v3 = bq_v3 + rem_v3_mults;
        unsigned R_v3 = bq_v3 * 2
                      + static_cast<unsigned>(dec_v3.first_order.size())
                      + static_cast<unsigned>(dec_v3.remainder.size());

        // Savings vs symmetric direct
        double sav_old = (M_sym > 0) ? 100.0 * (1.0 - static_cast<double>(M_old) / M_sym) : 0.0;
        double sav_v3  = (M_sym > 0) ? 100.0 * (1.0 - static_cast<double>(M_v3) / M_sym) : 0.0;

        std::printf("%-8s %4u │ %5u %5u │ %5u %5u │ %5u %5u │ %+5.0f%% %+5.0f%%\n",
                    tc.label.c_str(), N,
                    M_direct, M_sym,
                    M_old, R_old,
                    M_v3, R_v3,
                    sav_old, sav_v3);
    }

    // ══════════════════════════════════════════════════════════
    //  Part 6: White-noise filtering SNR summary
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 6: Качество фильтрации (белый шум, 100k отсчётов)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %10s %10s %10s │ %10s\n",
                "Фильтр", "N",
                "SNR_old", "SNR_v2", "SNR_v3",
                "|Δy|_v3");
    std::printf("──────── ──── │ ────────── ────────── ────────── │ ──────────\n");

    for (const auto& r : rows) {
        std::printf("%-8s %4u │ %10.1f %10.1f %10.1f │ %10.3e\n",
                    r.label.c_str(), r.N,
                    r.snr_old_vs_direct, r.snr_v2_vs_direct, r.snr_v3_vs_direct,
                    r.max_err_v3_vs_direct);
    }

    // ══════════════════════════════════════════════════════════
    //  Verdict
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ВЕРДИКТ\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    unsigned total_improved_over_old = 0;
    unsigned total_improved_over_v2  = 0;
    unsigned total_full              = 0;
    unsigned total_near_full         = 0;  // remainder deg <= 4
    unsigned total_degraded          = 0;
    unsigned total_cases             = static_cast<unsigned>(rows.size());

    for (const auto& r : rows) {
        unsigned z_old = r.old_biquads * 2 + r.old_first_order;
        unsigned z_v2  = r.v2_biquads * 2 + r.v2_first_order;
        unsigned z_v3  = r.v3_biquads * 2 + r.v3_first_order;

        if (z_v3 > z_old) ++total_improved_over_old;
        if (z_v3 > z_v2)  ++total_improved_over_v2;
        if (z_v3 == r.total_zeros) ++total_full;
        else if (r.v3_remainder_deg <= 4) ++total_near_full;

        // Check for degradation: v3 rebuild error much worse than old
        if (r.v3_rebuild_err > r.old_rebuild_err * 1000.0 &&
            r.v3_rebuild_err > 1e-3) {
            ++total_degraded;
            std::printf("  ⚠ %s: ошибка v3 (%.2e) >> ошибка old (%.2e)\n",
                        r.label.c_str(), r.v3_rebuild_err, r.old_rebuild_err);
        }
    }

    std::printf("\n  Результат:\n");
    std::printf("    Всего случаев:                   %u\n", total_cases);
    std::printf("    v3 выделил больше нулей чем old:  %u\n", total_improved_over_old);
    std::printf("    v3 выделил больше нулей чем v2:   %u\n", total_improved_over_v2);
    std::printf("    Полная декомпозиция (v3):         %u\n", total_full);
    std::printf("    Почти полная (остаток ≤ 4):       %u\n", total_near_full);
    std::printf("    Деградация качества (v3>>old):    %u\n", total_degraded);

    // Summary of key improvement: remainder degrees
    std::printf("\n  Ключевое улучшение — степень остатка:\n");
    std::printf("    %-8s  %4s  │  %6s  %6s  %6s\n", "Фильтр", "N", "old", "v2", "v3");
    std::printf("    ────────  ────  │  ──────  ──────  ──────\n");
    for (const auto& r : rows) {
        std::printf("    %-8s  %4u  │  %6u  %6u  %6u",
                    r.label.c_str(), r.N,
                    r.old_remainder_deg, r.v2_remainder_deg, r.v3_remainder_deg);
        if (r.v3_remainder_deg < r.old_remainder_deg)
            std::printf("  ↓↓");
        std::printf("\n");
    }

    if (total_full > 0 || total_near_full > 0) {
        std::printf("\n  ✓ decompose_v3 достигает полной (или почти полной) каскадной реализации!\n");
        std::printf("    Полностью: %u/%u фильтров, почти полностью: %u/%u\n",
                    total_full, total_cases, total_near_full, total_cases);
    }

    if (total_degraded > 0) {
        std::printf("\n  ◑ Есть %u случаев с повышенной ошибкой. Требуется настройка.\n",
                    total_degraded);
    }

    if (total_full == 0 && total_near_full == 0 && total_improved_over_old == 0) {
        std::printf("\n  ✗ decompose_v3 не показал улучшений.\n");
    }

    std::printf("\n");
    return 0;
}


// ============================================================================
// Original path: cascade_fir/tests/legacy/test_v4.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  test_v4.cpp — Test decompose_v4 (extended-precision pipeline)
//
//  Compares decompose (old), decompose_v2, decompose_v3, decompose_v4
//  across all filter sizes: rebuild error, filtering SNR.
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <cmath>
#include <cstdio>
#include <vector>
#include <string>
#include <algorithm>

// ─────────────────────────────────────────────────────────────
//  Helpers
// ─────────────────────────────────────────────────────────────

static double compute_rebuild_err(const CascadeDecomposition& dec,
                                  const std::vector<real_t>& h_orig,
                                  unsigned N)
{
    std::vector<real_t> rebuilt = recompose(dec, N);
    double max_err = 0.0;
    for (size_t n = 0; n < h_orig.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double d = std::abs(h_orig[n] - v);
        if (d > max_err) max_err = d;
    }
    return max_err;
}

static double compute_filter_snr(const DirectFIR& fir,
                                 const CascadeDecomposition& dec)
{
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);
    std::vector<sample_t> y_direct  = filter_direct(fir, noise);
    std::vector<sample_t> y_cascade = filter_cascade(dec, noise);

    double sig = 0.0, err = 0.0;
    for (size_t n = 0; n < noise_len; ++n) {
        double d = static_cast<double>(y_direct[n]);
        double c = static_cast<double>(y_cascade[n]);
        sig += d * d;
        err += (d - c) * (d - c);
    }
    if (err > 0.0)
        return 10.0 * std::log10(sig / err);
    return 300.0;
}

// ─────────────────────────────────────────────────────────────
//  Main
// ─────────────────────────────────────────────────────────────

int main()
{
    std::printf(
        "╔══════════════════════════════════════════════════════════════╗\n"
        "║  Тест decompose_v4: расширенная точность (__float128)      ║\n"
        "║  + companion matrix eigenvalues (LAPACK dgeev)             ║\n"
        "╚══════════════════════════════════════════════════════════════╝\n\n");

    struct TestCase {
        FilterSpec  spec;
        std::string label;
    };

    std::vector<TestCase> cases = {
        {{   9, 18000.0,  4000.0,  6000.0}, "ФНЧ-9"},
        {{  15, 32000.0,  4000.0,  6000.0}, "ФНЧ-15"},
        {{  29, 32000.0,  4000.0,  6000.0}, "ФНЧ-29"},
        {{  33, 32000.0,  4000.0,  6000.0}, "ФНЧ-33"},
        {{  49, 32000.0,  4000.0,  6000.0}, "ФНЧ-49"},
        {{  65, 48000.0,  8000.0, 12000.0}, "ФНЧ-65"},
        {{  97, 48000.0,  8000.0, 12000.0}, "ФНЧ-97"},
        {{ 129, 48000.0,  8000.0, 12000.0}, "ФНЧ-129"},
        {{ 257, 48000.0,  8000.0, 12000.0}, "ФНЧ-257"},
        {{  33, 32000.0,  2000.0,  4000.0}, "узк-33"},
        {{  65, 48000.0,  4000.0,  8000.0}, "узк-65"},
        {{  33, 32000.0, 12000.0, 14000.0}, "шир-33"},
    };

    // ══════════════════════════════════════════════════════════
    //  Part 1: Summary table
    // ══════════════════════════════════════════════════════════

    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 1: Сводная таблица (old / v2 / v3 / v4)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %4s %4s %10s │ %4s %4s %10s │ %4s %4s %4s %10s │ %4s %4s %4s %10s\n",
                "", "",
                "Bq", "dR", "err_old",
                "Bq", "dR", "err_v2",
                "Bq", "Qt", "dR", "err_v3",
                "Bq", "Qt", "dR", "err_v4");
    std::printf("──────── ──── │ ──── ──── ────────── │ ──── ──── ────────── │ ──── ──── ──── ────────── │ ──── ──── ──── ──────────\n");

    struct SummaryRow {
        std::string label;
        unsigned N;
        unsigned old_bq, old_rem;
        double old_err;
        unsigned v2_bq, v2_rem;
        double v2_err;
        unsigned v3_bq, v3_qt, v3_rem;
        double v3_err;
        unsigned v4_bq, v4_qt, v4_rem;
        double v4_err;
        double snr_old, snr_v2, snr_v3, snr_v4;
    };

    std::vector<SummaryRow> rows;
    rows.reserve(cases.size());

    for (const auto& tc : cases) {
        const FilterSpec& spec = tc.spec;
        DirectFIR fir = design_freq_sampling(spec);

        SummaryRow row;
        row.label = tc.label;
        row.N = spec.N;

        // Old
        CascadeDecomposition dec_old = decompose(fir, true);
        row.old_bq  = static_cast<unsigned>(dec_old.biquads.size());
        row.old_rem = dec_old.remainder.empty() ? 0 : static_cast<unsigned>(dec_old.remainder.size()) - 1;
        row.old_err = compute_rebuild_err(dec_old, fir.h, spec.N);

        // V2
        CascadeDecomposition dec_v2 = decompose_v2(fir, true);
        row.v2_bq  = static_cast<unsigned>(dec_v2.biquads.size());
        row.v2_rem = dec_v2.remainder.empty() ? 0 : static_cast<unsigned>(dec_v2.remainder.size()) - 1;
        row.v2_err = compute_rebuild_err(dec_v2, fir.h, spec.N);

        // V3
        CascadeDecomposition dec_v3 = decompose_v3(fir, true);
        row.v3_bq  = static_cast<unsigned>(dec_v3.biquads.size());
        row.v3_qt  = static_cast<unsigned>(dec_v3.quartics.size());
        row.v3_rem = dec_v3.remainder.empty() ? 0 : static_cast<unsigned>(dec_v3.remainder.size()) - 1;
        row.v3_err = compute_rebuild_err(dec_v3, fir.h, spec.N);

        // V4
        CascadeDecomposition dec_v4 = decompose_v4(fir, true);
        row.v4_bq  = static_cast<unsigned>(dec_v4.biquads.size());
        row.v4_qt  = static_cast<unsigned>(dec_v4.quartics.size());
        row.v4_rem = dec_v4.remainder.empty() ? 0 : static_cast<unsigned>(dec_v4.remainder.size()) - 1;
        row.v4_err = compute_rebuild_err(dec_v4, fir.h, spec.N);

        // Filtering SNR
        row.snr_old = compute_filter_snr(fir, dec_old);
        row.snr_v2  = compute_filter_snr(fir, dec_v2);
        row.snr_v3  = compute_filter_snr(fir, dec_v3);
        row.snr_v4  = compute_filter_snr(fir, dec_v4);

        rows.push_back(row);

        std::printf("%-8s %4u │ %4u %4u %10.2e │ %4u %4u %10.2e │ %4u %4u %4u %10.2e │ %4u %4u %4u %10.2e\n",
                    row.label.c_str(), row.N,
                    row.old_bq, row.old_rem, row.old_err,
                    row.v2_bq, row.v2_rem, row.v2_err,
                    row.v3_bq, row.v3_qt, row.v3_rem, row.v3_err,
                    row.v4_bq, row.v4_qt, row.v4_rem, row.v4_err);
    }

    // ══════════════════════════════════════════════════════════
    //  Part 2: Filtering SNR
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 2: SNR каскадной фильтрации (direct vs cascade, 100k отсчётов)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %10s %10s %10s %10s\n",
                "Фильтр", "N", "SNR_old", "SNR_v2", "SNR_v3", "SNR_v4");
    std::printf("──────── ──── │ ────────── ────────── ────────── ──────────\n");

    for (const auto& r : rows) {
        std::printf("%-8s %4u │ %10.1f %10.1f %10.1f %10.1f",
                    r.label.c_str(), r.N,
                    r.snr_old, r.snr_v2, r.snr_v3, r.snr_v4);

        // Mark best
        double best = std::max({r.snr_old, r.snr_v2, r.snr_v3, r.snr_v4});
        if (r.snr_v4 >= best - 0.5)
            std::printf("  ★v4");
        else if (r.snr_v3 >= best - 0.5)
            std::printf("  ★v3");
        else if (r.snr_v2 >= best - 0.5)
            std::printf("  ★v2");

        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Part 3: Zeros coverage & remainder degree
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 3: Степень остатка (меньше = лучше)\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    std::printf("%-8s %4s │ %6s %6s %6s %6s\n",
                "Фильтр", "N", "old", "v2", "v3", "v4");
    std::printf("──────── ──── │ ────── ────── ────── ──────\n");

    for (const auto& r : rows) {
        std::printf("%-8s %4u │ %6u %6u %6u %6u",
                    r.label.c_str(), r.N,
                    r.old_rem, r.v2_rem, r.v3_rem, r.v4_rem);
        if (r.v4_rem == 0)
            std::printf("  ★ПОЛНЫЙ");
        std::printf("\n");
    }

    // ══════════════════════════════════════════════════════════
    //  Part 4: Detailed v4 analysis for key cases
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ЧАСТЬ 4: Детальный анализ v4\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n");

    std::vector<FilterSpec> detail_specs = {
        { 33, 32000.0,  4000.0,  6000.0},
        { 49, 32000.0,  4000.0,  6000.0},
        { 65, 48000.0,  8000.0, 12000.0},
        { 97, 48000.0,  8000.0, 12000.0},
        {129, 48000.0,  8000.0, 12000.0},
        {257, 48000.0,  8000.0, 12000.0},
    };

    for (const auto& spec : detail_specs) {
        DirectFIR fir = design_freq_sampling(spec);
        CascadeDecomposition dec = decompose_v4(fir, true);

        double rebuild_err = compute_rebuild_err(dec, fir.h, spec.N);
        double snr = compute_filter_snr(fir, dec);

        std::printf("\n  ── N=%u ──\n", spec.N);
        std::printf("    Biquads:    %zu (stopband) + ... (numerical)\n",
                    dec.biquads.size());
        std::printf("    Quartics:   %zu\n", dec.quartics.size());
        std::printf("    First-order:%zu\n", dec.first_order.size());
        std::printf("    Remainder:  deg %zu\n",
                    dec.remainder.empty() ? size_t(0) : dec.remainder.size() - 1);
        std::printf("    Gain:       %.10e\n",
                    dec.remainder.empty() ? dec.gain : dec.remainder[0]);
        std::printf("    Rebuild err:%.3e\n", rebuild_err);
        std::printf("    Filter SNR: %.1f dB\n", snr);

        // Print biquad sections
        if (dec.biquads.size() <= 40) {
            std::printf("    Biquads:\n");
            for (size_t i = 0; i < dec.biquads.size(); ++i) {
                const auto& bq = dec.biquads[i];
                const char* src = (bq.k_index > 0) ? "sb" : "num";
                double f_norm;
                if (bq.k_index > 0) {
                    f_norm = static_cast<double>(bq.k_index) / spec.N;
                } else {
                    double clamped = std::max(-1.0, std::min(1.0, bq.gamma / 2.0));
                    f_norm = std::acos(clamped) / (2.0 * PI);
                }
                const char* loc = (std::abs(bq.gamma) <= 2.0 + 1e-9) ? "UC" : "off";
                std::printf("      [%2zu] γ=%+14.10f  f/fs=%10.6f  %s %s\n",
                            i + 1, bq.gamma, f_norm, src, loc);
            }
        }

        // Print quartic sections
        if (!dec.quartics.empty()) {
            std::printf("    Quartics:\n");
            for (size_t i = 0; i < dec.quartics.size(); ++i) {
                const auto& qt = dec.quartics[i];
                std::printf("      [%2zu] α=%+14.10f  β=%14.10f\n",
                            i + 1, qt.alpha, qt.beta);
            }
        }

        // Impulse response check
        size_t ir_len = spec.N * 2;
        std::vector<sample_t> impulse = generate_impulse(ir_len);
        std::vector<sample_t> y_direct  = filter_direct(fir, impulse);
        std::vector<sample_t> y_cascade = filter_cascade(dec, impulse);
        CompareMetrics cm = compare_signals(y_direct, y_cascade);
        std::printf("    Impulse: max|Δ|=%.3e  SNR=%.1f dB\n",
                    cm.max_abs_err, cm.snr_db);
    }

    // ══════════════════════════════════════════════════════════
    //  Verdict
    // ══════════════════════════════════════════════════════════

    std::printf("\n═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n");
    std::printf("  ВЕРДИКТ\n");
    std::printf("═══════════════════════════════════════════════════════════════════════════════════════════════════════════════\n\n");

    unsigned full_count = 0;
    unsigned good_count = 0;
    unsigned total = static_cast<unsigned>(rows.size());

    for (const auto& r : rows) {
        if (r.v4_rem == 0) ++full_count;
        if (r.snr_v4 > 40.0) ++good_count;
    }

    std::printf("    Полная каскадная реализация (rem=0): %u / %u\n", full_count, total);
    std::printf("    SNR > 40 дБ:                        %u / %u\n", good_count, total);

    std::printf("\n    Ключевое улучшение — степень остатка:\n");
    std::printf("    %-8s  %4s  │  %6s  %6s  %6s  %6s\n",
                "Фильтр", "N", "old", "v2", "v3", "v4");
    std::printf("    ────────  ────  │  ──────  ──────  ──────  ──────\n");
    for (const auto& r : rows) {
        std::printf("    %-8s  %4u  │  %6u  %6u  %6u  %6u",
                    r.label.c_str(), r.N,
                    r.old_rem, r.v2_rem, r.v3_rem, r.v4_rem);
        if (r.v4_rem == 0 && r.old_rem > 0)
            std::printf("  ↓↓ПОЛНЫЙ");
        std::printf("\n");
    }

    if (full_count == total) {
        std::printf("\n  ✓ decompose_v4 достиг полной каскадной реализации для ВСЕХ фильтров!\n");
    } else if (full_count > 0) {
        std::printf("\n  ◑ decompose_v4 достиг полной реализации для %u/%u фильтров.\n",
                    full_count, total);
    }

    std::printf("\n");
    return 0;
}

