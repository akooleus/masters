// ═══════════════════════════════════════════════════════════════
//  liquid_compare.cpp
//  Архивный сравнительный пример.
//
//  Сопоставляет три реализации КИХ-фильтра:
//
//    1. Прямая свёртка         — собственная реализация
//    2. Baseline-каскад        — `decompose()`
//    3. liquid-dsp firfilt_rrrf — внешний эталон
//
//  Файл сохранён как optional/archive demo для внешнего сравнения.
//  Основная кодовая ветка проекта сейчас — exact-first.
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"
#include <cstdlib>

// Определена в smith_example.cpp
extern void run_smith_example();

// ─────────────────────────────────────────────────────────────
//  benchmark — замер времени трёх реализаций
//
//  Каждая реализация прогоняется num_runs раз на сигнале
//  длины num_samples.  Возвращается среднее время в мкс.
// ─────────────────────────────────────────────────────────────

TimingResult benchmark(const DirectFIR& fir,
                       const CascadeDecomposition& dec,
                       size_t num_samples,
                       unsigned num_runs)
{
    TimingResult result{};
    result.num_samples = num_samples;
    result.num_runs    = num_runs;

    // Генерируем сигнал один раз
    std::vector<sample_t> x = generate_white_noise(num_samples, 777);

    // ── Прогрев кэша ─────────────────────────────────────────
    {
        auto y = filter_direct(fir, x);
        (void)y;
    }
    {
        auto y = filter_cascade(dec, x);
        (void)y;
    }
    {
        auto y = filter_liquid(fir, x);
        (void)y;
    }

    // ── Замер: прямая свёртка (своя) ─────────────────────────
    {
        using clock = std::chrono::high_resolution_clock;
        auto t0 = clock::now();
        for (unsigned r = 0; r < num_runs; ++r) {
            auto y = filter_direct(fir, x);
            // Предотвратить оптимизацию компилятором:
            if (y[num_samples / 2] == -999.0f) std::abort();
        }
        auto t1 = clock::now();
        double total_us = std::chrono::duration<double, std::micro>(t1 - t0).count();
        result.direct_us = total_us / num_runs;
    }

    // ── Замер: каскадная фильтрация (своя) ───────────────────
    {
        using clock = std::chrono::high_resolution_clock;
        auto t0 = clock::now();
        for (unsigned r = 0; r < num_runs; ++r) {
            auto y = filter_cascade(dec, x);
            if (y[num_samples / 2] == -999.0f) std::abort();
        }
        auto t1 = clock::now();
        double total_us = std::chrono::duration<double, std::micro>(t1 - t0).count();
        result.cascade_us = total_us / num_runs;
    }

    // ── Замер: liquid-dsp (эталон) ───────────────────────────
    {
        using clock = std::chrono::high_resolution_clock;
        auto t0 = clock::now();
        for (unsigned r = 0; r < num_runs; ++r) {
            auto y = filter_liquid(fir, x);
            if (y[num_samples / 2] == -999.0f) std::abort();
        }
        auto t1 = clock::now();
        double total_us = std::chrono::duration<double, std::micro>(t1 - t0).count();
        result.liquid_us = total_us / num_runs;
    }

    return result;
}

// ─────────────────────────────────────────────────────────────
//  run_comparison — полное сравнение для одного фильтра
// ─────────────────────────────────────────────────────────────

static void run_comparison(const FilterSpec& spec,
                           const std::string& label,
                           const std::vector<real_t>& transition = {})
{
    std::cout << "\n"
              << "╔══════════════════════════════════════════════════════╗\n"
              << "║  " << label << "\n"
              << "║  N=" << spec.N
              << "  fs=" << spec.fs
              << "  f_pass=" << spec.f_pass
              << "  f_stop=" << spec.f_stop << "\n"
              << "╚══════════════════════════════════════════════════════╝\n";

    // ──────────────────────────────────────────────────────────
    //  A.  Проектирование
    // ──────────────────────────────────────────────────────────

    std::cout << "\n--- A. Проектирование ---\n";
    DirectFIR fir = design_freq_sampling(spec, transition);

    std::cout << "  Длина фильтра:     " << fir.length() << "\n";
    std::cout << "  k_pass (посл. 1):  " << spec.k_pass() << "\n";
    std::cout << "  k_stop (первый 0): " << spec.k_stop() << "\n";

    // Напечатать первые и последние коэффициенты
    std::cout << "  h[0..4]: ";
    for (unsigned n = 0; n < 5 && n < fir.length(); ++n) {
        std::cout << std::scientific << std::setprecision(6) << fir.h[n] << " ";
    }
    std::cout << "\n  h[N-5..N-1]: ";
    for (unsigned n = (fir.length() > 5 ? fir.length() - 5 : 0); n < fir.length(); ++n) {
        std::cout << std::scientific << std::setprecision(6) << fir.h[n] << " ";
    }
    std::cout << std::defaultfloat << "\n";

    // Проверка симметрии
    double max_asym = 0.0;
    for (unsigned n = 0; n < fir.length() / 2; ++n) {
        double diff = std::abs(fir.h[n] - fir.h[fir.length() - 1 - n]);
        if (diff > max_asym) max_asym = diff;
    }
    std::cout << "  Симметрия max|h[n]-h[N-1-n]|: "
              << std::scientific << max_asym << std::defaultfloat << "\n";

    // ──────────────────────────────────────────────────────────
    //  B.  Каскадная декомпозиция
    // ──────────────────────────────────────────────────────────

    std::cout << "\n--- B. Каскадная декомпозиция ---\n";
    CascadeDecomposition dec = decompose(fir, true);
    print_decomposition(dec, spec);

    // ──────────────────────────────────────────────────────────
    //  C.  Верификация: пересборка коэффициентов
    // ──────────────────────────────────────────────────────────

    std::cout << "\n--- C. Верификация: пересборка ---\n";
    std::vector<real_t> h_recomp = recompose(dec, fir.length());

    CoeffMetrics cm_coeff = compare_coeffs(fir.h, h_recomp);
    cm_coeff.print("h_orig vs h_recomp");

    // АЧХ
    const unsigned NFFT = 8192;
    std::vector<real_t> mag_orig   = compute_magnitude_response(fir.h, NFFT);
    std::vector<real_t> mag_recomp = compute_magnitude_response(h_recomp, NFFT);

    double max_mag_diff = 0.0;
    for (unsigned i = 0; i < NFFT; ++i) {
        double diff = std::abs(mag_orig[i] - mag_recomp[i]);
        if (diff > max_mag_diff) max_mag_diff = diff;
    }
    std::cout << "  max|ΔH(ω)|: " << std::scientific << max_mag_diff
              << std::defaultfloat << "\n";

    // ──────────────────────────────────────────────────────────
    //  D.  Импульсная характеристика: три реализации vs h[n]
    // ──────────────────────────────────────────────────────────

    std::cout << "\n--- D. Импульсная характеристика ---\n";

    const size_t ir_len = fir.length() * 2;
    std::vector<sample_t> impulse = generate_impulse(ir_len);

    std::vector<sample_t> y_direct  = filter_direct(fir, impulse);
    std::vector<sample_t> y_cascade = filter_cascade(dec, impulse);
    std::vector<sample_t> y_liquid  = filter_liquid(fir, impulse);

    // Сформировать «идеальный» выход: h[n] приведённый к float
    std::vector<sample_t> y_ideal(ir_len, 0.0f);
    for (unsigned n = 0; n < fir.length(); ++n) {
        y_ideal[n] = static_cast<sample_t>(fir.h[n]);
    }

    CompareMetrics cm_d_ideal = compare_signals(y_direct,  y_ideal);
    CompareMetrics cm_c_ideal = compare_signals(y_cascade, y_ideal);
    CompareMetrics cm_l_ideal = compare_signals(y_liquid,  y_ideal);
    CompareMetrics cm_d_c     = compare_signals(y_direct,  y_cascade);
    CompareMetrics cm_d_l     = compare_signals(y_direct,  y_liquid);
    CompareMetrics cm_c_l     = compare_signals(y_cascade, y_liquid);

    cm_d_ideal.print("прямая      vs h[n]");
    cm_c_ideal.print("каскадная   vs h[n]");
    cm_l_ideal.print("liquid-dsp  vs h[n]");
    cm_d_c.print    ("прямая      vs каскадная");
    cm_d_l.print    ("прямая      vs liquid-dsp");
    cm_c_l.print    ("каскадная   vs liquid-dsp");

    // ──────────────────────────────────────────────────────────
    //  E.  Белый шум: три реализации, попарное сравнение
    // ──────────────────────────────────────────────────────────

    std::cout << "\n--- E. Белый шум (100 000 отсчётов) ---\n";

    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);

    std::vector<sample_t> yn_direct  = filter_direct(fir, noise);
    std::vector<sample_t> yn_cascade = filter_cascade(dec, noise);
    std::vector<sample_t> yn_liquid  = filter_liquid(fir, noise);

    CompareMetrics cmn_d_c = compare_signals(yn_direct,  yn_cascade);
    CompareMetrics cmn_d_l = compare_signals(yn_direct,  yn_liquid);
    CompareMetrics cmn_c_l = compare_signals(yn_cascade, yn_liquid);

    cmn_d_c.print("прямая      vs каскадная");
    cmn_d_l.print("прямая      vs liquid-dsp");
    cmn_c_l.print("каскадная   vs liquid-dsp");

    // ──────────────────────────────────────────────────────────
    //  F.  Замер быстродействия
    // ──────────────────────────────────────────────────────────

    std::cout << "\n--- F. Быстродействие ---\n";

    // Для коротких фильтров — больше отсчётов, для длинных — меньше
    size_t bench_samples = (spec.N > 100) ? 200000 : 500000;
    unsigned bench_runs  = (spec.N > 100) ? 20     : 50;

    TimingResult timing = benchmark(fir, dec, bench_samples, bench_runs);
    timing.print();
}

// ─────────────────────────────────────────────────────────────
//  print_summary_table — сводная таблица по всем фильтрам
// ─────────────────────────────────────────────────────────────

struct SummaryRow {
    std::string label;
    unsigned N;
    unsigned biquads;
    unsigned first_order;
    unsigned rem_order;
    double coeff_err;
    double snr_direct_cascade;
    double snr_direct_liquid;
    double time_direct_us;
    double time_cascade_us;
    double time_liquid_us;
};

static void print_summary_table(const std::vector<SummaryRow>& rows)
{
    std::cout << "\n"
              << "╔══════════════════════════════════════════════════════════════════════════════════════════╗\n"
              << "║                              СВОДНАЯ ТАБЛИЦА                                           ║\n"
              << "╚══════════════════════════════════════════════════════════════════════════════════════════╝\n";

    std::cout << std::left
              << std::setw(12) << "Фильтр"
              << std::setw(6)  << "N"
              << std::setw(6)  << "Biq"
              << std::setw(5)  << "FO"
              << std::setw(8)  << "RemOrd"
              << std::setw(12) << "max|Δh|"
              << std::setw(12) << "SNR d/c"
              << std::setw(12) << "SNR d/l"
              << std::setw(10) << "t_dir,мкс"
              << std::setw(10) << "t_cas,мкс"
              << std::setw(10) << "t_liq,мкс"
              << std::setw(8)  << "Ускор."
              << "\n";

    std::cout << std::string(111, '-') << "\n";

    for (const auto& r : rows) {
        std::cout << std::left
                  << std::setw(12) << r.label
                  << std::setw(6)  << r.N
                  << std::setw(6)  << r.biquads
                  << std::setw(5)  << r.first_order
                  << std::setw(8)  << r.rem_order
                  << std::setw(12) << std::scientific << std::setprecision(2) << r.coeff_err
                  << std::setw(12) << std::fixed << std::setprecision(1) << r.snr_direct_cascade
                  << std::setw(12) << r.snr_direct_liquid
                  << std::setw(10) << std::setprecision(0) << r.time_direct_us
                  << std::setw(10) << r.time_cascade_us
                  << std::setw(10) << r.time_liquid_us
                  << std::setw(8)  << std::setprecision(2)
                  << (r.time_cascade_us > 0 ? r.time_direct_us / r.time_cascade_us : 0.0)
                  << "\n";
    }

    std::cout << std::defaultfloat << "\n";
}

// ─────────────────────────────────────────────────────────────
//  collect_summary — запуск одного фильтра, сбор метрик
// ─────────────────────────────────────────────────────────────

static SummaryRow collect_summary(const FilterSpec& spec,
                                  const std::string& label,
                                  const std::vector<real_t>& transition = {})
{
    SummaryRow row;
    row.label = label;
    row.N     = spec.N;

    // Проектирование
    DirectFIR fir = design_freq_sampling(spec, transition);

    // Декомпозиция
    CascadeDecomposition dec = decompose(fir, true);
    row.biquads     = static_cast<unsigned>(dec.biquads.size());
    row.first_order = static_cast<unsigned>(dec.first_order.size());
    row.rem_order   = static_cast<unsigned>(dec.remainder.size()) - 1;

    // Пересборка
    std::vector<real_t> h_recomp = recompose(dec, fir.length());
    CoeffMetrics cm = compare_coeffs(fir.h, h_recomp);
    row.coeff_err = cm.max_abs_err;

    // Фильтрация шума
    const size_t noise_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(noise_len, 42);

    std::vector<sample_t> yn_d = filter_direct(fir, noise);
    std::vector<sample_t> yn_c = filter_cascade(dec, noise);
    std::vector<sample_t> yn_l = filter_liquid(fir, noise);

    CompareMetrics cm_dc = compare_signals(yn_d, yn_c);
    CompareMetrics cm_dl = compare_signals(yn_d, yn_l);

    row.snr_direct_cascade = cm_dc.snr_db;
    row.snr_direct_liquid  = cm_dl.snr_db;

    // Быстродействие
    size_t bench_samples = (spec.N > 100) ? 200000 : 500000;
    unsigned bench_runs  = (spec.N > 100) ? 20     : 50;

    TimingResult t = benchmark(fir, dec, bench_samples, bench_runs);
    row.time_direct_us  = t.direct_us;
    row.time_cascade_us = t.cascade_us;
    row.time_liquid_us  = t.liquid_us;

    return row;
}

// ═══════════════════════════════════════════════════════════════
//  main
// ═══════════════════════════════════════════════════════════════

int main(int argc, char* argv[])
{
    // ──────────────────────────────────────────────────────────
    //  Режим работы:
    //    без аргументов      — полный отчёт (подробный + сводка)
    //    --summary           — только сводная таблица
    //    --detail N fs fp fs — подробный отчёт для одного фильтра
    // ──────────────────────────────────────────────────────────

    bool summary_only = false;
    bool single_detail = false;
    FilterSpec single_spec{};

    if (argc >= 2 && std::string(argv[1]) == "--summary") {
        summary_only = true;
    } else if (argc >= 6 && std::string(argv[1]) == "--detail") {
        single_detail = true;
        single_spec.N      = static_cast<unsigned>(std::atoi(argv[2]));
        single_spec.fs     = std::atof(argv[3]);
        single_spec.f_pass = std::atof(argv[4]);
        single_spec.f_stop = std::atof(argv[5]);
    }

    std::cout
        << "╔══════════════════════════════════════════════════════════════╗\n"
        << "║  Сравнение реализаций КИХ-фильтра частотной выборки        ║\n"
        << "║                                                            ║\n"
        << "║  Прямая свёртка (своя)   vs   Каскад (свой)                ║\n"
        << "║                          vs   liquid-dsp (эталон)          ║\n"
        << "╚══════════════════════════════════════════════════════════════╝\n";

    // ──────────────────────────────────────────────────────────
    //  Набор тестовых фильтров
    // ──────────────────────────────────────────────────────────

    struct FilterCase {
        FilterSpec spec;
        std::string label;
    };

    std::vector<FilterCase> filters = {
        // ФНЧ, разные N
        {{  9, 18000.0,  4000.0,  6000.0}, "ФНЧ-9"},
        {{ 15, 32000.0,  4000.0,  6000.0}, "ФНЧ-15"},
        {{ 29, 32000.0,  4000.0,  6000.0}, "ФНЧ-29"},
        {{ 33, 32000.0,  4000.0,  6000.0}, "ФНЧ-33"},
        {{ 49, 32000.0,  4000.0,  6000.0}, "ФНЧ-49"},
        {{ 65, 48000.0,  8000.0, 12000.0}, "ФНЧ-65"},
        {{ 97, 48000.0,  8000.0, 12000.0}, "ФНЧ-97"},
        {{129, 48000.0,  8000.0, 12000.0}, "ФНЧ-129"},

        // Узкополосный ФНЧ (больше нулей в полосе заграждения)
        {{ 33, 32000.0,  2000.0,  4000.0}, "узкий-33"},
        {{ 65, 48000.0,  4000.0,  8000.0}, "узкий-65"},

        // Широкополосный ФНЧ (мало нулей в полосе заграждения)
        {{ 33, 32000.0, 12000.0, 14000.0}, "широк-33"},
    };

    // ──────────────────────────────────────────────────────────
    //  Одиночный подробный отчёт
    // ──────────────────────────────────────────────────────────

    if (single_detail) {
        run_comparison(single_spec, "Пользовательский фильтр");
        return 0;
    }

    // ──────────────────────────────────────────────────────────
    //  Полный отчёт / сводная таблица
    // ──────────────────────────────────────────────────────────

    if (!summary_only) {
        // Подробный отчёт для нескольких ключевых фильтров
        run_comparison(filters[0].spec, filters[0].label);    // N=9
        run_comparison(filters[3].spec, filters[3].label);    // N=33
        run_comparison(filters[7].spec, filters[7].label);    // N=129
    }

    // ──────────────────────────────────────────────────────────
    //  Пример Смита (BPF 40-го порядка, Table II/III)
    // ──────────────────────────────────────────────────────────

    run_smith_example();

    // Сводная таблица для всех фильтров
    std::cout << "\n\nСбор сводной таблицы (это может занять несколько минут)...\n";

    std::vector<SummaryRow> summary;
    for (const auto& fc : filters) {
        std::cout << "  Обработка " << fc.label << " (N=" << fc.spec.N << ")...\n";
        summary.push_back(collect_summary(fc.spec, fc.label));
    }

    print_summary_table(summary);

    // ──────────────────────────────────────────────────────────
    //  Выводы
    // ──────────────────────────────────────────────────────────

    std::cout
        << "══════════════════════════════════════════════════════════════\n"
        << "  ВЫВОДЫ:\n"
        << "\n"
        << "  1. Корректность: каскадная декомпозиция точна до уровня\n"
        << "     машинной арифметики (max|Δh| ~ 1e-14 для N=33).\n"
        << "\n"
        << "  2. Эквивалентность: все три реализации дают совпадающие\n"
        << "     результаты фильтрации с точностью формата float\n"
        << "     (SNR > 60 дБ для прямая vs каскадная).\n"
        << "\n"
        << "  3. Прямая и liquid-dsp дают практически идентичный выход\n"
        << "     (SNR > 100 дБ), что подтверждает корректность\n"
        << "     собственной реализации прямой свёртки.\n"
        << "\n"
        << "  4. Расхождение каскадной с прямой формой обусловлено\n"
        << "     двумя факторами: (a) промежуточные отсчёты хранятся\n"
        << "     в float между звеньями, (b) порядок арифметических\n"
        << "     операций отличается.\n"
        << "\n"
        << "  5. Быстродействие каскадной формы зависит от соотношения\n"
        << "     числа выделенных нулей и общей длины фильтра.\n"
        << "══════════════════════════════════════════════════════════════\n";

    return 0;
}



// ============================================================================
// Original path: cascade_fir/examples/legacy/numeric_diagnostics.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  numeric_diagnostics.cpp
//  Архивная диагностика численной устойчивости legacy v2/v3/v4
//  пайплайнов.
//
//  Сохранена для сравнений и регрессии против exact-first,
//  по умолчанию не собирается.
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <algorithm>
#include <cmath>
#include <complex>
#include <cstdio>
#include <limits>
#include <string>
#include <vector>

namespace {

using cd = std::complex<double>;
using cld = std::complex<long double>;

struct StageStats {
    std::string label;
    double max_in_abs = 0.0;
    double max_out_abs = 0.0;
    double rms_in = 0.0;
    double rms_out = 0.0;
};

static double stage_scale_first_order(int sign)
{
    return std::max(1.0, 1.0 + std::abs(static_cast<double>(sign)));
}

static double stage_scale_biquad(double gamma)
{
    return std::max(1.0, 2.0 + std::abs(gamma));
}

static double stage_scale_quartic(double alpha, double beta)
{
    return std::max(1.0, 2.0 + 2.0 * std::abs(alpha) + std::abs(beta));
}

template <typename T>
struct FilterStateT {
    std::vector<T> h;
    std::vector<T> buf;
    size_t idx = 0;

    explicit FilterStateT(const std::vector<real_t>& coeffs)
    {
        h.assign(coeffs.begin(), coeffs.end());
        buf.assign(h.size(), T(0));
    }

    T push(T x)
    {
        if (h.empty()) {
            return T(0);
        }

        buf[idx] = x;

        T acc = 0;
        size_t pos = idx;
        for (size_t n = 0; n < h.size(); ++n) {
            acc += h[n] * buf[pos];
            pos = (pos == 0) ? (h.size() - 1) : (pos - 1);
        }

        idx = (idx + 1) % h.size();
        return acc;
    }
};

struct RuntimeDiagnostics {
    std::vector<double> y_double;
    std::vector<long double> y_long_double;
    std::vector<StageStats> stages;
};

static double compute_response_max_err(const std::vector<real_t>& h1,
                                       const std::vector<real_t>& h2,
                                       unsigned nfft = 4096)
{
    const std::vector<real_t> mag1 = compute_magnitude_response(h1, nfft);
    const std::vector<real_t> mag2 = compute_magnitude_response(h2, nfft);

    double max_err = 0.0;
    for (size_t i = 0; i < mag1.size() && i < mag2.size(); ++i) {
        max_err = std::max(max_err, std::abs(mag1[i] - mag2[i]));
    }
    return max_err;
}

static CompareMetrics compare_double_to_float(const std::vector<double>& y1,
                                              const std::vector<sample_t>& y2)
{
    std::vector<sample_t> lhs(y1.size());
    for (size_t i = 0; i < y1.size(); ++i) {
        lhs[i] = static_cast<sample_t>(y1[i]);
    }
    return compare_signals(lhs, y2);
}

static CompareMetrics compare_long_double_to_double(
    const std::vector<long double>& y1,
    const std::vector<double>& y2)
{
    const size_t n = std::min(y1.size(), y2.size());
    std::vector<sample_t> lhs(n);
    std::vector<sample_t> rhs(n);
    for (size_t i = 0; i < n; ++i) {
        lhs[i] = static_cast<sample_t>(y1[i]);
        rhs[i] = static_cast<sample_t>(y2[i]);
    }
    return compare_signals(lhs, rhs);
}

static std::vector<cd> evaluate_sections_without_gain(
    const CascadeDecomposition& dec,
    unsigned nfft)
{
    std::vector<cd> values(nfft, cd(1.0, 0.0));

    for (unsigned i = 0; i < nfft; ++i) {
        const double theta = PI * static_cast<double>(i) / static_cast<double>(nfft);
        const cd z_inv = std::polar(1.0, -theta);
        const cd z_inv2 = z_inv * z_inv;
        const cd z_inv3 = z_inv2 * z_inv;
        const cd z_inv4 = z_inv2 * z_inv2;

        cd acc = 1.0;
        for (const auto& fo : dec.first_order) {
            acc *= (1.0 + static_cast<double>(fo.sign) * z_inv);
        }
        for (const auto& bq : dec.biquads) {
            acc *= (1.0 - bq.gamma * z_inv + z_inv2);
        }
        for (const auto& qt : dec.quartics) {
            acc *= (1.0 - qt.alpha * z_inv + qt.beta * z_inv2
                        - qt.alpha * z_inv3 + z_inv4);
        }
        values[i] = acc;
    }

    return values;
}

static std::vector<cd> evaluate_fir_response(const std::vector<real_t>& h,
                                             unsigned nfft)
{
    std::vector<cd> values(nfft, cd(0.0, 0.0));
    for (unsigned i = 0; i < nfft; ++i) {
        const double theta = PI * static_cast<double>(i) / static_cast<double>(nfft);
        const cd z_inv = std::polar(1.0, -theta);
        cd z_pow = 1.0;
        cd acc = 0.0;
        for (real_t coeff : h) {
            acc += coeff * z_pow;
            z_pow *= z_inv;
        }
        values[i] = acc;
    }
    return values;
}

static double current_scalar_gain(const CascadeDecomposition& dec)
{
    if (dec.remainder.size() == 1) {
        return dec.remainder[0] * dec.gain;
    }
    return dec.gain;
}

static double estimate_gain_ls_passband(const DirectFIR& fir,
                                        const CascadeDecomposition& dec,
                                        unsigned nfft = 4096)
{
    const std::vector<cd> H = evaluate_fir_response(fir.h, nfft);
    const std::vector<cd> S = evaluate_sections_without_gain(dec, nfft);

    const unsigned k_pass = std::min<unsigned>(
        fir.spec.k_pass(),
        nfft > 0 ? (nfft - 1) : 0);

    cd num = 0.0;
    double den = 0.0;

    for (unsigned k = 0; k <= k_pass; ++k) {
        num += std::conj(S[k]) * H[k];
        den += std::norm(S[k]);
    }

    if (den < 1e-30) {
        return current_scalar_gain(dec);
    }
    return (num / den).real();
}

static std::vector<real_t> rebuild_with_gain_override(
    const CascadeDecomposition& dec,
    double gain_override)
{
    std::vector<real_t> rebuilt = {gain_override};

    for (const auto& bq : dec.biquads) {
        rebuilt = poly_multiply(rebuilt, {1.0, -bq.gamma, 1.0});
    }
    for (const auto& qt : dec.quartics) {
        rebuilt = poly_multiply(rebuilt, {1.0, -qt.alpha, qt.beta, -qt.alpha, 1.0});
    }
    for (const auto& fo : dec.first_order) {
        rebuilt = poly_multiply(rebuilt, {1.0, static_cast<real_t>(fo.sign)});
    }
    return rebuilt;
}

static RuntimeDiagnostics run_runtime_diagnostics(
    const CascadeDecomposition& dec,
    const std::vector<sample_t>& x)
{
    RuntimeDiagnostics rd;
    rd.y_double.resize(x.size());
    rd.y_long_double.resize(x.size());

    const size_t total_stages =
        dec.first_order.size() +
        dec.biquads.size() +
        dec.quartics.size() +
        1 + 1;
    rd.stages.reserve(total_stages);

    for (size_t i = 0; i < dec.first_order.size(); ++i) {
        rd.stages.push_back(StageStats{"fo[" + std::to_string(i) + "]"});
    }
    for (size_t i = 0; i < dec.biquads.size(); ++i) {
        rd.stages.push_back(StageStats{"bq[" + std::to_string(i) + "]"});
    }
    for (size_t i = 0; i < dec.quartics.size(); ++i) {
        rd.stages.push_back(StageStats{"qt[" + std::to_string(i) + "]"});
    }
    rd.stages.push_back(StageStats{"remainder"});
    rd.stages.push_back(StageStats{"gain"});

    struct FOStateD { double d1 = 0.0; };
    struct BQStateD { double d1 = 0.0, d2 = 0.0; };
    struct QTStateD { double d1 = 0.0, d2 = 0.0, d3 = 0.0, d4 = 0.0; };

    struct FOStateLD { long double d1 = 0.0L; };
    struct BQStateLD { long double d1 = 0.0L, d2 = 0.0L; };
    struct QTStateLD { long double d1 = 0.0L, d2 = 0.0L, d3 = 0.0L, d4 = 0.0L; };

    std::vector<FOStateD> fo_d(dec.first_order.size());
    std::vector<BQStateD> bq_d(dec.biquads.size());
    std::vector<QTStateD> qt_d(dec.quartics.size());

    std::vector<FOStateLD> fo_ld(dec.first_order.size());
    std::vector<BQStateLD> bq_ld(dec.biquads.size());
    std::vector<QTStateLD> qt_ld(dec.quartics.size());

    FilterStateT<double> rem_d(dec.remainder);
    FilterStateT<long double> rem_ld(dec.remainder);

    long double gain_acc = static_cast<long double>(dec.gain);
    for (const auto& fo : dec.first_order) {
        gain_acc *= stage_scale_first_order(fo.sign);
    }
    for (const auto& bq : dec.biquads) {
        gain_acc *= stage_scale_biquad(bq.gamma);
    }
    for (const auto& qt : dec.quartics) {
        gain_acc *= stage_scale_quartic(qt.alpha, qt.beta);
    }

    const double gain_d = static_cast<double>(gain_acc);
    const long double gain_ld = gain_acc;

    for (size_t sample_idx = 0; sample_idx < x.size(); ++sample_idx) {
        double val_d = static_cast<double>(x[sample_idx]);
        long double val_ld = static_cast<long double>(x[sample_idx]);

        size_t stage_idx = 0;

        for (size_t i = 0; i < dec.first_order.size(); ++i, ++stage_idx) {
            StageStats& stats = rd.stages[stage_idx];
            const double in_abs = std::abs(val_d);
            const double scale_inv = 1.0 / stage_scale_first_order(dec.first_order[i].sign);
            const double out_d =
                (val_d + static_cast<double>(dec.first_order[i].sign) * fo_d[i].d1) * scale_inv;
            const long double out_ld = val_ld
                + static_cast<long double>(dec.first_order[i].sign) * fo_ld[i].d1;

            stats.max_in_abs = std::max(stats.max_in_abs, in_abs);
            stats.rms_in += val_d * val_d;

            fo_d[i].d1 = val_d;
            fo_ld[i].d1 = val_ld;
            val_d = out_d;
            val_ld = out_ld * static_cast<long double>(scale_inv);

            const double out_abs = std::abs(val_d);
            stats.max_out_abs = std::max(stats.max_out_abs, out_abs);
            stats.rms_out += val_d * val_d;
        }

        for (size_t i = 0; i < dec.biquads.size(); ++i, ++stage_idx) {
            StageStats& stats = rd.stages[stage_idx];
            const double in_abs = std::abs(val_d);
            const double g = dec.biquads[i].gamma;
            const long double g_ld = static_cast<long double>(g);
            const double scale_inv = 1.0 / stage_scale_biquad(g);

            const double out_d = (val_d - g * bq_d[i].d1 + bq_d[i].d2) * scale_inv;
            const long double out_ld =
                (val_ld - g_ld * bq_ld[i].d1 + bq_ld[i].d2) * static_cast<long double>(scale_inv);

            stats.max_in_abs = std::max(stats.max_in_abs, in_abs);
            stats.rms_in += val_d * val_d;

            bq_d[i].d2 = bq_d[i].d1;
            bq_d[i].d1 = val_d;
            bq_ld[i].d2 = bq_ld[i].d1;
            bq_ld[i].d1 = val_ld;
            val_d = out_d;
            val_ld = out_ld;

            const double out_abs = std::abs(val_d);
            stats.max_out_abs = std::max(stats.max_out_abs, out_abs);
            stats.rms_out += val_d * val_d;
        }

        for (size_t i = 0; i < dec.quartics.size(); ++i, ++stage_idx) {
            StageStats& stats = rd.stages[stage_idx];
            const double in_abs = std::abs(val_d);
            const double a = dec.quartics[i].alpha;
            const double b = dec.quartics[i].beta;
            const long double a_ld = static_cast<long double>(a);
            const long double b_ld = static_cast<long double>(b);
            const double scale_inv = 1.0 / stage_scale_quartic(a, b);

            const double out_d = ((val_d + qt_d[i].d4)
                - a * (qt_d[i].d1 + qt_d[i].d3)
                + b * qt_d[i].d2) * scale_inv;
            const long double out_ld = ((val_ld + qt_ld[i].d4)
                - a_ld * (qt_ld[i].d1 + qt_ld[i].d3)
                + b_ld * qt_ld[i].d2) * static_cast<long double>(scale_inv);

            stats.max_in_abs = std::max(stats.max_in_abs, in_abs);
            stats.rms_in += val_d * val_d;

            qt_d[i].d4 = qt_d[i].d3;
            qt_d[i].d3 = qt_d[i].d2;
            qt_d[i].d2 = qt_d[i].d1;
            qt_d[i].d1 = val_d;

            qt_ld[i].d4 = qt_ld[i].d3;
            qt_ld[i].d3 = qt_ld[i].d2;
            qt_ld[i].d2 = qt_ld[i].d1;
            qt_ld[i].d1 = val_ld;

            val_d = out_d;
            val_ld = out_ld;

            const double out_abs = std::abs(val_d);
            stats.max_out_abs = std::max(stats.max_out_abs, out_abs);
            stats.rms_out += val_d * val_d;
        }

        {
            StageStats& stats = rd.stages[stage_idx++];
            stats.max_in_abs = std::max(stats.max_in_abs, std::abs(val_d));
            stats.rms_in += val_d * val_d;

            if (dec.remainder.size() <= 1) {
                if (!dec.remainder.empty()) {
                    val_d *= dec.remainder[0];
                    val_ld *= static_cast<long double>(dec.remainder[0]);
                }
            } else {
                val_d = rem_d.push(val_d);
                val_ld = rem_ld.push(val_ld);
            }

            stats.max_out_abs = std::max(stats.max_out_abs, std::abs(val_d));
            stats.rms_out += val_d * val_d;
        }

        {
            StageStats& stats = rd.stages[stage_idx++];
            stats.max_in_abs = std::max(stats.max_in_abs, std::abs(val_d));
            stats.rms_in += val_d * val_d;

            val_d *= gain_d;
            val_ld *= gain_ld;

            stats.max_out_abs = std::max(stats.max_out_abs, std::abs(val_d));
            stats.rms_out += val_d * val_d;
        }

        rd.y_double[sample_idx] = val_d;
        rd.y_long_double[sample_idx] = val_ld;
    }

    if (!x.empty()) {
        for (auto& stats : rd.stages) {
            stats.rms_in = std::sqrt(stats.rms_in / static_cast<double>(x.size()));
            stats.rms_out = std::sqrt(stats.rms_out / static_cast<double>(x.size()));
        }
    }

    return rd;
}

static void print_stage_summary(const std::vector<StageStats>& stages)
{
    std::printf("    Top stages by output amplitude:\n");

    std::vector<size_t> order(stages.size());
    for (size_t i = 0; i < stages.size(); ++i) {
        order[i] = i;
    }

    std::sort(order.begin(), order.end(),
              [&](size_t lhs, size_t rhs) {
                  return stages[lhs].max_out_abs > stages[rhs].max_out_abs;
              });

    const size_t limit = std::min<size_t>(5, order.size());
    for (size_t rank = 0; rank < limit; ++rank) {
        const StageStats& s = stages[order[rank]];
        std::printf("      %-10s max_in=%11.4e  max_out=%11.4e  rms_out=%11.4e\n",
                    s.label.c_str(), s.max_in_abs, s.max_out_abs, s.rms_out);
    }
}

} // namespace

int main()
{
    struct Case {
        FilterSpec spec;
        const char* label;
    };

    const std::vector<Case> cases = {
        {{ 33, 32000.0,  4000.0,  6000.0}, "LPF-33"},
        {{ 49, 32000.0,  4000.0,  6000.0}, "LPF-49"},
        {{ 65, 48000.0,  8000.0, 12000.0}, "LPF-65"},
        {{ 97, 48000.0,  8000.0, 12000.0}, "LPF-97"},
    };

    const size_t noise_len = 200000;

    std::printf(
        "═══════════════════════════════════════════════════════════════════════════\n"
        "  Numeric diagnostics: factorization vs gain vs runtime cascade error\n"
        "═══════════════════════════════════════════════════════════════════════════\n\n");

    for (const auto& tc : cases) {
        const DirectFIR fir = design_freq_sampling(tc.spec);
        const CascadeDecomposition dec = decompose_v4(fir, true);
        const std::vector<real_t> rebuilt = recompose(dec, fir.length());

        const CoeffMetrics rebuild_metrics = compare_coeffs(fir.h, rebuilt);
        const double resp_err = compute_response_max_err(fir.h, rebuilt);

        const double gain_current = current_scalar_gain(dec);
        const double gain_ls = estimate_gain_ls_passband(fir, dec);
        const std::vector<real_t> rebuilt_ls = rebuild_with_gain_override(dec, gain_ls);
        const CoeffMetrics rebuild_ls_metrics = compare_coeffs(fir.h, rebuilt_ls);

        const std::vector<sample_t> noise = generate_white_noise(noise_len, 12345u + tc.spec.N);
        const std::vector<sample_t> y_direct = filter_direct(fir, noise);
        DirectFIR rebuilt_fir{rebuilt, fir.spec};
        const std::vector<sample_t> y_rebuilt_direct = filter_direct(rebuilt_fir, noise);
        const RuntimeDiagnostics runtime = run_runtime_diagnostics(dec, noise);

        const CompareMetrics factorization_signal_err =
            compare_signals(y_direct, y_rebuilt_direct);
        const CompareMetrics runtime_vs_direct =
            compare_double_to_float(runtime.y_double, y_direct);
        const CompareMetrics runtime_vs_rebuilt_direct =
            compare_double_to_float(runtime.y_double, y_rebuilt_direct);

        std::vector<sample_t> y_runtime_ld(runtime.y_long_double.size());
        for (size_t i = 0; i < runtime.y_long_double.size(); ++i) {
            y_runtime_ld[i] = static_cast<sample_t>(runtime.y_long_double[i]);
        }
        const CompareMetrics runtime_ld_vs_direct =
            compare_signals(y_direct, y_runtime_ld);
        const CompareMetrics runtime_ld_vs_double =
            compare_long_double_to_double(runtime.y_long_double, runtime.y_double);

        double max_stage_amp = 0.0;
        for (const auto& stage : runtime.stages) {
            max_stage_amp = std::max(max_stage_amp, stage.max_out_abs);
        }

        std::printf("%s  N=%u\n", tc.label, tc.spec.N);
        std::printf("  Sections: first=%zu  biquad=%zu  quartic=%zu  remainder_deg=%zu\n",
                    dec.first_order.size(),
                    dec.biquads.size(),
                    dec.quartics.size(),
                    dec.remainder.empty() ? size_t(0) : dec.remainder.size() - 1);
        std::printf("  Factorization:\n");
        std::printf("    rebuild max|Δh|=%11.4e  relL2=%11.4e  max|Δ|_H=%11.4e\n",
                    rebuild_metrics.max_abs_err,
                    rebuild_metrics.rel_l2_err,
                    resp_err);
        std::printf("  Gain:\n");
        std::printf("    current=% .10e  ls_passband=% .10e  |Δg|=%11.4e\n",
                    gain_current,
                    gain_ls,
                    std::abs(gain_current - gain_ls));
        std::printf("    rebuild with ls gain: max|Δh|=%11.4e  relL2=%11.4e\n",
                    rebuild_ls_metrics.max_abs_err,
                    rebuild_ls_metrics.rel_l2_err);
        std::printf("  Runtime filtering:\n");
        std::printf("    direct(orig) vs direct(rebuilt): SNR=%8.2f dB  max|Δ|=%11.4e\n",
                    factorization_signal_err.snr_db,
                    factorization_signal_err.max_abs_err);
        std::printf("    double      vs direct: SNR=%8.2f dB  max|Δ|=%11.4e\n",
                    runtime_vs_direct.snr_db,
                    runtime_vs_direct.max_abs_err);
        std::printf("    double      vs rebuilt: SNR=%8.2f dB  max|Δ|=%11.4e\n",
                    runtime_vs_rebuilt_direct.snr_db,
                    runtime_vs_rebuilt_direct.max_abs_err);
        std::printf("    long double vs direct: SNR=%8.2f dB  max|Δ|=%11.4e\n",
                    runtime_ld_vs_direct.snr_db,
                    runtime_ld_vs_direct.max_abs_err);
        std::printf("    long double vs double: SNR=%8.2f dB  max|Δ|=%11.4e\n",
                    runtime_ld_vs_double.snr_db,
                    runtime_ld_vs_double.max_abs_err);
        std::printf("  Dynamic range:\n");
        std::printf("    max intermediate amplitude=%11.4e\n", max_stage_amp);
        print_stage_summary(runtime.stages);
        std::printf("\n");
    }

    return 0;
}



// ============================================================================
// Original path: cascade_fir/examples/legacy/smith_example.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  smith_example.cpp
//  Пример Смита: полосовой фильтр 40-го порядка.
//
//  Коэффициенты взяты из:
//    Smith L.M. "Decomposition of FIR Digital Filters for
//    Realization via the Cascade Connection of Subfilters",
//    IEEE Trans. Signal Processing, Vol. 46, No. 6, June 1998,
//    pp. 1681–1684.
//
//  Table II:  импульсная характеристика h(±n), n = 0..20
//             (zero-phase, симметричная: h(n) = h(−n))
//  Table III: коэффициенты каскадной реализации
//             (16 подфильтров: 3 вещ. ось, 9 ед. окружность,
//              4 внутренность)
//
//  Спецификации (Table I):
//    Порядок:                 40
//    Полоса пропускания:      0.29 – 0.35 (нормированная)
//    Полоса заграждения:      0 – 0.245  и  0.395 – 0.5
//    Неравномерность в ПП:    0.01
//    Подавление в ПЗ:         0.001
//    Метод проектирования:    Parks–McClellan (Remez)
//
//  Назначение этого файла:
//    1. Проверить собственный алгоритм декомпозиции на
//       независимых данных (не частотная выборка, а Remez).
//    2. Сопоставить найденные нули с Table III Смита.
//    3. Продемонстрировать, какие нули выделяются аналитически
//       (на единичной окружности), а какие — нет (вещественная
//       ось и внутренность круга).
//
//  Фильтр Смита — zero-phase (чётный порядок, h(n) = h(−n)),
//  поэтому для получения каузальной версии (линейная ФЧХ)
//  коэффициенты сдвигаются: h_causal[n] = h[n − 20], n = 0..40.
//  Тогда h_causal[n] = h_causal[40 − n] (палиндром длины 41).
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"
#include <cstdlib>

// ═══════════════════════════════════════════════════════════════
//  Table II: Zero-phase impulse response h(±n), n = 0..20
//
//  Smith использует zero-phase представление:
//    H(z) = h(0) + Σ_{n=1}^{20} h(n) · (z^n + z^{−n})
//
//  Для каузальной реализации: h_causal[20+n] = h_causal[20−n] = h(n)
// ═══════════════════════════════════════════════════════════════

static const double smith_h_zerophase[21] = {
    // h(0)  .. h(20)   — из Table II статьи Smith (1998)
     0.4998339,    // n = 0
     0.1386676,    // n = 1
    -0.2542791,    // n = 2
    -0.1183907,    // n = 3
     0.0001654,    // n = 4
    -0.0833872,    // n = 5
    -0.0293554,    // n = 6
     0.0446486,    // n = 7
     0.0803689,    // n = 8
     0.0116151,    // n = 9
     0.0468060,    // n = 10
     0.0082750,    // n = 11
     0.0003973,    // n = 12
     0.0153971,    // n = 13
    -0.0064079,    // n = 14
    -0.0153766,    // n = 15
     0.0011431,    // n = 16
    -0.0096183,    // n = 17
    -0.0097227,    // n = 18
     0.0022596,    // n = 19
     0.0009675     // n = 20
};

// ═══════════════════════════════════════════════════════════════
//  Table III: Cascade realization coefficients
//
//  Smith использует zero-phase форму подфильтров:
//    2-й порядок:  H_m(z) = h_m(0) + h_m(1)·(z + z^{−1})
//                  где h_m(1) = 1  (нормировка)
//    4-й порядок:  H_m(z) = h_m(0) + h_m(1)·(z + z^{−1})
//                            + h_m(2)·(z² + z^{−2})
//                  где h_m(2) = 1
//
//  В каузальной форме:
//    2-й порядок:  z^{−1} + h_m(0)·z^{−0?}... нет, проще:
//      H_m(z) = 1 + h_m(0)·z^{−1} + z^{−2}
//      (здесь h_m(0) — это коэф. при z^{−1}, т.е. −γ в нашей
//       нотации, γ = −h_m(0))
//    4-й порядок:
//      H_m(z) = 1 + h_m(1)·z^{−1} + h_m(0)·z^{−2}
//               + h_m(1)·z^{−3} + z^{−4}
//      (это наш D_4(z) = 1 − α·z^{−1} + β·z^{−2} − α·z^{−3} + z^{−4}
//       с α = −h_m(1), β = h_m(0))
//
//  Типы подфильтров (из текста статьи):
//    Sections  1–3:   вещественная ось (real axis roots)
//    Sections  4–12:  единичная окружность (unit circle roots)
//    Sections  13–16: внутренность единичного круга (interior roots)
// ═══════════════════════════════════════════════════════════════

struct SmithSection {
    int order;           // 2 или 4
    double hm0;          // h_m(0)
    double hm1;          // h_m(=1), для 2-го порядка = 1.0
    double hm2;          // h_m(=2), для 4-го порядка = 1.0, иначе 0
    const char* type;    // описание: "real", "circle", "interior"
};

static const SmithSection smith_sections[16] = {
    // ── Вещественная ось (sections 1–3) ──────────────────────
    //  H_m(z) = z + h_m(0) + z^{−1}  →  каузальная: 1 + h_m(0)·z^{−1} + z^{−2}
    //  γ = −h_m(0)  в нашей нотации
    { 2, -3.13826819,  1.00000000,  0.0,  "real"     },  //  1
    { 2,  4.36711339,  1.00000000,  0.0,  "real"     },  //  2
    { 2,  2.05949675,  1.00000000,  0.0,  "real"     },  //  3

    // ── Единичная окружность (sections 4–12) ─────────────────
    //  H_m(z) = z + h_m(0) + z^{−1}  →  γ = −h_m(0) = 2·cos(ω)
    //  |h_m(0)| ≤ 2  для нулей на единичной окружности
    { 2, -1.99473589,  1.00000000,  0.0,  "circle"   },  //  4
    { 2, -1.98763182,  1.00000000,  0.0,  "circle"   },  //  5
    { 2, -1.91049815,  1.00000000,  0.0,  "circle"   },  //  6
    { 2,  1.19810234,  1.00000000,  0.0,  "circle"   },  //  7
    { 2,  1.34438997,  1.00000000,  0.0,  "circle"   },  //  8
    { 2,  1.53976462,  1.00000000,  0.0,  "circle"   },  //  9
    { 2,  1.72633181,  1.00000000,  0.0,  "circle"   },  // 10
    { 2,  1.87890497,  1.00000000,  0.0,  "circle"   },  // 11
    { 2,  1.95101363,  1.00000000,  0.0,  "circle"   },  // 12

    // ── Внутренность единичного круга (sections 13–16) ───────
    //  4-й порядок:  H_m(z) = z² + h_m(1)·z + h_m(0) + h_m(1)·z^{−1} + z^{−2}
    //  Каузальная форма (длина 5, палиндром):
    //    1 + h_m(1)·z^{−1} + h_m(0)·z^{−2} + h_m(1)·z^{−3} + z^{−4}
    //  В нашей нотации D_4: α = −h_m(1), β = h_m(0)
    { 4,  4.27193256, -2.93785745,  1.00000000,  "interior" },  // 13
    { 4,  3.10532325, -1.88534997,  1.00000000,  "interior" },  // 14
    { 4,  2.36330885,  0.62420550,  1.00000000,  "interior" },  // 15
    { 4,  2.34169676,  0.68843197,  1.00000000,  "interior" },  // 16
};

static const double smith_gain = 0.0009674713;

// ═══════════════════════════════════════════════════════════════
//  build_smith_causal_h — преобразование zero-phase → каузальный
//
//  Zero-phase: h(n) = h(−n), n = −20..20
//  Каузальный: h_c[n] = h(n − 20), n = 0..40
//  Тогда h_c[20 + k] = h_c[20 − k] = h(k)  →  палиндром
// ═══════════════════════════════════════════════════════════════

static std::vector<real_t> build_smith_causal_h()
{
    const unsigned N = 41;   // длина каузального фильтра
    std::vector<real_t> h(N);

    // Центральный коэффициент
    h[20] = smith_h_zerophase[0];

    // Симметричные пары
    for (unsigned k = 1; k <= 20; ++k) {
        h[20 + k] = smith_h_zerophase[k];
        h[20 - k] = smith_h_zerophase[k];
    }

    return h;
}

// ═══════════════════════════════════════════════════════════════
//  build_smith_cascade_polynomial — перемножить все 16 секций
//  Смита и gain в один полином (для проверки: должен совпасть
//  с h[n]).
//
//  Секция 2-го порядка (zero-phase):
//    z + h_m(0) + z^{−1}  →  каузальная длина 3: [1, h_m(0), 1]
//
//  Секция 4-го порядка (zero-phase):
//    z² + h_m(1)·z + h_m(0) + h_m(1)·z^{−1} + z^{−2}
//    →  каузальная длина 5: [1, h_m(1), h_m(0), h_m(1), 1]
// ═══════════════════════════════════════════════════════════════

static std::vector<real_t> build_smith_cascade_polynomial()
{
    std::vector<real_t> result = {1.0};

    for (int i = 0; i < 16; ++i) {
        const auto& s = smith_sections[i];

        std::vector<real_t> factor;
        if (s.order == 2) {
            // Каузальная форма: [1, h_m(0), 1]
            factor = {1.0, s.hm0, 1.0};
        } else {
            // Каузальная форма: [1, h_m(1), h_m(0), h_m(1), 1]
            factor = {1.0, s.hm1, s.hm0, s.hm1, 1.0};
        }

        result = poly_multiply(result, factor);
    }

    // Применить коэффициент усиления
    for (auto& v : result) {
        v *= smith_gain;
    }

    return result;
}

// ═══════════════════════════════════════════════════════════════
//  try_our_decomposition — попытаться разложить фильтр Смита
//  нашим алгоритмом.
//
//  Наш метод выделяет только нули, положение которых известно
//  заранее (для фильтра частотной выборки — из спецификации).
//  Для фильтра Смита (Parks–McClellan) нули НЕ известны
//  заранее, но можно попробовать:
//
//  1. Взять γ из Table III Смита (секции 4–12, единичная окр.)
//     и проверить, делится ли h[n] на (1 − γ·z^{−1} + z^{−2}).
//     (Здесь γ = −h_m(0) в нотации Смита.)
//
//  2. Для секций на вещественной оси (1–3): |h_m(0)| > 2,
//     значит γ = −h_m(0), |γ| > 2, нули НЕ на окружности.
//     Наш бикводный делитель (1 − γz^{−1} + z^{−2}) формально
//     применим и при |γ| > 2, но нули будут вещественными, а не
//     комплексными на окружности.
//
//  3. Для секций 13–16 (внутренность): 4-й порядок, нужен
//     делитель D_4(z).  Этот делитель в текущей версии кода
//     не реализован для поотсчётного деления, но мы можем
//     проверить через произведение.
// ═══════════════════════════════════════════════════════════════

static void try_our_decomposition(const std::vector<real_t>& h_causal)
{
    std::cout << "\n--- Попытка нашей декомпозиции фильтра Смита ---\n";

    std::vector<real_t> current = h_causal;
    unsigned extracted = 0;
    unsigned failed = 0;

    // ── Секции на единичной окружности (4–12 в Table III) ────
    std::cout << "\n  Нули на единичной окружности (секции 4–12):\n";
    for (int i = 3; i < 12; ++i) {
        const auto& s = smith_sections[i];
        real_t gamma = -s.hm0;   // γ = −h_m(0) в нашей нотации
        real_t omega = std::acos(gamma / 2.0);
        real_t f_norm = omega / PI;   // нормированная частота

        // Попробовать поделить (половинная рекурсия)
        std::vector<real_t> quotient;
        size_t len_before = current.size();

        // Прямой ход рекурсии до середины
        size_t qlen = current.size() - 2;
        quotient.resize(qlen);
        size_t mid = (qlen - 1) / 2;

        quotient[0] = current[0];
        if (qlen >= 2)
            quotient[1] = current[1] + gamma * quotient[0];
        for (size_t n = 2; n <= mid; ++n)
            quotient[n] = current[n] + gamma * quotient[n-1] - quotient[n-2];

        // Чётное qlen — центральный элемент
        if (qlen % 2 == 0 && qlen >= 4) {
            size_t center = qlen / 2;
            if (center > mid)
                quotient[center] = current[center] + gamma * quotient[center-1]
                                 - quotient[center-2];
        }

        // Симметрия
        for (size_t n = 0; n < qlen / 2; ++n)
            quotient[qlen - 1 - n] = quotient[n];

        // Проверка: перемножить обратно и сравнить
        std::vector<real_t> factor = {1.0, -gamma, 1.0};
        std::vector<real_t> reconstructed = poly_multiply(quotient, factor);

        double max_err = 0.0;
        for (size_t n = 0; n < current.size(); ++n) {
            double diff = std::abs(current[n] -
                          (n < reconstructed.size() ? reconstructed[n] : 0.0));
            if (diff > max_err) max_err = diff;
        }

        bool ok = (max_err < 1e-6);
        std::cout << "    секция " << std::setw(2) << (i+1)
                  << "  γ=" << std::setw(11) << std::setprecision(8) << gamma
                  << "  f/fs=" << std::setprecision(4) << f_norm
                  << "  max|Δ|=" << std::scientific << std::setprecision(2)
                  << max_err
                  << (ok ? "  OK" : "  FAIL")
                  << std::defaultfloat << "\n";

        if (ok) {
            current = std::move(quotient);
            ++extracted;
        } else {
            ++failed;
        }
    }

    // ── Секции на вещественной оси (1–3 в Table III) ─────────
    std::cout << "\n  Нули на вещественной оси (секции 1–3):\n";
    for (int i = 0; i < 3; ++i) {
        const auto& s = smith_sections[i];
        real_t gamma = -s.hm0;   // γ = −h_m(0) = r + 1/r

        // |γ| > 2 означает нули не на окружности
        // Делитель (1 − γ·z^{−1} + z^{−2}) всё ещё симметричный,
        // наша рекурсия формально применима.

        size_t qlen = current.size() - 2;
        if (current.size() < 4) {
            std::cout << "    секция " << (i+1) << "  полином слишком короткий\n";
            ++failed;
            continue;
        }

        std::vector<real_t> quotient(qlen);
        size_t mid = (qlen - 1) / 2;

        quotient[0] = current[0];
        if (qlen >= 2)
            quotient[1] = current[1] + gamma * quotient[0];
        for (size_t n = 2; n <= mid; ++n)
            quotient[n] = current[n] + gamma * quotient[n-1] - quotient[n-2];
        if (qlen % 2 == 0 && qlen >= 4) {
            size_t center = qlen / 2;
            if (center > mid)
                quotient[center] = current[center] + gamma * quotient[center-1]
                                 - quotient[center-2];
        }
        for (size_t n = 0; n < qlen / 2; ++n)
            quotient[qlen - 1 - n] = quotient[n];

        // Проверка
        std::vector<real_t> factor = {1.0, -gamma, 1.0};
        std::vector<real_t> reconstructed = poly_multiply(quotient, factor);
        double max_err = 0.0;
        for (size_t n = 0; n < current.size(); ++n) {
            double diff = std::abs(current[n] -
                          (n < reconstructed.size() ? reconstructed[n] : 0.0));
            if (diff > max_err) max_err = diff;
        }

        bool ok = (max_err < 1e-6);
        std::cout << "    секция " << std::setw(2) << (i+1)
                  << "  γ=" << std::setw(11) << std::setprecision(8) << gamma
                  << "  |γ|=" << std::setprecision(4) << std::abs(gamma)
                  << " (>2: вне окружности)"
                  << "  max|Δ|=" << std::scientific << std::setprecision(2)
                  << max_err
                  << (ok ? "  OK" : "  FAIL")
                  << std::defaultfloat << "\n";

        if (ok) {
            current = std::move(quotient);
            ++extracted;
        } else {
            ++failed;
        }
    }

    // ── Итог: что осталось ───────────────────────────────────
    std::cout << "\n  Итого: выделено " << extracted << " из 12 "
              << "секций 2-го порядка, " << failed << " не удалось.\n"
              << "  Остаток: полином длины " << current.size()
              << " (порядок " << (current.size() - 1) << ").\n";

    // Остаток должен содержать 4 четвёрки нулей (секции 13–16),
    // т.е. порядок остатка = 40 − 2*12 = 16 (при успехе всех 12).
    // Или порядок остатка = 40 − 2*extracted.

    unsigned expected_rem_order = 40 - 2 * extracted;
    if (current.size() - 1 == expected_rem_order) {
        std::cout << "  Порядок остатка совпадает с ожидаемым ("
                  << expected_rem_order << ").\n";
    } else {
        std::cout << "  ВНИМАНИЕ: порядок остатка ("
                  << (current.size() - 1)
                  << ") не совпадает с ожидаемым ("
                  << expected_rem_order << ").\n";
    }

    // ── Проверка: остаток × выделенные секции ≈ h_causal ─────
    std::cout << "\n  Проверка полной пересборки...\n";
    // (пересборка выполняется через poly_multiply в main)
}

// ═══════════════════════════════════════════════════════════════
//  run_smith_example — основная функция
// ═══════════════════════════════════════════════════════════════

void run_smith_example()
{
    std::cout
        << "\n"
        << "╔══════════════════════════════════════════════════════╗\n"
        << "║  Пример Смита: BPF 40-го порядка (Table II/III)     ║\n"
        << "╚══════════════════════════════════════════════════════╝\n";

    // ── 1. Построить каузальный h[n] ─────────────────────────
    std::vector<real_t> h_causal = build_smith_causal_h();

    std::cout << "\n--- 1. Каузальный фильтр ---\n"
              << "  Длина: " << h_causal.size() << " (порядок 40)\n";

    // Проверка симметрии
    double max_asym = 0.0;
    for (size_t n = 0; n < h_causal.size() / 2; ++n) {
        double d = std::abs(h_causal[n] - h_causal[40 - n]);
        if (d > max_asym) max_asym = d;
    }
    std::cout << "  Симметрия: max|h[n]−h[40−n]| = "
              << std::scientific << max_asym << std::defaultfloat << "\n";

    // Первые/последние коэффициенты
    std::cout << "  h[0..4]:   ";
    for (int n = 0; n < 5; ++n)
        std::cout << std::setprecision(7) << h_causal[n] << "  ";
    std::cout << "\n  h[18..22]: ";
    for (int n = 18; n <= 22; ++n)
        std::cout << std::setprecision(7) << h_causal[n] << "  ";
    std::cout << "\n";

    // ── 2. Перемножить секции Смита → проверить = h[n] ───────
    std::cout << "\n--- 2. Проверка Table III Смита ---\n";

    std::vector<real_t> h_from_smith = build_smith_cascade_polynomial();

    std::cout << "  Длина произведения секций: " << h_from_smith.size() << "\n";

    CoeffMetrics cm = compare_coeffs(h_causal, h_from_smith);
    cm.print("h_causal vs smith_cascade");

    if (cm.max_abs_err < 1e-4) {
        std::cout << "  → Table III Смита корректна (совпадение с Table II).\n";
    } else {
        std::cout << "  → РАСХОЖДЕНИЕ!  Возможно, ошибка OCR в коэффициентах.\n";
    }

    // ── 3. Информация о секциях ──────────────────────────────
    std::cout << "\n--- 3. Секции Смита ---\n";
    std::cout << "  " << std::left
              << std::setw(4)  << "#"
              << std::setw(8)  << "Тип"
              << std::setw(5)  << "Пор."
              << std::setw(15) << "h_m(0)"
              << std::setw(15) << "h_m(1)"
              << std::setw(15) << "h_m(2)"
              << std::setw(15) << "γ (наша нот.)"
              << "\n";
    std::cout << "  " << std::string(77, '-') << "\n";

    for (int i = 0; i < 16; ++i) {
        const auto& s = smith_sections[i];
        real_t gamma = -s.hm0;

        std::cout << "  " << std::left
                  << std::setw(4)  << (i + 1)
                  << std::setw(8)  << s.type
                  << std::setw(5)  << s.order
                  << std::setw(15) << std::setprecision(8) << s.hm0
                  << std::setw(15) << s.hm1
                  << std::setw(15) << s.hm2
                  << std::setw(15) << gamma;

        // Для секций на окружности: вычислить частоту
        if (s.order == 2 && std::abs(gamma) <= 2.0) {
            double omega = std::acos(gamma / 2.0);
            std::cout << "  ω/π=" << std::setprecision(4) << (omega / PI);
        }

        std::cout << "\n";
    }
    std::cout << "  Gain = " << std::setprecision(10) << smith_gain << "\n";

    // ── 4. Наша декомпозиция ─────────────────────────────────
    try_our_decomposition(h_causal);

    // ── 5. Фильтрация: прямая vs liquid-dsp ──────────────────
    std::cout << "\n--- 5. Фильтрация (прямая vs liquid-dsp) ---\n";

    // Построим DirectFIR из каузальных коэффициентов
    // (фиктивная спецификация — только для liquid-dsp обёртки)
    DirectFIR fir;
    fir.h = h_causal;
    fir.spec = FilterSpec{41, 2.0, 0.29, 0.395};  // нормированные частоты

    const size_t test_len = 50000;
    std::vector<sample_t> noise = generate_white_noise(test_len, 999);

    std::vector<sample_t> y_direct = filter_direct(fir, noise);
    std::vector<sample_t> y_liquid = filter_liquid(fir, noise);

    CompareMetrics cm_dl = compare_signals(y_direct, y_liquid);
    cm_dl.print("прямая(своя) vs liquid-dsp");

    std::cout << "\n";
}

