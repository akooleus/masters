/*
  UNUSED LEGACY ARCHIVE

  This file is intentionally not listed in CMakeLists.txt and must not
  be compiled as part of the project. It preserves the old experimental
  v2/v3/v4 decomposition pipelines, liquid-dsp comparison app, and manual
  diagnostics that were removed from the active GitHub-facing tree.

  Why this code is unused:
  - the maintained implementation path is the exact-first family in
    src/decompose_exact_fs.cpp;
  - v2/v3/v4 were research experiments with duplicated helper code, noisy
    diagnostics, and weaker global acceptance criteria;
  - the liquid-dsp comparison path depends on an optional external library
    and is not required for core or exact-first regression testing;
  - keeping these files in src/examples/tests made the public project look
    like it still supported obsolete pipelines.

  To revive any piece of this archive, split the relevant section back into
  a normal source/test file, add a deliberate CMake target, and document why
  the exact-first path is insufficient for that use case.
*/

#if 0


// ============================================================================
// Original path: cascade_fir/src/legacy/decompose_v2.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  decompose_v2.cpp — Archived comparison pipeline (v2)
//
//  Historical algorithm kept for regression/comparison against the
//  exact-first family. It is not the default workflow and is built
//  only when `CASCADE_BUILD_LEGACY_PIPELINES=ON`.
//
//  Two-phase algorithm:
//    Phase 1: Analytical extraction of known stopband zeros
//             (sequential biquad half-recurrence with periodic
//              refresh from original h[n])
//    Phase 2: Numerical root-finding for remainder polynomial
//             (palindrome → u-substitution → Aberth–Ehrlich)
//
//  Result: (nearly) complete cascade — all or most zeros are
//  extracted into biquad/first-order sections, with a minimal
//  remainder (often just a constant gain).
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <complex>
#include <algorithm>
#include <cmath>
#include <vector>
#include <numeric>
#include <iostream>
#include <iomanip>
#include <cassert>

using cx = std::complex<double>;

// ─────────────────────────────────────────────────────────────
//  1.  Complex polynomial evaluation (Horner)
//
//  p(z) = coeffs[0] + coeffs[1]*z + ... + coeffs[n]*z^n
// ─────────────────────────────────────────────────────────────

static cx poly_eval_cx(const std::vector<double>& p, cx z)
{
    cx val = 0.0;
    for (int i = static_cast<int>(p.size()) - 1; i >= 0; --i)
        val = val * z + p[static_cast<size_t>(i)];
    return val;
}

// Evaluate p(z) and p'(z) simultaneously (Horner)
static cx poly_eval_deriv(const std::vector<double>& p, cx z, cx& dp)
{
    int n = static_cast<int>(p.size()) - 1;
    if (n < 0) { dp = 0.0; return 0.0; }

    cx val = p[static_cast<size_t>(n)];
    dp = 0.0;
    for (int i = n - 1; i >= 0; --i) {
        dp  = dp * z + val;
        val = val * z + p[static_cast<size_t>(i)];
    }
    return val;
}


// ─────────────────────────────────────────────────────────────
//  2.  Aberth–Ehrlich root finder for real polynomials
//
//  Input:  coefficients of F(u) = c[0] + c[1]*u + ... + c[M]*u^M
//  Output: complex roots (length M)
//
//  For polynomials with real coefficients, complex roots appear
//  in conjugate pairs.
// ─────────────────────────────────────────────────────────────

static std::vector<cx> roots_aberth(const std::vector<double>& coeffs,
                                    int max_iter = 300,
                                    double tol = 1e-14)
{
    int n = static_cast<int>(coeffs.size()) - 1;
    if (n <= 0) return {};

    // Degree-1: direct solution
    if (n == 1)
        return { cx(-coeffs[0] / coeffs[1], 0.0) };

    // Degree-2: quadratic formula
    if (n == 2) {
        double a = coeffs[2], b = coeffs[1], c0 = coeffs[0];
        double disc = b * b - 4.0 * a * c0;
        if (disc >= 0.0) {
            double sq = std::sqrt(disc);
            return { cx((-b + sq) / (2.0 * a), 0.0),
                     cx((-b - sq) / (2.0 * a), 0.0) };
        } else {
            double sq = std::sqrt(-disc);
            return { cx(-b / (2.0 * a),  sq / (2.0 * a)),
                     cx(-b / (2.0 * a), -sq / (2.0 * a)) };
        }
    }

    // Make monic for root-bound estimation
    double lc = coeffs[static_cast<size_t>(n)];
    std::vector<double> p(coeffs.size());
    for (size_t i = 0; i < p.size(); ++i)
        p[i] = coeffs[i] / lc;

    // Cauchy upper bound: all roots satisfy |z| < R
    double R = 1.0;
    for (int i = 0; i < n; ++i) {
        double bound = std::pow(std::abs(p[static_cast<size_t>(i)]) + 1e-30,
                                1.0 / static_cast<double>(n - i));
        if (bound > R) R = bound;
    }
    R = std::max(R * 1.5, 3.0);

    // Initial guesses on a circle of radius R with Aberth offset
    std::vector<cx> z(static_cast<size_t>(n));
    for (int k = 0; k < n; ++k) {
        double angle = 2.0 * PI * (k + 0.7 / n) / n;
        z[static_cast<size_t>(k)] = R * cx(std::cos(angle), std::sin(angle));
    }

    // Aberth–Ehrlich iteration
    for (int iter = 0; iter < max_iter; ++iter) {
        double max_shift = 0.0;

        for (int i = 0; i < n; ++i) {
            cx dp;
            cx pz = poly_eval_deriv(p, z[static_cast<size_t>(i)], dp);

            if (std::abs(pz) < 1e-300) continue;  // already converged

            // Newton ratio
            cx ratio = pz / dp;

            // Aberth correction: sum_{j≠i} 1/(z_i - z_j)
            cx aberth_sum = 0.0;
            for (int j = 0; j < n; ++j) {
                if (j == i) continue;
                cx diff = z[static_cast<size_t>(i)] - z[static_cast<size_t>(j)];
                if (std::abs(diff) > 1e-300)
                    aberth_sum += 1.0 / diff;
            }

            cx denom = 1.0 - ratio * aberth_sum;
            if (std::abs(denom) < 1e-300) denom = cx(1e-300, 0.0);

            cx shift = ratio / denom;
            z[static_cast<size_t>(i)] -= shift;

            double s = std::abs(shift);
            if (s > max_shift) max_shift = s;
        }

        if (max_shift < tol) break;
    }

    return z;
}


// ─────────────────────────────────────────────────────────────
//  3.  Palindromic polynomial → polynomial in u = z + z⁻¹
//
//  Given palindromic Q[0..2M] with Q[k] = Q[2M-k],
//  compute F(u) of degree M such that:
//
//      z^M · Q(z) = F(z + z⁻¹)
//
//  The key identity used:
//      s_k(u) ≡ z^k + z^{-k}
//      s_0 = 2,  s_1 = u,  s_k = u·s_{k-1} − s_{k-2}
//
//  F(u) = Q[M] + Σ_{k=1}^{M} Q[M−k] · s_k(u)
//
//  Result coefficients: F[j] is the coefficient of u^j.
// ─────────────────────────────────────────────────────────────

static std::vector<double> palindrome_to_u_poly(const std::vector<real_t>& Q)
{
    int deg = static_cast<int>(Q.size()) - 1;
    assert(deg >= 0);
    assert(deg % 2 == 0);  // must be even degree for u-substitution
    int M = deg / 2;

    if (M == 0) {
        // Q is a constant
        return { Q[0] };
    }

    // Build s_k(u) as coefficient arrays in u and accumulate F
    // s_prev2 = s_{k-2},  s_prev1 = s_{k-1},  s_cur = s_k

    // F starts as Q[M] * s_0, but s_0 = 2 contributes only to
    // the constant term of F.  Actually, by the formula:
    //   F(u) = Q[M] + Σ_{k=1}^{M} Q[M-k] * s_k(u)
    // so F[0] = Q[M] + Σ_{k=1}^{M} Q[M-k] * s_k[0]

    // We'll accumulate F by building each s_k incrementally.
    std::vector<double> F(static_cast<size_t>(M + 1), 0.0);
    F[0] = Q[static_cast<size_t>(M)];   // constant term from Q[M]*1

    // s_{k-2} and s_{k-1} stored as coefficient arrays of u
    // s_0 = [2],  s_1 = [0, 1]
    std::vector<double> s_prev2 = {2.0};
    std::vector<double> s_prev1 = {0.0, 1.0};

    // k=1: F += Q[M-1] * s_1 = Q[M-1] * [0, 1]
    F[0] += Q[static_cast<size_t>(M) - 1] * s_prev1[0];
    if (M >= 1) F[1] += Q[static_cast<size_t>(M) - 1] * s_prev1[1];

    for (int k = 2; k <= M; ++k) {
        // s_k = u * s_{k-1} - s_{k-2}
        //   u * s_{k-1}:  shift s_{k-1} coefficients right by 1
        //   Then subtract s_{k-2}

        size_t len_k = static_cast<size_t>(k + 1);
        std::vector<double> s_cur(len_k, 0.0);

        // u * s_{k-1}:  s_cur[j] = s_{k-1}[j-1]
        for (size_t j = 1; j < len_k && j - 1 < s_prev1.size(); ++j)
            s_cur[j] = s_prev1[j - 1];

        // - s_{k-2}:    s_cur[j] -= s_{k-2}[j]
        for (size_t j = 0; j < s_prev2.size() && j < len_k; ++j)
            s_cur[j] -= s_prev2[j];

        // Accumulate: F += Q[M-k] * s_cur
        double weight = Q[static_cast<size_t>(M - k)];
        for (size_t j = 0; j < len_k && j < F.size(); ++j)
            F[j] += weight * s_cur[j];

        // Shift: s_{k-2} ← s_{k-1}, s_{k-1} ← s_k
        s_prev2 = std::move(s_prev1);
        s_prev1 = std::move(s_cur);
    }

    return F;
}


// ─────────────────────────────────────────────────────────────
//  4.  Biquad half-recurrence divide
//
//  Divides palindromic h[0..L-1] by (1 − γ·z⁻¹ + z⁻²).
//  Recurrence runs only to the midpoint; second half is mirrored.
//  Returns false if h is too short.
// ─────────────────────────────────────────────────────────────

static bool biquad_half_divide(const std::vector<real_t>& h,
                               real_t gamma,
                               std::vector<real_t>& q)
{
    const size_t len = h.size();
    if (len < 4) return false;

    const size_t qlen = len - 2;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;

    q[0] = h[0];
    if (qlen >= 2)
        q[1] = h[1] + gamma * q[0];
    for (size_t n = 2; n <= mid; ++n)
        q[n] = h[n] + gamma * q[n - 1] - q[n - 2];

    // Even-length quotient: compute the element just past mid
    if (qlen % 2 == 0 && qlen >= 4) {
        size_t c = qlen / 2;
        if (c > mid)
            q[c] = h[c] + gamma * q[c - 1] - q[c - 2];
    }

    // Mirror second half from first half
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];

    return true;
}


// ─────────────────────────────────────────────────────────────
//  5.  First-order half-recurrence divide
//
//  Divides palindromic h by (1 + sign·z⁻¹).
//  sign = +1 → divisor (1 + z⁻¹), zero at z = −1
//  sign = −1 → divisor (1 − z⁻¹), zero at z = +1
// ─────────────────────────────────────────────────────────────

static bool first_order_half_divide(const std::vector<real_t>& h,
                                    int sign,
                                    std::vector<real_t>& q)
{
    const size_t len = h.size();
    if (len < 2) return false;

    const size_t qlen = len - 1;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;
    const real_t s = static_cast<real_t>(sign);

    q[0] = h[0];
    for (size_t n = 1; n <= mid; ++n)
        q[n] = h[n] - s * q[n - 1];

    // Mirror
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];

    return true;
}


// ─────────────────────────────────────────────────────────────
//  6.  Enforce palindromic symmetry
// ─────────────────────────────────────────────────────────────

static void enforce_symmetry_v2(std::vector<real_t>& p)
{
    const size_t len = p.size();
    for (size_t n = 0; n < len / 2; ++n) {
        real_t avg = (p[n] + p[len - 1 - n]) * 0.5;
        p[n] = avg;
        p[len - 1 - n] = avg;
    }
}


// ─────────────────────────────────────────────────────────────
//  7.  Stopband zero identification
// ─────────────────────────────────────────────────────────────

struct StopbandInfo {
    std::vector<unsigned> pair_k;    // k-indices for biquad pairs
    bool has_dc_zero;                // k = 0 → z = +1
    bool has_nyq_zero;               // k = N/2 → z = −1
};

static StopbandInfo find_stopband_zeros_v2(const FilterSpec& spec)
{
    StopbandInfo si;
    si.has_dc_zero  = false;
    si.has_nyq_zero = false;

    const unsigned N      = spec.N;
    const unsigned k_stop = spec.k_stop();
    const unsigned k_half = N / 2;

    for (unsigned k = k_stop; k <= k_half; ++k) {
        if (k == 0) {
            si.has_dc_zero = true;
        } else if (N % 2 == 0 && k == k_half) {
            si.has_nyq_zero = true;
        } else {
            si.pair_k.push_back(k);
        }
    }
    return si;
}


// ─────────────────────────────────────────────────────────────
//  8.  Interleave indices (low–high–low–high…)
// ─────────────────────────────────────────────────────────────

static std::vector<unsigned> interleave_indices_v2(
    const std::vector<unsigned>& indices)
{
    std::vector<unsigned> sorted = indices;
    std::sort(sorted.begin(), sorted.end());

    std::vector<unsigned> result;
    result.reserve(sorted.size());

    size_t lo = 0, hi = sorted.size();
    if (hi == 0) return result;
    --hi;

    bool take_lo = true;
    while (result.size() < sorted.size()) {
        if (take_lo) {
            result.push_back(sorted[lo++]);
        } else {
            result.push_back(sorted[hi--]);
        }
        take_lo = !take_lo;
        if (lo > hi && result.size() < sorted.size()) break;
    }
    return result;
}


// ─────────────────────────────────────────────────────────────
//  9.  Phase 1 — Analytical extraction with periodic refresh
//
//  Sequential biquad half-recurrence divisions.
//  Every refresh_interval steps, re-derive the current polynomial
//  by dividing the ORIGINAL h[n] through all accepted factors
//  (each division is a fresh biquad_half_divide).
//
//  Quality check: rebuild h from quotient × factors and compare
//  with original.  If error exceeds threshold → stop.
// ─────────────────────────────────────────────────────────────

struct AnalyticalResult {
    std::vector<Biquad>     biquads;
    std::vector<FirstOrder> first_order;
    std::vector<real_t>     remainder;    // palindromic quotient
};

static AnalyticalResult phase1_analytical(
    const std::vector<real_t>& h_orig,
    const FilterSpec& spec,
    bool interleave_order,
    unsigned refresh_interval = 5)
{
    AnalyticalResult ar;

    const unsigned N = spec.N;
    StopbandInfo si = find_stopband_zeros_v2(spec);

    // ── Build ordered factor list ────────────────────────────
    //  Each factor is either first-order (sign) or biquad (gamma, k)

    struct Factor {
        enum { FO, BQ } type;
        int    sign;       // for first-order
        real_t gamma;      // for biquad
        unsigned k_index;  // frequency bin
    };

    std::vector<Factor> factors;

    if (si.has_dc_zero)
        factors.push_back({Factor::FO, -1, 0.0, 0});
    if (si.has_nyq_zero)
        factors.push_back({Factor::FO, +1, 0.0, N / 2});

    {
        std::vector<unsigned> ordered = interleave_order
            ? interleave_indices_v2(si.pair_k)
            : si.pair_k;

        for (unsigned k : ordered) {
            real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
            factors.push_back({Factor::BQ, 0, gamma, k});
        }
    }

    // ── Helper: apply one factor division ────────────────────
    auto apply_one = [](const std::vector<real_t>& poly,
                        const Factor& f) -> std::vector<real_t>
    {
        std::vector<real_t> q;
        if (f.type == Factor::FO)
            first_order_half_divide(poly, f.sign, q);
        else
            biquad_half_divide(poly, f.gamma, q);
        return q;
    };

    // ── Helper: rebuild from quotient × factors [0..n) ───────
    auto rebuild_err = [&](const std::vector<real_t>& quotient,
                           unsigned n_factors) -> double
    {
        std::vector<real_t> rebuilt = quotient;
        for (unsigned j = 0; j < n_factors; ++j) {
            const auto& f = factors[j];
            std::vector<real_t> fp;
            if (f.type == Factor::FO)
                fp = {1.0, static_cast<real_t>(f.sign)};
            else
                fp = {1.0, -f.gamma, 1.0};
            rebuilt = poly_multiply(rebuilt, fp);
        }
        double max_err = 0.0;
        for (size_t i = 0; i < h_orig.size(); ++i) {
            double v = (i < rebuilt.size()) ? rebuilt[i] : 0.0;
            double d = std::abs(h_orig[i] - v);
            if (d > max_err) max_err = d;
        }
        return max_err;
    };

    double max_h = 0.0;
    for (const auto& v : h_orig)
        if (std::abs(v) > max_h) max_h = std::abs(v);

    static constexpr double QUALITY_THRESHOLD = 1e-6;

    // ── Main extraction loop ─────────────────────────────────
    std::vector<real_t> current = h_orig;
    unsigned accepted = 0;

    for (unsigned i = 0; i < static_cast<unsigned>(factors.size()); ++i) {
        // Sequential division step
        current = apply_one(current, factors[i]);

        unsigned steps_in_block = (i + 1) - accepted
                                + (accepted > 0 ? 0 : 0);
        // Check: every refresh_interval steps and at the end
        bool do_refresh = ((i + 1 - accepted) >= refresh_interval)
                       || (i + 1 == static_cast<unsigned>(factors.size()));

        if (do_refresh) {
            // Re-derive from scratch: h_orig → divide by factors[0..i]
            std::vector<real_t> fresh = h_orig;
            for (unsigned j = 0; j <= i; ++j)
                fresh = apply_one(fresh, factors[j]);
            enforce_symmetry_v2(fresh);

            double rel_err = (max_h > 1e-30)
                ? rebuild_err(fresh, i + 1) / max_h : 0.0;

            if (rel_err > QUALITY_THRESHOLD) {
                // Error too large — try to find the maximum acceptable
                // number of factors within the current block.
                for (unsigned try_end = i; try_end > accepted; --try_end) {
                    std::vector<real_t> trial = h_orig;
                    for (unsigned j = 0; j < try_end; ++j)
                        trial = apply_one(trial, factors[j]);
                    enforce_symmetry_v2(trial);
                    double trial_err = (max_h > 1e-30)
                        ? rebuild_err(trial, try_end) / max_h : 0.0;
                    if (trial_err <= QUALITY_THRESHOLD) {
                        current = std::move(trial);
                        accepted = try_end;
                        goto extraction_done;
                    }
                }
                // Nothing new could be added
                goto extraction_done;
            }

            // Accept the whole block
            current = std::move(fresh);
            accepted = i + 1;
        }
    }
    // All factors accepted
    accepted = static_cast<unsigned>(factors.size());

extraction_done:

    // ── Fill output ──────────────────────────────────────────
    for (unsigned j = 0; j < accepted; ++j) {
        const auto& f = factors[j];
        if (f.type == Factor::FO)
            ar.first_order.push_back(FirstOrder{f.sign});
        else
            ar.biquads.push_back(Biquad{f.gamma, f.k_index});
    }
    ar.remainder = std::move(current);
    enforce_symmetry_v2(ar.remainder);

    return ar;
}


// ─────────────────────────────────────────────────────────────
//  10.  Phase 2 — Numerical root-finding on remainder
//
//  Steps:
//    a) If remainder has odd degree, extract (1 + z⁻¹) first.
//    b) Convert even-degree palindrome to u-polynomial F(u).
//    c) Find roots of F(u) via Aberth–Ehrlich.
//    d) Classify roots: real → biquad, complex pair → quartic.
// ─────────────────────────────────────────────────────────────

struct NumericalRoot {
    enum Type { BIQUAD, QUARTIC } type;
    real_t gamma;                // for BIQUAD: γ = u (real root)
    real_t quartic_alpha;        // for QUARTIC: α = 2·Re(u)
    real_t quartic_beta;         // for QUARTIC: β = 2 + |u|²
};

struct Phase2Result {
    std::vector<NumericalRoot> roots;
    std::vector<FirstOrder>    extra_fo;   // from odd-degree extraction
    real_t                     gain;       // leading coefficient of Q
};

static Phase2Result phase2_numerical(const std::vector<real_t>& Q_in)
{
    Phase2Result pr;
    pr.gain = 1.0;

    if (Q_in.size() <= 1) {
        // Constant polynomial — no roots to find
        pr.gain = Q_in.empty() ? 1.0 : Q_in[0];
        return pr;
    }

    std::vector<real_t> Q = Q_in;
    enforce_symmetry_v2(Q);

    int deg = static_cast<int>(Q.size()) - 1;

    // a) Odd degree → extract (1 + z⁻¹)
    //    For any palindromic polynomial of odd degree,
    //    Q(-1) = 0 (proven in the thesis).
    if (deg % 2 != 0) {
        std::vector<real_t> q;
        if (first_order_half_divide(Q, +1, q)) {
            pr.extra_fo.push_back(FirstOrder{+1});
            Q = std::move(q);
            enforce_symmetry_v2(Q);
            deg = static_cast<int>(Q.size()) - 1;
        }
    }

    // If still odd (shouldn't happen, but safety check),
    // also try (1 − z⁻¹)
    if (deg % 2 != 0) {
        std::vector<real_t> q;
        if (first_order_half_divide(Q, -1, q)) {
            pr.extra_fo.push_back(FirstOrder{-1});
            Q = std::move(q);
            enforce_symmetry_v2(Q);
            deg = static_cast<int>(Q.size()) - 1;
        }
    }

    if (deg <= 0) {
        pr.gain = Q.empty() ? 1.0 : Q[0];
        return pr;
    }

    assert(deg % 2 == 0);
    int M = deg / 2;

    // Store gain = Q[0] (leading coefficient of the z⁻ⁿ polynomial)
    pr.gain = Q[0];

    // b) Convert palindrome to u-polynomial F(u)
    std::vector<double> F = palindrome_to_u_poly(Q);
    // F has degree M, F[M] = Q[0] (the leading coefficient)

    if (M == 0) {
        // No roots
        return pr;
    }

    // c) Find roots of F(u)
    std::vector<cx> raw_roots = roots_aberth(F);

    // d) Classify roots
    //    Tolerance for deciding "real": |Im(u)| < tol
    //    Tolerance for pairing conjugates
    static constexpr double REAL_TOL = 1e-8;
    static constexpr double PAIR_TOL = 1e-6;

    // Separate real and complex roots
    std::vector<bool> used(raw_roots.size(), false);

    // First pass: identify real roots
    for (size_t i = 0; i < raw_roots.size(); ++i) {
        if (std::abs(raw_roots[i].imag()) < REAL_TOL) {
            NumericalRoot nr;
            nr.type  = NumericalRoot::BIQUAD;
            nr.gamma = raw_roots[i].real();
            nr.quartic_alpha = 0.0;
            nr.quartic_beta  = 0.0;
            pr.roots.push_back(nr);
            used[i] = true;
        }
    }

    // Second pass: match conjugate pairs among unused complex roots
    for (size_t i = 0; i < raw_roots.size(); ++i) {
        if (used[i]) continue;

        // Find conjugate partner
        size_t best_j = raw_roots.size();
        double best_dist = 1e30;

        for (size_t j = i + 1; j < raw_roots.size(); ++j) {
            if (used[j]) continue;
            // Check if j is conjugate of i: u_j ≈ u_i*
            cx conj_i = std::conj(raw_roots[i]);
            double dist = std::abs(raw_roots[j] - conj_i);
            if (dist < best_dist) {
                best_dist = dist;
                best_j = j;
            }
        }

        if (best_j < raw_roots.size() && best_dist < PAIR_TOL) {
            // Matched conjugate pair → quartic section
            double re_u = (raw_roots[i].real() + raw_roots[best_j].real()) * 0.5;
            double im_u = std::abs(
                (raw_roots[i].imag() - raw_roots[best_j].imag()) * 0.5);

            // Quartic: (1 − u z⁻¹ + z⁻²)(1 − u* z⁻¹ + z⁻²)
            //        = 1 − 2·Re(u) z⁻¹ + (2 + |u|²) z⁻² − 2·Re(u) z⁻³ + z⁻⁴
            NumericalRoot nr;
            nr.type = NumericalRoot::QUARTIC;
            nr.gamma = 0.0;
            nr.quartic_alpha = 2.0 * re_u;
            nr.quartic_beta  = 2.0 + re_u * re_u + im_u * im_u;
            pr.roots.push_back(nr);

            used[i] = true;
            used[best_j] = true;
        } else {
            // Unmatched complex root — treat real part as approximation
            // This shouldn't happen for well-conditioned polynomials
            std::cerr << "  Phase 2 warning: unmatched complex root u = "
                      << raw_roots[i] << " — using Re(u) as biquad γ\n";
            NumericalRoot nr;
            nr.type  = NumericalRoot::BIQUAD;
            nr.gamma = raw_roots[i].real();
            nr.quartic_alpha = 0.0;
            nr.quartic_beta  = 0.0;
            pr.roots.push_back(nr);
            used[i] = true;
        }
    }

    return pr;
}


// ─────────────────────────────────────────────────────────────
//  11.  Assemble full CascadeDecomposition
// ─────────────────────────────────────────────────────────────

CascadeDecomposition decompose_v2(const DirectFIR& fir,
                                  bool interleave_order)
{
    CascadeDecomposition dec;
    dec.gain = 1.0;

    const unsigned N = fir.length();
    const auto& h = fir.h;

    if (N < 3) {
        dec.remainder = h;
        return dec;
    }

    // ═════════════════════════════════════════════════════════
    //  Phase 1: Analytical extraction of stopband zeros
    // ═════════════════════════════════════════════════════════

    AnalyticalResult ar = phase1_analytical(h, fir.spec, interleave_order);

    dec.first_order = std::move(ar.first_order);
    dec.biquads     = std::move(ar.biquads);

    unsigned analytical_biquads = static_cast<unsigned>(dec.biquads.size());
    unsigned analytical_fo      = static_cast<unsigned>(dec.first_order.size());

    // ── Save Phase 1 result for possible fallback ────────────
    CascadeDecomposition dec_phase1_only = dec;
    dec_phase1_only.remainder = ar.remainder;
    dec_phase1_only.gain = 1.0;

    // ═════════════════════════════════════════════════════════
    //  Phase 2: Numerical root-finding on remainder
    //
    //  Only attempted when the remainder polynomial is short
    //  enough for reliable root-finding (degree ≤ threshold).
    //  For large remainders, the roots of the u-polynomial are
    //  poorly conditioned and the Aberth–Ehrlich iteration
    //  diverges or returns spurious roots with |γ| > 2.
    // ═════════════════════════════════════════════════════════

    static constexpr unsigned MAX_REMAINDER_DEG_FOR_PHASE2 = 40;

    unsigned rem_deg = ar.remainder.empty()
                     ? 0 : static_cast<unsigned>(ar.remainder.size()) - 1;

    bool do_phase2 = (rem_deg >= 2) && (rem_deg <= MAX_REMAINDER_DEG_FOR_PHASE2);

    unsigned numerical_biquads  = 0;
    unsigned numerical_quartics = 0;
    unsigned numerical_rejected = 0;

    if (do_phase2) {

    Phase2Result pr = phase2_numerical(ar.remainder);

    // Extra first-order factors from Phase 2 (odd-degree handling)
    for (const auto& fo : pr.extra_fo)
        dec.first_order.push_back(fo);

    // Separate numerical results into biquads and quartics.
    // Biquads go directly into dec.biquads.
    // Quartics are multiplied together to form the remainder polynomial.
    //
    // VALIDATION: a biquad (1 − γz⁻¹ + z⁻²) has zeros on the unit
    // circle only when |γ| ≤ 2.  Roots with |γ| > 2 correspond to
    // zeros OFF the unit circle — they come in reciprocal pairs and
    // must be realised as quartic sections.  We fold such pairs into
    // the remainder instead.

    std::vector<real_t> remainder_poly = {1.0};

    // Collect valid biquads and invalid ones separately
    std::vector<NumericalRoot> invalid_biquads;

    for (const auto& nr : pr.roots) {
        if (nr.type == NumericalRoot::BIQUAD) {
            if (std::abs(nr.gamma) <= 2.0 + 1e-9) {
                // Clamp to [-2, 2] for safety
                real_t gamma_clamped = std::max(-2.0, std::min(2.0, nr.gamma));
                dec.biquads.push_back(Biquad{gamma_clamped, 0});
                ++numerical_biquads;
            } else {
                // |γ| > 2 → zeros not on unit circle, fold into remainder
                invalid_biquads.push_back(nr);
                ++numerical_rejected;
            }
        } else {
            // QUARTIC: fold into remainder polynomial
            std::vector<real_t> quartic = {
                1.0,
                -nr.quartic_alpha,
                 nr.quartic_beta,
                -nr.quartic_alpha,
                1.0
            };
            remainder_poly = poly_multiply(remainder_poly, quartic);
            ++numerical_quartics;
        }
    }

    // Fold rejected biquads into remainder as (1 − γz⁻¹ + z⁻²)
    // pairs.  Try to pair them: if two rejected biquads have γ values
    // that are reciprocal-pair related, combine into quartic.
    // Otherwise, just multiply each into the remainder individually.
    for (const auto& inv : invalid_biquads) {
        std::vector<real_t> factor = {1.0, -inv.gamma, 1.0};
        remainder_poly = poly_multiply(remainder_poly, factor);
    }

    // ═════════════════════════════════════════════════════════
    //  Gain and remainder assembly
    //
    //  H(z) = gain · ∏(first_order) · ∏(biquads) · ∏(quartics)
    //
    //  gain = Q[0] from Phase 2 (= h[0] of original polynomial)
    //
    //  The remainder polynomial in CascadeDecomposition is
    //  gain · ∏(quartic sections) · ∏(rejected biquads).
    //  If there are none, remainder = {gain}.
    // ═════════════════════════════════════════════════════════

    dec.gain = 1.0;   // folded into remainder

    // Multiply gain into remainder_poly
    for (auto& v : remainder_poly)
        v *= pr.gain;

    dec.remainder = std::move(remainder_poly);

    } else {
        // Phase 2 skipped — remainder stays as-is from Phase 1
        dec.remainder = std::move(ar.remainder);
        dec.gain = 1.0;
    }

    // ═════════════════════════════════════════════════════════
    //  Verification: rebuild and check against original h[n]
    // ═════════════════════════════════════════════════════════

    std::vector<real_t> rebuilt = dec.remainder;

    for (const auto& bq : dec.biquads) {
        std::vector<real_t> f = {1.0, -bq.gamma, 1.0};
        rebuilt = poly_multiply(rebuilt, f);
    }
    for (const auto& fo : dec.first_order) {
        std::vector<real_t> f = {1.0, static_cast<real_t>(fo.sign)};
        rebuilt = poly_multiply(rebuilt, f);
    }

    double max_err = 0.0;
    double max_h   = 0.0;
    for (size_t n = 0; n < h.size(); ++n) {
        double v = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double d = std::abs(h[n] - v);
        if (d > max_err) max_err = d;
        if (std::abs(h[n]) > max_h) max_h = std::abs(h[n]);
    }
    double rel_err = (max_h > 1e-30) ? max_err / max_h : max_err;

    // ═════════════════════════════════════════════════════════
    //  Fallback: if Phase 2 degraded quality, revert to Phase 1
    //
    //  Compute Phase 1 rebuild error for comparison.
    // ═════════════════════════════════════════════════════════

    if (do_phase2) {
        // Phase 1 rebuild error
        std::vector<real_t> rebuilt_p1 = dec_phase1_only.remainder;
        for (const auto& bq : dec_phase1_only.biquads) {
            std::vector<real_t> f = {1.0, -bq.gamma, 1.0};
            rebuilt_p1 = poly_multiply(rebuilt_p1, f);
        }
        for (const auto& fo : dec_phase1_only.first_order) {
            std::vector<real_t> f = {1.0, static_cast<real_t>(fo.sign)};
            rebuilt_p1 = poly_multiply(rebuilt_p1, f);
        }
        double p1_max_err = 0.0;
        for (size_t n = 0; n < h.size(); ++n) {
            double v = (n < rebuilt_p1.size()) ? rebuilt_p1[n] : 0.0;
            double d = std::abs(h[n] - v);
            if (d > p1_max_err) p1_max_err = d;
        }
        double p1_rel_err = (max_h > 1e-30) ? p1_max_err / max_h : p1_max_err;

        // Fallback if Phase 2 made things worse by > 100×
        // or if the absolute error is unacceptable (> 1e-2)
        if ((rel_err > p1_rel_err * 10.0 && rel_err > 1e-5) ||
            rel_err > 1e-3) {
            std::cerr << "    Phase 2 fallback: v2 rel_err=" << std::scientific
                      << rel_err << " > p1 rel_err=" << p1_rel_err
                      << std::defaultfloat << ".  Reverting to Phase 1 only.\n";
            dec = std::move(dec_phase1_only);

            // Recompute for diagnostics
            analytical_biquads = static_cast<unsigned>(dec.biquads.size());
            analytical_fo = static_cast<unsigned>(dec.first_order.size());
            numerical_biquads  = 0;
            numerical_quartics = 0;
            numerical_rejected = 0;
            max_err = p1_max_err;
            rel_err = p1_rel_err;
        }
    }

    // ═════════════════════════════════════════════════════════
    //  Diagnostic output
    // ═════════════════════════════════════════════════════════

    std::cerr << "\n  decompose_v2 summary (N=" << N << "):\n"
              << "    Phase 1: " << analytical_fo << " first-order + "
              << analytical_biquads << " biquads (analytical)\n"
              << "    Phase 2: " << (do_phase2 ? "YES" : "SKIPPED")
              << " (rem deg=" << rem_deg << "/"
              << MAX_REMAINDER_DEG_FOR_PHASE2 << ")\n";
    if (do_phase2) {
        std::cerr << "      " << numerical_biquads << " biquads + "
                  << numerical_quartics << " quartics";
        if (numerical_rejected > 0)
            std::cerr << " + " << numerical_rejected << " rejected (|γ|>2)";
        std::cerr << "\n";
    }
    std::cerr << "    Total zeros extracted: "
              << dec.first_order.size() + dec.biquads.size() * 2
                 + numerical_quartics * 4
              << " / " << (N - 1) << "\n"
              << "    Remainder degree: " << (dec.remainder.size() - 1) << "\n"
              << "    Rebuild error (rel): " << std::scientific
              << rel_err << std::defaultfloat << "\n";

    if (rel_err > 1e-3) {
        std::cerr << "    *** WARNING: large rebuild error! ***\n";
    }

    return dec;
}



// ============================================================================
// Original path: cascade_fir/src/legacy/decompose_v3.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  decompose_v3.cpp — Archived comparison pipeline (v3)
//
//  Historical full-factorization experiment kept for comparison
//  against the exact-first family. It is not the default workflow
//  and is built only when `CASCADE_BUILD_LEGACY_PIPELINES=ON`.
//
//  Algorithm (single bulk division + Aberth–Ehrlich):
//    1. Identify ALL stopband zeros from the filter specification
//    2. Build the product of all stopband biquads as one polynomial
//    3. SINGLE polynomial division: h / product → quotient
//    4. Factor the quotient completely:
//       a) Extract (1+z⁻¹) if odd degree
//       b) u-substitution on even-degree palindrome
//       c) Aberth–Ehrlich root finding (NO degree limit)
//       d) Classify: real roots → biquads, complex pairs → quartics
//    5. Assemble cascade: stopband biquads + numerical biquads + gain
//
//  Key differences from decompose_v2:
//    • NO sequential biquad division — no accumulated error
//    • NO degree limit on Phase 2 root finding
//    • ALL real u-roots become biquads (even |γ|>2 — valid for
//      palindromic filters with reciprocal-pair zeros off the UC)
//    • Result: remainder = {gain} × quartics (often just a constant)
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <complex>
#include <algorithm>
#include <cmath>
#include <vector>
#include <numeric>
#include <iostream>
#include <iomanip>
#include <cassert>

// ─────────────────────────────────────────────────────────────
//  Local type alias (this TU only)
// ─────────────────────────────────────────────────────────────

using cx = std::complex<double>;

// ─────────────────────────────────────────────────────────────
//  1. Complex polynomial evaluation (Horner)
//
//  p(z) = coeffs[0] + coeffs[1]*z + … + coeffs[n]*z^n
// ─────────────────────────────────────────────────────────────

static cx v3_poly_eval_cx(const std::vector<double>& p, cx z)
{
    cx val = 0.0;
    for (int i = static_cast<int>(p.size()) - 1; i >= 0; --i)
        val = val * z + p[static_cast<size_t>(i)];
    return val;
}

// Evaluate p(z) and p'(z) simultaneously (Horner)
static cx v3_poly_eval_deriv(const std::vector<double>& p, cx z, cx& dp)
{
    int n = static_cast<int>(p.size()) - 1;
    if (n < 0) { dp = 0.0; return 0.0; }

    cx val = p[static_cast<size_t>(n)];
    dp = 0.0;
    for (int i = n - 1; i >= 0; --i) {
        dp  = dp * z + val;
        val = val * z + p[static_cast<size_t>(i)];
    }
    return val;
}

// ─────────────────────────────────────────────────────────────
//  2. Aberth–Ehrlich root finder for real polynomials
//
//  Input:  coefficients of F(u) = c[0] + c[1]*u + … + c[M]*u^M
//  Output: complex roots (length M)
//
//  This version uses higher iteration count and tighter tolerance
//  than v2, because v3 uses it on potentially larger polynomials.
// ─────────────────────────────────────────────────────────────

static std::vector<cx> v3_roots_aberth(const std::vector<double>& coeffs,
                                       int   max_iter = 500,
                                       double tol     = 1e-14)
{
    int n = static_cast<int>(coeffs.size()) - 1;
    if (n <= 0) return {};

    // ── Degree 1: direct ─────────────────────────────────────
    if (n == 1)
        return { cx(-coeffs[0] / coeffs[1], 0.0) };

    // ── Degree 2: quadratic formula ─────────────────────────
    if (n == 2) {
        double a = coeffs[2], b = coeffs[1], c0 = coeffs[0];
        double disc = b * b - 4.0 * a * c0;
        if (disc >= 0.0) {
            double sq = std::sqrt(disc);
            return { cx((-b + sq) / (2.0 * a), 0.0),
                     cx((-b - sq) / (2.0 * a), 0.0) };
        } else {
            double sq = std::sqrt(-disc);
            return { cx(-b / (2.0 * a),  sq / (2.0 * a)),
                     cx(-b / (2.0 * a), -sq / (2.0 * a)) };
        }
    }

    // ── Make monic for root-bound estimation ─────────────────
    double lc = coeffs[static_cast<size_t>(n)];
    std::vector<double> p(coeffs.size());
    for (size_t i = 0; i < p.size(); ++i)
        p[i] = coeffs[i] / lc;

    // Cauchy upper bound: all roots satisfy |z| < R
    double R = 1.0;
    for (int i = 0; i < n; ++i) {
        double bound = std::pow(std::abs(p[static_cast<size_t>(i)]) + 1e-30,
                                1.0 / static_cast<double>(n - i));
        if (bound > R) R = bound;
    }
    R = std::max(R * 1.5, 3.0);

    // ── Initial guesses on a circle of radius R ──────────────
    std::vector<cx> z(static_cast<size_t>(n));
    for (int k = 0; k < n; ++k) {
        double angle = 2.0 * PI * (k + 0.7 / n) / n;
        z[static_cast<size_t>(k)] = R * cx(std::cos(angle), std::sin(angle));
    }

    // ── Aberth–Ehrlich iteration ─────────────────────────────
    for (int iter = 0; iter < max_iter; ++iter) {
        double max_shift = 0.0;

        for (int i = 0; i < n; ++i) {
            cx dp;
            cx pz = v3_poly_eval_deriv(p, z[static_cast<size_t>(i)], dp);

            if (std::abs(pz) < 1e-300) continue;   // already converged

            // Newton ratio
            cx ratio = pz / dp;

            // Aberth correction: sum_{j!=i} 1/(z_i - z_j)
            cx aberth_sum = 0.0;
            for (int j = 0; j < n; ++j) {
                if (j == i) continue;
                cx diff = z[static_cast<size_t>(i)] - z[static_cast<size_t>(j)];
                if (std::abs(diff) > 1e-300)
                    aberth_sum += 1.0 / diff;
            }

            cx denom = 1.0 - ratio * aberth_sum;
            if (std::abs(denom) < 1e-300) denom = cx(1e-300, 0.0);

            cx shift = ratio / denom;
            z[static_cast<size_t>(i)] -= shift;

            double s = std::abs(shift);
            if (s > max_shift) max_shift = s;
        }

        if (max_shift < tol) break;
    }

    return z;
}

// ─────────────────────────────────────────────────────────────
//  3. Palindromic polynomial → polynomial in u = z + z⁻¹
//
//  Given palindromic Q[0..2M] with Q[k] = Q[2M-k],
//  compute F(u) of degree M such that:
//
//      z^{-M} · Q(z) = F(z + z⁻¹)
//
//  The Chebyshev-like recurrence:
//      s_k(u) ≡ z^k + z^{-k}
//      s_0 = 2,  s_1 = u,  s_k = u·s_{k-1} − s_{k-2}
//
//  F(u) = Q[M] + Σ_{k=1}^{M} Q[M−k] · s_k(u)
//
//  Result: F[j] is the coefficient of u^j.
//  F has degree M, with leading coefficient F[M] = Q[0].
// ─────────────────────────────────────────────────────────────

static std::vector<double> v3_palindrome_to_u_poly(
    const std::vector<real_t>& Q)
{
    int deg = static_cast<int>(Q.size()) - 1;
    assert(deg >= 0);
    assert(deg % 2 == 0);   // must be even degree for u-substitution
    int M = deg / 2;

    if (M == 0) {
        // Q is a constant
        return { Q[0] };
    }

    // Accumulate F by building s_k incrementally via recurrence.
    std::vector<double> F(static_cast<size_t>(M + 1), 0.0);
    F[0] = Q[static_cast<size_t>(M)];      // constant term from Q[M] · s_0/2
                                            // (actually F starts as Q[M]·1)

    // s_0 = [2],  s_1 = [0, 1]
    std::vector<double> s_prev2 = {2.0};
    std::vector<double> s_prev1 = {0.0, 1.0};

    // k = 1: F += Q[M-1] · s_1
    F[0] += Q[static_cast<size_t>(M) - 1] * s_prev1[0];
    if (M >= 1) F[1] += Q[static_cast<size_t>(M) - 1] * s_prev1[1];

    for (int k = 2; k <= M; ++k) {
        // s_k = u · s_{k-1} - s_{k-2}
        size_t len_k = static_cast<size_t>(k + 1);
        std::vector<double> s_cur(len_k, 0.0);

        // u · s_{k-1}: shift coefficients right by 1
        for (size_t j = 1; j < len_k && j - 1 < s_prev1.size(); ++j)
            s_cur[j] = s_prev1[j - 1];

        // - s_{k-2}
        for (size_t j = 0; j < s_prev2.size() && j < len_k; ++j)
            s_cur[j] -= s_prev2[j];

        // Accumulate: F += Q[M-k] · s_cur
        double weight = Q[static_cast<size_t>(M - k)];
        for (size_t j = 0; j < len_k && j < F.size(); ++j)
            F[j] += weight * s_cur[j];

        // Shift: s_{k-2} ← s_{k-1}, s_{k-1} ← s_k
        s_prev2 = std::move(s_prev1);
        s_prev1 = std::move(s_cur);
    }

    return F;
}

// ─────────────────────────────────────────────────────────────
//  4. Enforce palindromic symmetry: p[k] ← (p[k]+p[N-1-k])/2
// ─────────────────────────────────────────────────────────────

static void v3_enforce_symmetry(std::vector<real_t>& p)
{
    const size_t len = p.size();
    for (size_t n = 0; n < len / 2; ++n) {
        real_t avg = (p[n] + p[len - 1 - n]) * 0.5;
        p[n] = avg;
        p[len - 1 - n] = avg;
    }
}

// ─────────────────────────────────────────────────────────────
//  5. First-order half-recurrence divide for palindromic polys
//
//  Divides palindromic h by (1 + sign·z⁻¹).
//  Recurrence runs to midpoint; second half is mirrored.
// ─────────────────────────────────────────────────────────────

static bool v3_first_order_half_divide(const std::vector<real_t>& h,
                                       int sign,
                                       std::vector<real_t>& q)
{
    const size_t len = h.size();
    if (len < 2) return false;

    const size_t qlen = len - 1;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;
    const real_t s = static_cast<real_t>(sign);

    q[0] = h[0];
    for (size_t n = 1; n <= mid; ++n)
        q[n] = h[n] - s * q[n - 1];

    // Mirror second half
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];

    return true;
}

// ─────────────────────────────────────────────────────────────
//  6. Stopband zero identification
// ─────────────────────────────────────────────────────────────

struct V3_StopbandInfo {
    std::vector<unsigned> pair_k;    // k-indices for biquad pairs
    bool has_dc_zero;                // k = 0  → z = +1
    bool has_nyq_zero;               // k = N/2 → z = −1
};

static V3_StopbandInfo v3_find_stopband_zeros(const FilterSpec& spec)
{
    V3_StopbandInfo si;
    si.has_dc_zero  = false;
    si.has_nyq_zero = false;

    const unsigned N      = spec.N;
    const unsigned k_stop = spec.k_stop();
    const unsigned k_half = N / 2;

    for (unsigned k = k_stop; k <= k_half; ++k) {
        if (k == 0) {
            si.has_dc_zero = true;
        } else if (N % 2 == 0 && k == k_half) {
            si.has_nyq_zero = true;
        } else {
            si.pair_k.push_back(k);
        }
    }
    return si;
}

// ─────────────────────────────────────────────────────────────
//  7. Interleave indices (low-high-low-high…)
//
//  For cascade filtering, alternating between low and high
//  frequency sections reduces intermediate signal dynamic range.
// ─────────────────────────────────────────────────────────────

static std::vector<unsigned> v3_interleave_indices(
    const std::vector<unsigned>& indices)
{
    std::vector<unsigned> sorted = indices;
    std::sort(sorted.begin(), sorted.end());

    std::vector<unsigned> result;
    result.reserve(sorted.size());

    size_t lo = 0, hi = sorted.size();
    if (hi == 0) return result;
    --hi;

    bool take_lo = true;
    while (result.size() < sorted.size()) {
        if (take_lo) {
            result.push_back(sorted[lo++]);
        } else {
            result.push_back(sorted[hi--]);
        }
        take_lo = !take_lo;
        if (lo > hi && result.size() < sorted.size()) break;
    }
    return result;
}

// ─────────────────────────────────────────────────────────────
//  7b. Biquad half-recurrence divide for palindromic polys
//
//  Divides palindromic h[0..L-1] by (1 − γ·z⁻¹ + z⁻²).
//  Recurrence runs only to the midpoint; second half is mirrored.
// ─────────────────────────────────────────────────────────────

static bool v3_biquad_half_divide(const std::vector<real_t>& h,
                                  real_t gamma,
                                  std::vector<real_t>& q)
{
    const size_t len = h.size();
    if (len < 4) return false;

    const size_t qlen = len - 2;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;

    q[0] = h[0];
    if (qlen >= 2)
        q[1] = h[1] + gamma * q[0];
    for (size_t n = 2; n <= mid; ++n)
        q[n] = h[n] + gamma * q[n - 1] - q[n - 2];

    if (qlen % 2 == 0 && qlen >= 4) {
        size_t c = qlen / 2;
        if (c > mid)
            q[c] = h[c] + gamma * q[c - 1] - q[c - 2];
    }

    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];

    return true;
}

// ─────────────────────────────────────────────────────────────
//  8. Numerical root classification
// ─────────────────────────────────────────────────────────────

struct V3_NumericalRoot {
    enum Type { BIQUAD, QUARTIC } type;
    real_t gamma;            // for BIQUAD: γ = u (the real root)
    real_t quartic_alpha;    // for QUARTIC: α = 2·Re(u)
    real_t quartic_beta;     // for QUARTIC: β = 2 + |u|²
};

// ─────────────────────────────────────────────────────────────
//  9. Bairstow's method: find quadratic factor of u-polynomial
//
//  Given F(u) = coeffs[0] + coeffs[1]*u + ... + coeffs[M]*u^M,
//  find (r, s) such that (u² - r·u - s) divides F(u).
//
//  This is a proper 2×2 Newton iteration on the remainder
//  coefficients.  Convergence is quadratic near simple factors.
//
//  For complex conjugate pair u₀ = a + jb, u₀* = a - jb:
//    quadratic factor: u² - 2a·u + (a²+b²) = u² - r·u - s
//    so r = 2a, s = -(a²+b²)
//
//  Mapping to z-domain quartic (1 − α z⁻¹ + β z⁻² − α z⁻³ + z⁻⁴):
//    α = r,  β = 2 − s
// ─────────────────────────────────────────────────────────────

static bool v3_bairstow(const std::vector<double>& coeffs,
                         double& r, double& s,
                         int max_iter = 100, double tol = 1e-14)
{
    const int n = static_cast<int>(coeffs.size()) - 1;
    if (n < 2) return false;

    std::vector<double> b(n + 1), c(n + 1);

    for (int iter = 0; iter < max_iter; ++iter) {
        // Synthetic division: F(u) / (u² - r·u - s)
        //   b[n] = a[n]
        //   b[n-1] = a[n-1] + r·b[n]
        //   b[j] = a[j] + r·b[j+1] + s·b[j+2],  j = n-2,...,0
        b[n] = coeffs[n];
        b[n - 1] = coeffs[n - 1] + r * b[n];
        for (int j = n - 2; j >= 0; --j)
            b[j] = coeffs[j] + r * b[j + 1] + s * b[j + 2];

        // b[1] and b[0] are the remainder: R(u) = b[1]·u + b[0]
        // For exact division we need b[0] = b[1] = 0.

        double scale = std::abs(coeffs[0]) + std::abs(coeffs[n]) + 1.0;
        if (std::abs(b[0]) + std::abs(b[1]) < tol * scale)
            return true;

        // Second synthetic division of b[] for the Jacobian:
        //   c[n] = b[n]
        //   c[n-1] = b[n-1] + r·c[n]
        //   c[j] = b[j] + r·c[j+1] + s·c[j+2],  j = n-2,...,2
        c[n] = b[n];
        c[n - 1] = b[n - 1] + r * c[n];
        for (int j = n - 2; j >= 2; --j)
            c[j] = b[j] + r * c[j + 1] + s * c[j + 2];

        // Extend to c[1] for the Jacobian:
        double c1 = b[1] + r * c[2];
        if (n >= 3) c1 += s * c[3];

        // Jacobian J of [b[1], b[0]] w.r.t. [r, s]:
        //   J = | c[2]  c3_val |
        //       | c1    c[2]   |
        // where c3_val = c[3] if n>=3, else 0.
        double c3_val = (n >= 3) ? c[3] : 0.0;

        double det = c[2] * c[2] - c3_val * c1;
        if (std::abs(det) < 1e-30) break;   // singular

        // Newton step: J · [Δr, Δs]ᵀ = -[b[1], b[0]]ᵀ
        double dr = (-b[1] * c[2] + b[0] * c3_val) / det;
        double ds = (-b[0] * c[2] + b[1] * c1) / det;

        r += dr;
        s += ds;

        if (std::abs(dr) + std::abs(ds) <
            tol * (std::abs(r) + std::abs(s) + 1.0))
            return true;
    }

    return false;
}


// ═══════════════════════════════════════════════════════════════
//
//   decompose_v3  —  FULL FACTORIZATION
//
// ═══════════════════════════════════════════════════════════════

CascadeDecomposition decompose_v3(const DirectFIR& fir,
                                  bool interleave_order)
{
    CascadeDecomposition dec;
    dec.gain = 1.0;

    const unsigned N = fir.length();
    const auto& h = fir.h;

    if (N < 3) {
        dec.remainder = h;
        std::cerr << "\n  decompose_v3: N=" << N
                  << " < 3, nothing to decompose.\n";
        return dec;
    }

    std::cerr << "\n  ========================================================\n"
              << "  decompose_v3: ITERATIVE VERIFIED FACTORIZATION (N=" << N
              << ")\n"
              << "  ========================================================\n";

    // ═════════════════════════════════════════════════════════
    //  STEP 1: Identify all stopband zeros
    // ═════════════════════════════════════════════════════════

    V3_StopbandInfo si = v3_find_stopband_zeros(fir.spec);

    unsigned num_sb_biquads = static_cast<unsigned>(si.pair_k.size());
    unsigned num_sb_fo      = (si.has_dc_zero ? 1u : 0u)
                            + (si.has_nyq_zero ? 1u : 0u);

    std::cerr << "  Step 1: Stopband zeros: "
              << num_sb_biquads << " biquad pairs + "
              << num_sb_fo << " first-order\n";

    // ═════════════════════════════════════════════════════════
    //  STEPS 2-3: Sequential half-recurrence for ALL stopband zeros
    //
    //  Instead of building one large product polynomial and doing
    //  a single (numerically unstable) long division, we extract
    //  each stopband zero individually using the palindromic
    //  half-recurrence.  Each individual division is stable:
    //  recurrence runs only to the midpoint, second half mirrored.
    //  NO quality threshold — we extract ALL stopband zeros.
    // ═════════════════════════════════════════════════════════

    std::vector<real_t> quotient = h;

    if (si.has_dc_zero) {
        std::vector<real_t> q;
        v3_first_order_half_divide(quotient, -1, q);
        quotient = std::move(q);
        v3_enforce_symmetry(quotient);
    }
    if (si.has_nyq_zero) {
        std::vector<real_t> q;
        v3_first_order_half_divide(quotient, +1, q);
        quotient = std::move(q);
        v3_enforce_symmetry(quotient);
    }

    for (unsigned k : si.pair_k) {
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
        std::vector<real_t> q;
        v3_biquad_half_divide(quotient, gamma, q);
        v3_enforce_symmetry(q);
        quotient = std::move(q);
    }

    unsigned quot_deg = quotient.empty()
                      ? 0u : static_cast<unsigned>(quotient.size()) - 1;
    std::cerr << "  Steps 2-3: Sequential extraction of "
              << num_sb_biquads << " biquads + "
              << num_sb_fo << " first-order → quotient deg "
              << quot_deg << "\n";

    // ═════════════════════════════════════════════════════════
    //  STEP 4: Iterative verified factorization of quotient
    //
    //  Loop:
    //    - u-substitution on Q → F(u)
    //    - Aberth-Ehrlich → candidate roots
    //    - For each candidate: form biquad, try poly_divide(Q, biquad),
    //      accept only if division remainder is small
    //    - Update Q = Q / (product of accepted biquads)
    //    - Repeat until no more roots accepted or Q is constant
    //
    //  This avoids the catastrophic error of trusting all roots
    //  blindly: only roots that ACTUALLY divide Q are accepted.
    // ═════════════════════════════════════════════════════════

    std::vector<real_t> Q = quotient;

    // Accumulators
    std::vector<FirstOrder>   numerical_fo;
    std::vector<Biquad>       numerical_bq;
    std::vector<Quartic>      numerical_qt;
    unsigned                  n_num_quartics = 0;
    real_t                    quotient_gain = 1.0;

    static constexpr int    MAX_OUTER_ITERS   = 20;
    static constexpr double DIVISION_TOL      = 1e-6;

    for (int outer = 0; outer < MAX_OUTER_ITERS; ++outer) {
        int Q_deg = static_cast<int>(Q.size()) - 1;
        if (Q_deg <= 0) {
            quotient_gain = Q.empty() ? 1.0 : Q[0];
            break;
        }

        // ── 4a: Extract first-order if odd degree ────────────
        if (Q_deg % 2 != 0) {
            std::vector<real_t> q;
            if (v3_first_order_half_divide(Q, +1, q)) {
                numerical_fo.push_back(FirstOrder{+1});
                Q = std::move(q);
                v3_enforce_symmetry(Q);
                Q_deg = static_cast<int>(Q.size()) - 1;
            }
        }
        if (Q_deg > 0 && Q_deg % 2 != 0) {
            std::vector<real_t> q;
            if (v3_first_order_half_divide(Q, -1, q)) {
                numerical_fo.push_back(FirstOrder{-1});
                Q = std::move(q);
                v3_enforce_symmetry(Q);
                Q_deg = static_cast<int>(Q.size()) - 1;
            }
        }
        if (Q_deg <= 0) {
            quotient_gain = Q.empty() ? 1.0 : Q[0];
            break;
        }
        if (Q_deg % 2 != 0) {
            std::cerr << "    iter " << outer
                      << ": Q degree " << Q_deg
                      << " still odd — cannot factor, stopping.\n";
            break;
        }

        int M = Q_deg / 2;

        // ── 4b: u-substitution ───────────────────────────────
        std::vector<double> F = v3_palindrome_to_u_poly(Q);

        // ── 4c: Aberth-Ehrlich root finding ──────────────────
        std::vector<cx> raw_roots = v3_roots_aberth(F, 500, 1e-14);

        std::cerr << "    iter " << outer << ": Q deg=" << Q_deg
                  << ", u-poly deg=" << M
                  << ", roots found=" << raw_roots.size() << "\n";

        // ── 4d: Classify roots ───────────────────────────────
        static constexpr double REAL_TOL = 1e-8;
        static constexpr double PAIR_TOL = 1e-6;

        // Collect candidate biquads and quartics with quality metric
        struct Candidate {
            enum { BQ, QT } type;
            real_t gamma;           // for BQ
            real_t qt_alpha, qt_beta; // for QT
            double quality;         // |F(u)| — smaller is better
        };
        std::vector<Candidate> candidates;
        std::vector<bool> used(raw_roots.size(), false);

        // 1st pass: real roots → biquad candidates
        for (size_t i = 0; i < raw_roots.size(); ++i) {
            if (std::abs(raw_roots[i].imag()) < REAL_TOL) {
                Candidate c;
                c.type = Candidate::BQ;
                c.gamma = raw_roots[i].real();
                c.qt_alpha = c.qt_beta = 0.0;
                c.quality = std::abs(v3_poly_eval_cx(F, raw_roots[i]));
                candidates.push_back(c);
                used[i] = true;
            }
        }

        // 2nd pass: conjugate pairs → quartic candidates
        for (size_t i = 0; i < raw_roots.size(); ++i) {
            if (used[i]) continue;
            size_t best_j = raw_roots.size();
            double best_dist = 1e30;
            for (size_t j = i + 1; j < raw_roots.size(); ++j) {
                if (used[j]) continue;
                double dist = std::abs(raw_roots[j] - std::conj(raw_roots[i]));
                if (dist < best_dist) { best_dist = dist; best_j = j; }
            }
            if (best_j < raw_roots.size() && best_dist < PAIR_TOL) {
                double re_u = (raw_roots[i].real() + raw_roots[best_j].real()) * 0.5;
                double im_u = std::abs((raw_roots[i].imag() - raw_roots[best_j].imag()) * 0.5);
                Candidate c;
                c.type = Candidate::QT;
                c.gamma = 0.0;
                c.qt_alpha = 2.0 * re_u;
                c.qt_beta  = 2.0 + re_u * re_u + im_u * im_u;
                c.quality = std::max(
                    std::abs(v3_poly_eval_cx(F, raw_roots[i])),
                    std::abs(v3_poly_eval_cx(F, raw_roots[best_j])));
                candidates.push_back(c);
                used[i] = true;
                used[best_j] = true;
            } else {
                // Unmatched — try as real biquad
                Candidate c;
                c.type = Candidate::BQ;
                c.gamma = raw_roots[i].real();
                c.qt_alpha = c.qt_beta = 0.0;
                c.quality = std::abs(v3_poly_eval_cx(F, raw_roots[i]));
                candidates.push_back(c);
                used[i] = true;
            }
        }

        // Sort candidates by quality (best roots first)
        std::sort(candidates.begin(), candidates.end(),
                  [](const Candidate& a, const Candidate& b) {
                      return a.quality < b.quality;
                  });

        // ── 4e: Verify each candidate by actual poly_divide ──
        //
        //  For each candidate, divide Q by its factor polynomial.
        //  If the division remainder is small → accept.
        //  This is the key: we don't trust the root value,
        //  we trust the division.

        double max_Q = 0.0;
        for (const auto& v : Q)
            if (std::abs(v) > max_Q) max_Q = std::abs(v);

        unsigned accepted = 0;
        std::vector<real_t> Q_work = Q;

        // Defer quartics to later iterations when Q is smaller
        // (condition number of complex roots improves dramatically)
        static constexpr int QUARTIC_DEGREE_THRESHOLD = 8;

        for (const auto& cand : candidates) {
            // Skip quartic candidates when u-poly is large
            if (cand.type == Candidate::QT && M > QUARTIC_DEGREE_THRESHOLD)
                continue;

            std::vector<real_t> factor;
            if (cand.type == Candidate::BQ) {
                factor = {1.0, -cand.gamma, 1.0};
            } else {
                factor = {1.0, -cand.qt_alpha, cand.qt_beta,
                          -cand.qt_alpha, 1.0};
            }

            if (factor.size() > Q_work.size()) continue;

            auto [q_trial, rem_trial] = poly_divide(Q_work, factor);

            double max_r = 0.0;
            for (const auto& v : rem_trial)
                if (std::abs(v) > max_r) max_r = std::abs(v);

            double max_qw = 0.0;
            for (const auto& v : Q_work)
                if (std::abs(v) > max_qw) max_qw = std::abs(v);

            double rel_rem = (max_qw > 1e-30) ? max_r / max_qw : max_r;

            if (cand.type == Candidate::BQ) {
                // Biquads: verify by poly_divide remainder
                if (rel_rem < DIVISION_TOL) {
                    v3_enforce_symmetry(q_trial);
                    Q_work = std::move(q_trial);
                    numerical_bq.push_back(Biquad{cand.gamma, 0});
                    ++accepted;
                }
            } else {
                // Quartics: ALWAYS accept (approximate params from Aberth).
                // Divide Q_work to reduce degree for next iteration.
                // Actual (α,β) will be refined by Bairstow on fresh F(u)
                // in Step 4B Phase 3.
                v3_enforce_symmetry(q_trial);
                Q_work = std::move(q_trial);
                numerical_qt.push_back(Quartic{cand.qt_alpha, cand.qt_beta});
                ++n_num_quartics;
                ++accepted;
            }
        }

        std::cerr << "      verified & accepted: " << accepted
                  << " / " << candidates.size()
                  << ", Q deg " << Q_deg << " → "
                  << ((int)Q_work.size() - 1) << "\n";

        Q = std::move(Q_work);

        if (accepted == 0) {
            std::cerr << "      no progress — stopping iteration.\n";
            break;
        }
    }

    // Final Q: either constant or small unfactorable remainder
    int final_Q_deg = static_cast<int>(Q.size()) - 1;
    if (final_Q_deg <= 0) {
        quotient_gain = Q.empty() ? 1.0 : Q[0];
    }

    // ═════════════════════════════════════════════════════════
    //  STEP 4B: Refine sections via Bairstow
    //
    //  Phase 1: Refine numerical BIQUADS on h_original.
    //    Biquad (1−γz⁻¹+z⁻²) → z²−γz+1 → Bairstow (r=γ, s=−1).
    //    h has exact coefficients → refinement to ~ε_mach.
    //
    //  Phase 2: Recompute quotient Q from h via half-recurrence
    //    using ALL refined biquads + exact stopband zeros.
    //    Since biquads are now refined, Q is much cleaner.
    //
    //  Phase 3: Recompute F(u) from the fresh Q, then refine
    //    QUARTICS via Bairstow on F(u).
    //    F(u) is short (degree 6–12) → Bairstow converges easily.
    // ═════════════════════════════════════════════════════════
    {
        const std::vector<double>& p_asc = h;
        unsigned bq_refined = 0, qt_refined = 0;

        // ── Phase 1: Refine biquads on h_original ────────────
        for (auto& bq : numerical_bq) {
            double r_bw = bq.gamma;
            double s_bw = -1.0;
            if (v3_bairstow(p_asc, r_bw, s_bw)) {
                bq.gamma = r_bw;
                ++bq_refined;
            }
        }

        std::cerr << "  Step 4B phase 1: Biquads refined on h: "
                  << bq_refined << " / " << numerical_bq.size() << "\n";

        // ── Phase 2: Recompute Q via half-recurrence ─────────
        //  Now with refined biquad gammas, the quotient is cleaner.
        if (!numerical_qt.empty()) {
            std::vector<real_t> Q_fresh = h;

            // Stopband first-order
            if (si.has_dc_zero) {
                std::vector<real_t> q;
                v3_first_order_half_divide(Q_fresh, -1, q);
                v3_enforce_symmetry(q);
                Q_fresh = std::move(q);
            }
            if (si.has_nyq_zero) {
                std::vector<real_t> q;
                v3_first_order_half_divide(Q_fresh, +1, q);
                v3_enforce_symmetry(q);
                Q_fresh = std::move(q);
            }

            // Stopband biquads (exact γ_k)
            for (unsigned k : si.pair_k) {
                real_t g = 2.0 * std::cos(2.0 * PI * k / N);
                std::vector<real_t> q;
                v3_biquad_half_divide(Q_fresh, g, q);
                v3_enforce_symmetry(q);
                Q_fresh = std::move(q);
            }

            // Numerical first-order
            for (const auto& fo : numerical_fo) {
                std::vector<real_t> q;
                v3_first_order_half_divide(Q_fresh, fo.sign, q);
                v3_enforce_symmetry(q);
                Q_fresh = std::move(q);
            }

            // Numerical biquads (now REFINED gammas)
            for (const auto& bq : numerical_bq) {
                std::vector<real_t> q;
                v3_biquad_half_divide(Q_fresh, bq.gamma, q);
                v3_enforce_symmetry(q);
                Q_fresh = std::move(q);
            }

            int Q_fresh_deg = static_cast<int>(Q_fresh.size()) - 1;
            std::cerr << "  Step 4B phase 2: Recomputed Q_fresh deg="
                      << Q_fresh_deg << "\n";

            // ── Phase 3: Refine quartics via Bairstow on F(u) ──
            //  Q_fresh still contains the quartic zeros.
            //  Extract first-order if odd, then u-substitution.
            if (Q_fresh_deg > 0 && Q_fresh_deg % 2 != 0) {
                std::vector<real_t> q;
                v3_first_order_half_divide(Q_fresh, +1, q);
                v3_enforce_symmetry(q);
                Q_fresh = std::move(q);
                Q_fresh_deg = static_cast<int>(Q_fresh.size()) - 1;
            }

            if (Q_fresh_deg >= 2 && Q_fresh_deg % 2 == 0) {
                std::vector<double> F_fresh = v3_palindrome_to_u_poly(Q_fresh);
                int M_fresh = Q_fresh_deg / 2;

                std::cerr << "  Step 4B phase 3: F_fresh(u) deg="
                          << M_fresh << ", refining quartics...\n";

                // For each quartic, Bairstow on F_fresh(u)
                // Quartic in z ↔ quadratic factor in u:
                //   u² − r·u − s,  where r = α, s = 2 − β
                for (auto& qt : numerical_qt) {
                    double r_bw = qt.alpha;
                    double s_bw = 2.0 - qt.beta;
                    if (v3_bairstow(F_fresh, r_bw, s_bw)) {
                        qt.alpha = r_bw;
                        qt.beta  = 2.0 - s_bw;
                        ++qt_refined;
                    }

                    // Deflate F_fresh for next quartic
                    // (Bairstow's quotient after convergence)
                    if (F_fresh.size() >= 3) {
                        int fn = static_cast<int>(F_fresh.size()) - 1;
                        std::vector<double> F_def(fn - 1);
                        F_def[fn - 2] = F_fresh[fn];
                        if (fn >= 3)
                            F_def[fn - 3] = F_fresh[fn - 1] + r_bw * F_def[fn - 2];
                        for (int j = fn - 4; j >= 0; --j)
                            F_def[j] = F_fresh[j + 2] + r_bw * F_def[j + 1]
                                     + s_bw * F_def[j + 2];
                        F_fresh = std::move(F_def);
                    }
                }
            }
        }

        std::cerr << "  Step 4B phase 3: Quartics refined on F(u): "
                  << qt_refined << " / " << numerical_qt.size() << "\n";
    }

    // ═════════════════════════════════════════════════════════
    //  STEP 4G: Compute gain spectrally — NO polynomial division
    //
    //  H(z) = G × ∏FO × ∏BQ × quartic_remainder(z) × Q_unfactored(z)
    //
    //  remainder = G × quartic_remainder × Q_unfactored
    //
    //  G = H(z₀) / [∏FO(z₀) × ∏BQ(z₀) × quartic_rem(z₀) × Q(z₀)]
    //
    //  Division of two complex numbers — error ≈ ε_mach.
    // ═════════════════════════════════════════════════════════
    {
        // z₀ = e^{jΩ₀} at center of passband (far from zeros)
        double Omega0 = PI * fir.spec.k_pass() / (2.0 * N);
        if (Omega0 < 1e-10) Omega0 = 0.1;

        cx z0 = cx(std::cos(Omega0), std::sin(Omega0));
        cx z0_inv = 1.0 / z0;

        // H(z₀) = Σ h[n] · z₀^{-n}
        cx z0_inv_n = 1.0;
        cx H_z0 = 0.0;
        for (unsigned n = 0; n < N; ++n) {
            H_z0 += h[n] * z0_inv_n;
            z0_inv_n *= z0_inv;
        }

        // ∏ of ALL known sections at z₀
        cx prod_z0 = 1.0;
        cx z0_inv2 = z0_inv * z0_inv;

        // Stopband first-order
        if (si.has_dc_zero)
            prod_z0 *= (1.0 - z0_inv);
        if (si.has_nyq_zero)
            prod_z0 *= (1.0 + z0_inv);

        // Stopband biquads
        for (unsigned k : si.pair_k) {
            real_t g = 2.0 * std::cos(2.0 * PI * k / N);
            prod_z0 *= (1.0 - g * z0_inv + z0_inv2);
        }

        // Numerical first-order
        for (const auto& fo : numerical_fo) {
            double s = static_cast<double>(fo.sign);
            prod_z0 *= (1.0 + s * z0_inv);
        }

        // Numerical biquads
        for (const auto& bq : numerical_bq)
            prod_z0 *= (1.0 - bq.gamma * z0_inv + z0_inv2);

        // Quartic sections at z₀: (1 − α·z⁻¹ + β·z⁻² − α·z⁻³ + z⁻⁴)
        cx z0_inv3 = z0_inv2 * z0_inv;
        cx z0_inv4 = z0_inv2 * z0_inv2;
        for (const auto& qt : numerical_qt) {
            prod_z0 *= (1.0 - qt.alpha * z0_inv + qt.beta * z0_inv2
                            - qt.alpha * z0_inv3 + z0_inv4);
        }

        // Q_unfactored at z₀ (if Q still has degree > 0)
        cx Q_z0 = 0.0;
        {
            cx zpow = 1.0;
            for (size_t i = 0; i < Q.size(); ++i) {
                Q_z0 += Q[i] * zpow;
                zpow *= z0_inv;
            }
        }
        prod_z0 *= Q_z0;

        // G = H(z₀) / ∏everything(z₀)
        cx G_cx = H_z0 / prod_z0;
        real_t G = G_cx.real();

        std::cerr << "  Step 4G: Spectral gain\n"
                  << "    G = " << G
                  << "  (|imag| = " << std::scientific
                  << std::abs(G_cx.imag()) << std::defaultfloat
                  << ")\n";

        // Remainder = {G} × Q_unfactored (quartics go to dec.quartics)
        if (Q.size() == 1) {
            G *= Q[0];
            Q = {G};
        } else if (Q.size() > 1) {
            for (auto& v : Q) v *= G;
        } else {
            Q = {G};
        }
        final_Q_deg = static_cast<int>(Q.size()) - 1;
        quotient_gain = 1.0;
    }

    // ═════════════════════════════════════════════════════════
    //  STEP 5: Assemble CascadeDecomposition
    // ═════════════════════════════════════════════════════════

    // First-order sections from stopband
    if (si.has_dc_zero)
        dec.first_order.push_back(FirstOrder{-1});
    if (si.has_nyq_zero)
        dec.first_order.push_back(FirstOrder{+1});
    for (const auto& fo : numerical_fo)
        dec.first_order.push_back(fo);

    // Stopband biquads
    std::vector<unsigned> ordered_k = interleave_order
        ? v3_interleave_indices(si.pair_k)
        : si.pair_k;
    for (unsigned k : ordered_k) {
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
        dec.biquads.push_back(Biquad{gamma, k});
    }
    unsigned n_stopband_bq = static_cast<unsigned>(dec.biquads.size());

    // Numerical biquads
    for (const auto& bq : numerical_bq)
        dec.biquads.push_back(bq);
    unsigned n_num_biquads = static_cast<unsigned>(numerical_bq.size());

    // Numerical quartics → each filters independently as 4th-order section
    for (const auto& qt : numerical_qt)
        dec.quartics.push_back(qt);

    // Remainder = Q (gain × any unfactored content, typically just {G})
    dec.remainder = Q;
    dec.gain = 1.0;

    // ═════════════════════════════════════════════════════════
    //  STEP 6: Verification
    // ═════════════════════════════════════════════════════════

    std::vector<real_t> rebuilt = dec.remainder;
    for (const auto& bq : dec.biquads) {
        std::vector<real_t> f = {1.0, -bq.gamma, 1.0};
        rebuilt = poly_multiply(rebuilt, f);
    }
    for (const auto& qt : dec.quartics) {
        std::vector<real_t> f = {1.0, -qt.alpha, qt.beta, -qt.alpha, 1.0};
        rebuilt = poly_multiply(rebuilt, f);
    }
    for (const auto& fo : dec.first_order) {
        std::vector<real_t> f = {1.0, static_cast<real_t>(fo.sign)};
        rebuilt = poly_multiply(rebuilt, f);
    }

    double max_err = 0.0, max_hv = 0.0;
    for (size_t n = 0; n < std::max(h.size(), rebuilt.size()); ++n) {
        double ho = (n < h.size())      ? h[n]      : 0.0;
        double hr = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double d  = std::abs(ho - hr);
        if (d > max_err) max_err = d;
        if (std::abs(ho) > max_hv) max_hv = std::abs(ho);
    }
    double rel_err = (max_hv > 1e-30) ? max_err / max_hv : max_err;

    unsigned total_zeros =
        static_cast<unsigned>(dec.first_order.size())
        + static_cast<unsigned>(dec.biquads.size()) * 2
        + n_num_quartics * 4;
    unsigned rem_deg = dec.remainder.empty()
        ? 0u : static_cast<unsigned>(dec.remainder.size()) - 1;

    std::cerr << "\n  ──────── decompose_v3 SUMMARY ────────\n"
              << "    N=" << N << "  order=" << (N-1) << "\n"
              << "    Stopband biquads: " << n_stopband_bq << "\n"
              << "    Numerical biquads: " << n_num_biquads << "\n"
              << "    Quartics (in rem): " << n_num_quartics << "\n"
              << "    First-order: " << dec.first_order.size() << "\n"
              << "    Total biquads: " << dec.biquads.size() << "\n"
              << "    Zeros in sections: " << total_zeros
              << " / " << (N-1) << "\n"
              << "    Remainder degree: " << rem_deg << "\n"
              << "    Rebuild rel err: " << std::scientific << rel_err
              << std::defaultfloat << "\n";

    if (rem_deg == 0)
        std::cerr << "    >>> FULL FACTORIZATION ACHIEVED <<<\n";

    if (rel_err <= 1e-10)
        std::cerr << "    Quality: EXCELLENT\n";
    else if (rel_err <= 1e-6)
        std::cerr << "    Quality: GOOD\n";
    else if (rel_err <= 1e-3)
        std::cerr << "    Quality: ACCEPTABLE\n";
    else
        std::cerr << "    Quality: *** POOR ***\n";

    std::cerr << "  ========================================================\n\n";

    return dec;
}



// ============================================================================
// Original path: cascade_fir/src/legacy/decompose_v4.cpp
// ============================================================================

// ═══════════════════════════════════════════════════════════════
//  decompose_v4.cpp — Archived comparison pipeline (v4)
//
//  Historical extended-precision factorization experiment kept for
//  comparison against the exact-first family. It is not the default
//  workflow and is built only when `CASCADE_BUILD_LEGACY_PIPELINES=ON`.
//
//  Algorithm:
//    1. Identify stopband zeros from filter specification
//    2. Compute quotient Q via sequential half-recurrence
//       in __float128 (34 significant digits) — eliminates
//       accumulated error from 20+ sequential divisions
//    3. u-substitution Q(z) → F(u) in __float128, then
//       convert F(u) coefficients to double
//    4. Find roots of F(u) via companion matrix eigenvalues
//       (LAPACK dgeev) — stable for degree up to ~60
//    5. Classify roots: real → biquads, complex pairs → quartics
//    6. Spectral gain: G = H(z₀) / ∏sections(z₀) — no poly division
//    7. Assemble full cascade: biquads + quartics + gain
//
//  Key properties:
//    • No polynomial division for gain computation
//    • No accumulated error in Q (extended precision)
//    • Remainder = {G} (scalar) for all practical N
//    • Quartic sections filtered directly (2 multiplications each)
//
//  Requirements:
//    • GCC with __float128 support (standard on x86-64)
//    • libquadmath (-lquadmath)
//    • LAPACK (-llapack) for dgeev
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"

#include <quadmath.h>

#include <complex>
#include <algorithm>
#include <cmath>
#include <vector>
#include <numeric>
#include <iostream>
#include <iomanip>
#include <cassert>
#include <cstring>
#include <limits>

// ─────────────────────────────────────────────────────────────
//  LAPACK prototype (Fortran calling convention)
// ─────────────────────────────────────────────────────────────

extern "C" {
void dgeev_(const char* jobvl, const char* jobvr,
            const int* n, double* a, const int* lda,
            double* wr, double* wi,
            double* vl, const int* ldvl,
            double* vr, const int* ldvr,
            double* work, const int* lwork, int* info);
}

// ─────────────────────────────────────────────────────────────
//  Local type aliases
// ─────────────────────────────────────────────────────────────

using cx = std::complex<double>;
using cld = std::complex<long double>;
using quad = __float128;

static const quad Q_PI = 3.14159265358979323846264338327950288Q;

// ─────────────────────────────────────────────────────────────
//  1. Stopband zero identification (same as v3)
// ─────────────────────────────────────────────────────────────

struct V4_StopbandInfo {
    std::vector<unsigned> pair_k;
    bool has_dc_zero;
    bool has_nyq_zero;
};

static V4_StopbandInfo v4_find_stopband_zeros(const DirectFIR& fir)
{
    V4_StopbandInfo si;
    si.has_dc_zero  = false;
    si.has_nyq_zero = false;

    const unsigned N = fir.length();
    const unsigned k_half = N / 2;
    long double max_abs = 0.0L;
    std::vector<long double> mags(k_half + 1, 0.0L);

    for (unsigned k = 0; k <= k_half; ++k) {
        const long double theta =
            2.0L * static_cast<long double>(PI)
            * static_cast<long double>(k)
            / static_cast<long double>(N);
        const std::complex<long double> z_inv =
            std::polar(1.0L, -theta);

        std::complex<long double> z_pow = 1.0L;
        std::complex<long double> acc = 0.0L;
        for (real_t coeff : fir.h) {
            acc += static_cast<long double>(coeff) * z_pow;
            z_pow *= z_inv;
        }

        const long double mag = std::abs(acc);
        mags[k] = mag;
        max_abs = std::max(max_abs, mag);
    }

    const long double zero_tol = std::max(1e-18L, max_abs * 1e-12L);
    for (unsigned k = 0; k <= k_half; ++k) {
        if (mags[k] > zero_tol) {
            continue;
        }

        if (k == 0) {
            si.has_dc_zero = true;
        } else if (N % 2 == 0 && k == k_half) {
            si.has_nyq_zero = true;
        } else {
            si.pair_k.push_back(k);
        }
    }
    return si;
}

// ─────────────────────────────────────────────────────────────
//  2. Interleave indices for cascade ordering
// ─────────────────────────────────────────────────────────────

static std::vector<unsigned> v4_interleave_indices(
    const std::vector<unsigned>& indices)
{
    std::vector<unsigned> sorted = indices;
    std::sort(sorted.begin(), sorted.end());

    std::vector<unsigned> result;
    result.reserve(sorted.size());

    size_t lo = 0, hi = sorted.size();
    if (hi == 0) return result;
    --hi;

    bool take_lo = true;
    while (result.size() < sorted.size()) {
        if (take_lo) {
            result.push_back(sorted[lo++]);
        } else {
            result.push_back(sorted[hi--]);
        }
        take_lo = !take_lo;
        if (lo > hi && result.size() < sorted.size()) break;
    }
    return result;
}

// ─────────────────────────────────────────────────────────────
//  3. __float128 half-recurrence division for palindromic polys
//
//  Divides palindromic h[0..L-1] by (1 − γ·z⁻¹ + z⁻²).
//  Recurrence runs only to the midpoint; second half mirrored.
//  ALL arithmetic in __float128 (34 significant digits).
// ─────────────────────────────────────────────────────────────

static void q128_biquad_half_divide(const std::vector<quad>& h,
                                    quad gamma,
                                    std::vector<quad>& q)
{
    const size_t len = h.size();
    if (len < 4) { q = h; return; }

    const size_t qlen = len - 2;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;

    q[0] = h[0];
    if (qlen >= 2)
        q[1] = h[1] + gamma * q[0];
    for (size_t n = 2; n <= mid; ++n)
        q[n] = h[n] + gamma * q[n - 1] - q[n - 2];

    // Even-length quotient: element past mid
    if (qlen % 2 == 0 && qlen >= 4) {
        size_t c = qlen / 2;
        if (c > mid)
            q[c] = h[c] + gamma * q[c - 1] - q[c - 2];
    }

    // Mirror second half
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];
}

static std::vector<quad> q128_compute_U_sequence(size_t count, quad gamma)
{
    std::vector<quad> U(count, 0.0Q);
    if (count == 0) return U;
    U[0] = 1.0Q;
    if (count == 1) return U;
    U[1] = gamma;
    for (size_t n = 2; n < count; ++n) {
        U[n] = gamma * U[n - 1] - U[n - 2];
    }
    return U;
}

static quad q128_biquad_divisibility_delta(const std::vector<quad>& h,
                                           quad gamma)
{
    const size_t len = h.size();
    if (len < 3) return 0.0Q;

    const size_t max_u = len - 2; // U_0 .. U_{len-3}
    const std::vector<quad> U = q128_compute_U_sequence(max_u, gamma);

    quad sum = -h[0];
    for (size_t m = 0; m <= len - 3; ++m) {
        sum += h[m] * U[len - 3 - m];
    }
    return sum;
}

static void q128_correct_for_biquad_divisibility(std::vector<quad>& h,
                                                 quad gamma)
{
    const size_t len = h.size();
    if (len < 3) return;

    const quad delta = q128_biquad_divisibility_delta(h, gamma);
    quad h_scale = 0.0Q;
    for (quad x : h) {
        const quad ax = fabsq(x);
        if (ax > h_scale) h_scale = ax;
    }
    h_scale = std::max(1e-30Q, h_scale);
    if (fabsq(delta) <= 1e-28Q * h_scale) {
        return;
    }

    if (len % 2 == 0) {
        return;
    }

    const size_t center = len / 2;
    const size_t u_idx = len - 3 - center;
    const std::vector<quad> U = q128_compute_U_sequence(len - 2, gamma);
    const quad denom = U[u_idx];
    if (fabsq(denom) <= 1e-30Q) {
        return;
    }

    h[center] -= delta / denom;
    for (size_t n = 0; n < len / 2; ++n) {
        quad avg = (h[n] + h[len - 1 - n]) / 2.0Q;
        h[n] = avg;
        h[len - 1 - n] = avg;
    }
}

// ─────────────────────────────────────────────────────────────
//  4. __float128 first-order half-recurrence
// ─────────────────────────────────────────────────────────────

static void q128_first_order_half_divide(const std::vector<quad>& h,
                                         int sign,
                                         std::vector<quad>& q)
{
    const size_t len = h.size();
    if (len < 2) { q = h; return; }

    const size_t qlen = len - 1;
    q.resize(qlen);

    const size_t mid = (qlen - 1) / 2;
    const quad s = static_cast<quad>(sign);

    q[0] = h[0];
    for (size_t n = 1; n <= mid; ++n)
        q[n] = h[n] - s * q[n - 1];

    // Mirror
    for (size_t n = 0; n < qlen / 2; ++n)
        q[qlen - 1 - n] = q[n];
}

// ─────────────────────────────────────────────────────────────
//  5. __float128 palindromic symmetry enforcement
// ─────────────────────────────────────────────────────────────

static void q128_enforce_symmetry(std::vector<quad>& p)
{
    const size_t len = p.size();
    for (size_t n = 0; n < len / 2; ++n) {
        quad avg = (p[n] + p[len - 1 - n]) / 2.0Q;
        p[n] = avg;
        p[len - 1 - n] = avg;
    }
}

// ─────────────────────────────────────────────────────────────
//  6. __float128 u-substitution: palindrome Q → F(u)
//
//  Q(z) palindromic of even degree 2M.
//  F(u) has degree M, F[j] = coefficient of u^j.
//  ALL computation in __float128.
// ─────────────────────────────────────────────────────────────

static std::vector<quad> q128_palindrome_to_u_poly(
    const std::vector<quad>& Q)
{
    int deg = static_cast<int>(Q.size()) - 1;
    assert(deg >= 0);
    assert(deg % 2 == 0);
    int M = deg / 2;

    if (M == 0) {
        return { Q[0] };
    }

    std::vector<quad> F(static_cast<size_t>(M + 1), 0.0Q);
    F[0] = Q[static_cast<size_t>(M)];

    // s_0 = [2], s_1 = [0, 1]
    std::vector<quad> s_prev2 = {2.0Q};
    std::vector<quad> s_prev1 = {0.0Q, 1.0Q};

    // k = 1: F += Q[M-1] * s_1
    F[0] += Q[static_cast<size_t>(M) - 1] * s_prev1[0];
    if (M >= 1) F[1] += Q[static_cast<size_t>(M) - 1] * s_prev1[1];

    for (int k = 2; k <= M; ++k) {
        // s_k = u * s_{k-1} - s_{k-2}
        size_t len_k = static_cast<size_t>(k + 1);
        std::vector<quad> s_cur(len_k, 0.0Q);

        for (size_t j = 1; j < len_k && j - 1 < s_prev1.size(); ++j)
            s_cur[j] = s_prev1[j - 1];

        for (size_t j = 0; j < s_prev2.size() && j < len_k; ++j)
            s_cur[j] -= s_prev2[j];

        quad weight = Q[static_cast<size_t>(M - k)];
        for (size_t j = 0; j < len_k && j < F.size(); ++j)
            F[j] += weight * s_cur[j];

        s_prev2 = std::move(s_prev1);
        s_prev1 = std::move(s_cur);
    }

    return F;
}

// ─────────────────────────────────────────────────────────────
//  7. Companion matrix eigenvalues via LAPACK dgeev
//
//  For polynomial F(u) = c[0] + c[1]*u + ... + c[M]*u^M,
//  the companion matrix is M×M:
//
//      C = | 0  0  ...  0  -c[0]/c[M] |
//          | 1  0  ...  0  -c[1]/c[M] |
//          | 0  1  ...  0  -c[2]/c[M] |
//          | .  .       .      .       |
//          | 0  0  ...  1  -c[M-1]/c[M]|
//
//  Eigenvalues of C = roots of F(u).
//  LAPACK dgeev computes all eigenvalues of a general real matrix.
//
//  Returns: vector of complex eigenvalues.
// ─────────────────────────────────────────────────────────────

static std::vector<cx> companion_eigenvalues(const std::vector<double>& coeffs)
{
    int M = static_cast<int>(coeffs.size()) - 1;
    if (M <= 0) return {};

    if (M == 1) {
        return { cx(-coeffs[0] / coeffs[1], 0.0) };
    }

    if (M == 2) {
        double a = coeffs[2], b = coeffs[1], c = coeffs[0];
        double disc = b * b - 4.0 * a * c;
        if (disc >= 0.0) {
            double sq = std::sqrt(disc);
            return { cx((-b + sq) / (2.0 * a), 0.0),
                     cx((-b - sq) / (2.0 * a), 0.0) };
        } else {
            double sq = std::sqrt(-disc);
            return { cx(-b / (2.0 * a),  sq / (2.0 * a)),
                     cx(-b / (2.0 * a), -sq / (2.0 * a)) };
        }
    }

    // Балансировка по переменной u = scale * v.
    // Для полинома F(u)=Σ c_k u^k строим эквивалентный
    // G(v)=F(scale*v)=Σ c_k scale^k v^k и подбираем scale так,
    // чтобы динамический диапазон коэффициентов G(v) был меньше.
    // Это не меняет корни как множество: u_i = scale * v_i.
    auto coeff_spread = [](const std::vector<double>& c, double log2_scale) {
        double min_log2 = std::numeric_limits<double>::infinity();
        double max_log2 = -std::numeric_limits<double>::infinity();
        for (size_t k = 0; k < c.size(); ++k) {
            const double ak = std::abs(c[k]);
            if (ak < 1e-300) continue;
            const double lv = std::log2(ak) + static_cast<double>(k) * log2_scale;
            min_log2 = std::min(min_log2, lv);
            max_log2 = std::max(max_log2, lv);
        }
        if (!std::isfinite(min_log2) || !std::isfinite(max_log2)) {
            return std::numeric_limits<double>::infinity();
        }
        return max_log2 - min_log2;
    };

    double best_log2_scale = 0.0;
    double best_spread = coeff_spread(coeffs, 0.0);
    for (int half_step = -64; half_step <= 64; ++half_step) {
        const double log2_scale = 0.5 * static_cast<double>(half_step);
        const double spread = coeff_spread(coeffs, log2_scale);
        if (spread < best_spread) {
            best_spread = spread;
            best_log2_scale = log2_scale;
        }
    }

    const double u_scale = std::exp2(best_log2_scale);
    std::vector<double> balanced = coeffs;
    if (std::abs(best_log2_scale) > 1e-12) {
        double scale_pow = 1.0;
        for (double& ck : balanced) {
            ck *= scale_pow;
            scale_pow *= u_scale;
        }
    }

    // Build companion matrix in column-major order (Fortran)
    double lc = balanced[static_cast<size_t>(M)];
    int n = M;
    std::vector<double> A(static_cast<size_t>(n * n), 0.0);

    // Fill companion matrix: subdiagonal = 1, last column = -c[k]/lc
    for (int i = 0; i < n; ++i) {
        // Last column: A[i][n-1] = -coeffs[i] / lc
        A[static_cast<size_t>(i + (n - 1) * n)] = -balanced[static_cast<size_t>(i)] / lc;
        // Subdiagonal: A[i+1][i] = 1
        if (i + 1 < n)
            A[static_cast<size_t>((i + 1) + i * n)] = 1.0;
    }

    // Allocate output arrays
    std::vector<double> wr(static_cast<size_t>(n));   // real parts
    std::vector<double> wi(static_cast<size_t>(n));   // imaginary parts

    // Workspace query
    double work_query;
    int lwork = -1;
    int info = 0;
    int one = 1;
    dgeev_("N", "N", &n, A.data(), &n,
           wr.data(), wi.data(),
           nullptr, &one, nullptr, &one,
           &work_query, &lwork, &info);

    lwork = static_cast<int>(work_query);
    std::vector<double> work(static_cast<size_t>(lwork));

    // Compute eigenvalues
    dgeev_("N", "N", &n, A.data(), &n,
           wr.data(), wi.data(),
           nullptr, &one, nullptr, &one,
           work.data(), &lwork, &info);

    if (info != 0) {
        std::cerr << "  v4: dgeev failed, info=" << info << "\n";
        return {};
    }

    // Pack into complex vector
    std::vector<cx> roots(static_cast<size_t>(n));
    for (int i = 0; i < n; ++i) {
        roots[static_cast<size_t>(i)] =
            cx(wr[static_cast<size_t>(i)], wi[static_cast<size_t>(i)]) * u_scale;
    }

    return roots;
}

// ─────────────────────────────────────────────────────────────
//  7b. Newton polishing of u-roots using higher-precision coeffs
//
//  dgeev gives a solid initial approximation, but for M ≳ 12 the
//  roots can still drift enough to noticeably perturb quartic
//  parameters.  Refine each root with several Newton steps using
//  F(u) coefficients before they were compressed into companion form.
// ─────────────────────────────────────────────────────────────

static std::pair<cld, cld> eval_poly_and_derivative(
    const std::vector<quad>& coeffs,
    cld z)
{
    cld p = 0.0L;
    cld dp = 0.0L;

    for (size_t i = coeffs.size(); i-- > 0;) {
        dp = dp * z + p;
        p = p * z + static_cast<long double>(coeffs[i]);
    }

    return {p, dp};
}

static void polish_u_roots(const std::vector<quad>& coeffs_q,
                           std::vector<cx>& roots)
{
    if (coeffs_q.size() < 2 || roots.empty()) {
        return;
    }

    for (cx& root : roots) {
        cld z(static_cast<long double>(root.real()),
              static_cast<long double>(root.imag()));

        for (int iter = 0; iter < 12; ++iter) {
            const auto [p, dp] = eval_poly_and_derivative(coeffs_q, z);
            const long double dp_norm = std::abs(dp);
            if (!(dp_norm > 1e-24L)) {
                break;
            }

            cld step = p / dp;
            const long double step_abs = std::abs(step);
            const long double z_scale = 1.0L + std::abs(z);
            if (step_abs > 0.5L * z_scale) {
                step *= (0.5L * z_scale / step_abs);
            }

            z -= step;
            if (step_abs < 1e-22L * z_scale) {
                break;
            }
        }

        long double re = z.real();
        long double im = z.imag();
        if (std::abs(im) < 1e-18L * (1.0L + std::abs(re))) {
            im = 0.0L;
        }

        root = cx(static_cast<double>(re), static_cast<double>(im));
    }
}

static quad q128_abs_max(const std::vector<quad>& v)
{
    quad m = 0.0Q;
    for (quad x : v) {
        quad ax = fabsq(x);
        if (ax > m) m = ax;
    }
    return m;
}

static void q128_trim_trailing(std::vector<quad>& v)
{
    while (!v.empty() && fabsq(v.back()) < 1e-30Q) {
        v.pop_back();
    }
    if (v.empty()) {
        v.push_back(0.0Q);
    }
}

static std::vector<quad> q128_poly_multiply(const std::vector<quad>& a,
                                            const std::vector<quad>& b)
{
    if (a.empty() || b.empty()) {
        return {};
    }

    std::vector<quad> c(a.size() + b.size() - 1, 0.0Q);
    for (size_t i = 0; i < a.size(); ++i) {
        for (size_t j = 0; j < b.size(); ++j) {
            c[i + j] += a[i] * b[j];
        }
    }
    return c;
}

static std::pair<std::vector<quad>, std::vector<quad>>
q128_poly_divide(const std::vector<quad>& a,
                 const std::vector<quad>& b)
{
    const size_t na = a.size();
    const size_t nb = b.size();

    if (nb == 0 || na < nb || fabsq(b[0]) < 1e-34Q) {
        return {{}, a};
    }

    std::vector<quad> r = a;
    const size_t qlen = na - nb + 1;
    std::vector<quad> q(qlen, 0.0Q);

    for (size_t i = 0; i < qlen; ++i) {
        q[i] = r[i] / b[0];
        for (size_t j = 0; j < nb; ++j) {
            r[i + j] -= q[i] * b[j];
        }
    }

    std::vector<quad> rem(r.begin() + static_cast<long>(qlen), r.end());
    q128_trim_trailing(q);
    q128_trim_trailing(rem);
    return {std::move(q), std::move(rem)};
}

static double q128_relative_rebuild_error(const std::vector<quad>& original,
                                          const std::vector<quad>& quotient,
                                          quad gamma)
{
    const std::vector<quad> rebuilt =
        q128_poly_multiply(quotient, {1.0Q, -gamma, 1.0Q});

    quad max_err = 0.0Q;
    quad max_ref = 0.0Q;
    for (size_t i = 0; i < std::max(original.size(), rebuilt.size()); ++i) {
        const quad o = (i < original.size()) ? original[i] : 0.0Q;
        const quad r = (i < rebuilt.size()) ? rebuilt[i] : 0.0Q;
        max_err = std::max(max_err, fabsq(o - r));
        max_ref = std::max(max_ref, fabsq(o));
    }
    return static_cast<double>(max_err / std::max(1e-30Q, max_ref));
}

static real_t q128_to_real(quad x)
{
    return static_cast<real_t>(x);
}

static std::vector<real_t> rebuild_from_sections(const CascadeDecomposition& dec)
{
    std::vector<real_t> rebuilt = dec.remainder.empty()
        ? std::vector<real_t>{dec.gain}
        : dec.remainder;

    for (const auto& bq : dec.biquads) {
        rebuilt = poly_multiply(rebuilt, {1.0, -bq.gamma, 1.0});
    }
    for (const auto& qt : dec.quartics) {
        rebuilt = poly_multiply(rebuilt, {1.0, -qt.alpha, qt.beta, -qt.alpha, 1.0});
    }
    for (const auto& fo : dec.first_order) {
        rebuilt = poly_multiply(rebuilt, {1.0, static_cast<real_t>(fo.sign)});
    }
    return rebuilt;
}

static std::vector<real_t> q128_to_real_vector(const std::vector<quad>& v)
{
    std::vector<real_t> out(v.size());
    for (size_t i = 0; i < v.size(); ++i) {
        out[i] = q128_to_real(v[i]);
    }
    return out;
}

static double compute_rebuild_rel_error_parts(
    const std::vector<FirstOrder>& first_order,
    const std::vector<Biquad>& biquads,
    const std::vector<Quartic>& quartics,
    const std::vector<real_t>& remainder,
    const std::vector<real_t>& h)
{
    std::vector<real_t> rebuilt = remainder;
    for (const auto& bq : biquads) {
        rebuilt = poly_multiply(rebuilt, {1.0, -bq.gamma, 1.0});
    }
    for (const auto& qt : quartics) {
        rebuilt = poly_multiply(rebuilt, {1.0, -qt.alpha, qt.beta, -qt.alpha, 1.0});
    }
    for (const auto& fo : first_order) {
        rebuilt = poly_multiply(rebuilt, {1.0, static_cast<real_t>(fo.sign)});
    }

    double max_err = 0.0;
    double max_hv = 0.0;
    for (size_t n = 0; n < std::max(h.size(), rebuilt.size()); ++n) {
        const double ho = (n < h.size()) ? h[n] : 0.0;
        const double hr = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        max_err = std::max(max_err, std::abs(ho - hr));
        max_hv = std::max(max_hv, std::abs(ho));
    }
    return (max_hv > 1e-30) ? max_err / max_hv : max_err;
}

// ═══════════════════════════════════════════════════════════════
//
//   decompose_v4 — FULL FACTORIZATION WITH EXTENDED PRECISION
//
// ═══════════════════════════════════════════════════════════════

CascadeDecomposition decompose_v4(const DirectFIR& fir,
                                  bool interleave_order)
{
    CascadeDecomposition dec;
    dec.gain = 1.0;

    const unsigned N = fir.length();
    const auto& h = fir.h;

    if (N < 3) {
        dec.remainder = h;
        return dec;
    }

    std::cerr << "\n  ========================================================\n"
              << "  decompose_v4: EXTENDED PRECISION FACTORIZATION (N=" << N
              << ")\n"
              << "  ========================================================\n";

    // ═════════════════════════════════════════════════════════
    //  STEP 1: Identify stopband zeros
    // ═════════════════════════════════════════════════════════

    V4_StopbandInfo si = v4_find_stopband_zeros(fir);
    unsigned num_sb_biquads = static_cast<unsigned>(si.pair_k.size());
    unsigned num_sb_fo      = (si.has_dc_zero ? 1u : 0u)
                            + (si.has_nyq_zero ? 1u : 0u);

    std::cerr << "  Step 1: Stopband: "
              << num_sb_biquads << " biquads + "
              << num_sb_fo << " first-order\n";

    // ═════════════════════════════════════════════════════════
    //  STEP 2: Compute h[n] and extract Q in __float128
    //
    //  Design h[n] from scratch in quad precision, then
    //  sequential half-recurrence — all in 34-digit arithmetic.
    //  Error per division: ~N × 10⁻³⁴.
    //  After P divisions: ~P × N × 10⁻³⁴ ≈ 10⁻²⁸ (for N=257, P=64)
    //  Conversion to double: ε_coeff ≈ 10⁻¹⁵ (= ε_mach)
    // ═════════════════════════════════════════════════════════

    // ── 2a. Design h[n] in __float128 ────────────────────────
    std::vector<quad> h_q(N);
    for (unsigned n = 0; n < N; ++n) {
        h_q[n] = static_cast<quad>(h[n]);
    }
    q128_enforce_symmetry(h_q);
    quad q_N = static_cast<quad>(N);

    // ── 2b. Sequential half-recurrence in __float128 ─────────
    std::vector<quad> Q_q = h_q;

    if (si.has_dc_zero) {
        std::vector<quad> q;
        q128_first_order_half_divide(Q_q, -1, q);
        q128_enforce_symmetry(q);
        Q_q = std::move(q);
    }
    if (si.has_nyq_zero) {
        std::vector<quad> q;
        q128_first_order_half_divide(Q_q, +1, q);
        q128_enforce_symmetry(q);
        Q_q = std::move(q);
    }
    std::vector<unsigned> extraction_k;
    extraction_k.reserve(si.pair_k.size());
    std::vector<unsigned> remaining_k = interleave_order
        ? v4_interleave_indices(si.pair_k)
        : si.pair_k;

    while (!remaining_k.empty()) {
        size_t best_idx = remaining_k.size();
        double best_score = 1e300;
        std::vector<quad> best_q;

        for (size_t i = 0; i < remaining_k.size(); ++i) {
            const quad gamma_q =
                2.0Q * cosq(2.0Q * Q_PI * static_cast<quad>(remaining_k[i]) / q_N);
            std::vector<quad> h_trial = Q_q;
            q128_correct_for_biquad_divisibility(h_trial, gamma_q);
            std::vector<quad> q_trial;
            q128_biquad_half_divide(h_trial, gamma_q, q_trial);
            q128_enforce_symmetry(q_trial);

            const double score = q128_relative_rebuild_error(h_trial, q_trial, gamma_q);
            if (score < best_score) {
                best_score = score;
                best_idx = i;
                best_q = std::move(q_trial);
            }
        }

        if (best_idx == remaining_k.size()) {
            break;
        }

        extraction_k.push_back(remaining_k[best_idx]);
        Q_q = std::move(best_q);
        remaining_k.erase(remaining_k.begin() + static_cast<long>(best_idx));
    }

    int Q_deg = static_cast<int>(Q_q.size()) - 1;

    std::cerr << "  Step 2: Q computed in __float128, deg=" << Q_deg << "\n";

    // ═════════════════════════════════════════════════════════
    //  STEP 3: Build sections
    // ═════════════════════════════════════════════════════════

    // Stopband sections (exact) → straight into dec
    std::vector<FirstOrder> stopband_fo;
    std::vector<Biquad> stopband_bq;
    if (si.has_dc_zero)
        stopband_fo.push_back(FirstOrder{-1});
    if (si.has_nyq_zero)
        stopband_fo.push_back(FirstOrder{+1});
    for (unsigned k : extraction_k) {
        real_t gamma = 2.0 * std::cos(2.0 * PI * k / N);
        stopband_bq.push_back(Biquad{gamma, k});
    }
    dec.first_order = stopband_fo;
    dec.biquads = stopband_bq;
    unsigned n_stopband_bq = static_cast<unsigned>(dec.biquads.size());

    // Numerical sections from quotient
    std::vector<Biquad>   numerical_bq;
    std::vector<Quartic>  numerical_qt;
    std::vector<FirstOrder> numerical_fo;
    std::vector<quad> remainder_q = Q_q;

    if (Q_deg > 0) {
        // ── 3a. Extract first-order if odd degree ────────────
        if (Q_deg % 2 != 0) {
            std::vector<quad> q;
            q128_first_order_half_divide(Q_q, +1, q);
            q128_enforce_symmetry(q);
            Q_q = std::move(q);
            remainder_q = Q_q;
            Q_deg = static_cast<int>(Q_q.size()) - 1;
            numerical_fo.push_back(FirstOrder{+1});
        }
        if (Q_deg > 0 && Q_deg % 2 != 0) {
            std::vector<quad> q;
            q128_first_order_half_divide(Q_q, -1, q);
            q128_enforce_symmetry(q);
            Q_q = std::move(q);
            remainder_q = Q_q;
            Q_deg = static_cast<int>(Q_q.size()) - 1;
            numerical_fo.push_back(FirstOrder{-1});
        }

        if (Q_deg >= 2 && Q_deg % 2 == 0) {
            // ── 3b. u-substitution in __float128 ─────────────
            std::vector<quad> F_q = q128_palindrome_to_u_poly(Q_q);
            int M = Q_deg / 2;

            std::cerr << "  Step 3: F(u) deg=" << M
                      << " (from Q deg=" << Q_deg << ")\n";

            // ── 3c. Convert F(u) to double ───────────────────
            std::vector<double> F_d(F_q.size());
            for (size_t i = 0; i < F_q.size(); ++i)
                F_d[i] = static_cast<double>(F_q[i]);

            // ── 3d. Companion matrix eigenvalues (LAPACK) ────
            std::vector<cx> u_roots = companion_eigenvalues(F_d);
            if (M <= 16) {
                polish_u_roots(F_q, u_roots);
            }

            std::cerr << "  Step 3: Found " << u_roots.size()
                      << " u-roots via LAPACK dgeev";
            if (M <= 16) {
                std::cerr << " + Newton polishing";
            }
            std::cerr << "\n";

            // ── 3e. Candidate factors from u-roots ───────────
            struct Candidate {
                enum Type { BQ, QT } type;
                double gamma = 0.0;
                double alpha = 0.0;
                double beta = 0.0;
                double quality = 0.0;
            };

            static constexpr double REAL_TOL = 1e-8;
            static constexpr double PAIR_TOL = 1e-6;
            std::vector<bool> used(u_roots.size(), false);
            std::vector<Candidate> candidates;

            for (size_t i = 0; i < u_roots.size(); ++i) {
                if (std::abs(u_roots[i].imag()) < REAL_TOL) {
                    Candidate c;
                    c.type = Candidate::BQ;
                    c.gamma = u_roots[i].real();
                    c.quality = std::abs(u_roots[i].imag());
                    candidates.push_back(c);
                    used[i] = true;
                }
            }

            for (size_t i = 0; i < u_roots.size(); ++i) {
                if (used[i]) continue;
                if (std::abs(u_roots[i].imag()) < REAL_TOL) continue;

                size_t best_j = u_roots.size();
                double best_dist = 1e30;
                for (size_t j = i + 1; j < u_roots.size(); ++j) {
                    if (used[j]) continue;
                    if (u_roots[i].imag() * u_roots[j].imag() > 0.0) continue;
                    double dist = std::abs(u_roots[j] - std::conj(u_roots[i]));
                    if (dist < best_dist) { best_dist = dist; best_j = j; }
                }
                const double pair_tol = PAIR_TOL * (1.0 + std::abs(u_roots[i]));
                if (best_j < u_roots.size() && best_dist < pair_tol) {
                    const double re_u = (u_roots[i].real() + u_roots[best_j].real()) / 2.0;
                    const double im_u = std::abs(
                        (u_roots[i].imag() - u_roots[best_j].imag()) / 2.0);
                    Candidate c;
                    c.type = Candidate::QT;
                    c.alpha = 2.0 * re_u;
                    c.beta  = 2.0 + re_u * re_u + im_u * im_u;
                    c.quality = best_dist;
                    candidates.push_back(c);
                    used[i] = true;
                    used[best_j] = true;
                }
            }

            std::sort(candidates.begin(), candidates.end(),
                      [](const Candidate& a, const Candidate& b) {
                          return a.quality < b.quality;
                      });

            std::vector<quad> Q_work = Q_q;
            std::vector<quad> F_work = F_q;
            unsigned accepted_bq = 0;
            unsigned accepted_qt = 0;

            static constexpr double STRICT_DIV_TOL = 1e-14;
            static constexpr double GLOBAL_REBUILD_TOL = 1e-6;

            while (!candidates.empty() && F_work.size() > 1) {
                size_t best_idx = candidates.size();
                double best_score = 1e300;
                double best_global_err = 1e300;
                std::vector<quad> best_Q_next;
                std::vector<quad> best_F_next;
                Candidate best_cand;

                for (size_t ci = 0; ci < candidates.size(); ++ci) {
                    const Candidate& cand = candidates[ci];

                    std::vector<quad> factor_u;
                    std::vector<quad> factor_z;
                    if (cand.type == Candidate::BQ) {
                        factor_u = { -static_cast<quad>(cand.gamma), 1.0Q };
                        factor_z = { 1.0Q, -static_cast<quad>(cand.gamma), 1.0Q };
                    } else {
                        factor_u = {
                            static_cast<quad>(cand.beta - 2.0),
                            -static_cast<quad>(cand.alpha),
                            1.0Q
                        };
                        factor_z = {
                            1.0Q,
                            -static_cast<quad>(cand.alpha),
                            static_cast<quad>(cand.beta),
                            -static_cast<quad>(cand.alpha),
                            1.0Q
                        };
                    }

                    if (factor_u.size() > F_work.size() || factor_z.size() > Q_work.size()) {
                        continue;
                    }

                    auto [F_trial, F_rem] = q128_poly_divide(F_work, factor_u);
                    auto [Q_trial, Q_rem] = q128_poly_divide(Q_work, factor_z);

                    const double rel_F = static_cast<double>(
                        q128_abs_max(F_rem) / std::max(1e-30Q, q128_abs_max(F_work)));
                    const double rel_Q = static_cast<double>(
                        q128_abs_max(Q_rem) / std::max(1e-30Q, q128_abs_max(Q_work)));

                    double sym_err = 0.0;
                    for (size_t i = 0; i < Q_trial.size() / 2; ++i) {
                        sym_err = std::max(sym_err, static_cast<double>(
                            fabsq(Q_trial[i] - Q_trial[Q_trial.size() - 1 - i])));
                    }
                    sym_err /= std::max(1e-30, static_cast<double>(q128_abs_max(Q_trial)));

                    const double score = std::max({rel_F, rel_Q, sym_err});
                    if (score > STRICT_DIV_TOL) {
                        continue;
                    }

                    std::vector<Biquad> trial_bq = numerical_bq;
                    std::vector<Quartic> trial_qt = numerical_qt;
                    if (cand.type == Candidate::BQ) {
                        trial_bq.push_back(Biquad{cand.gamma, 0});
                    } else {
                        trial_qt.push_back(Quartic{cand.alpha, cand.beta});
                    }

                    const double global_err = compute_rebuild_rel_error_parts(
                        dec.first_order,
                        [&]() {
                            std::vector<Biquad> all = dec.biquads;
                            all.insert(all.end(), trial_bq.begin(), trial_bq.end());
                            return all;
                        }(),
                        trial_qt,
                        q128_to_real_vector(Q_trial),
                        h);

                    if (score < best_score) {
                        best_score = score;
                        best_global_err = global_err;
                        best_idx = ci;
                        best_Q_next = std::move(Q_trial);
                        best_F_next = std::move(F_trial);
                        best_cand = cand;
                    }
                }

                if (best_idx == candidates.size() || best_global_err > GLOBAL_REBUILD_TOL) {
                    break;
                }

                q128_enforce_symmetry(best_Q_next);
                Q_work = std::move(best_Q_next);
                F_work = std::move(best_F_next);
                q128_trim_trailing(Q_work);
                q128_trim_trailing(F_work);

                if (best_cand.type == Candidate::BQ) {
                    numerical_bq.push_back(Biquad{best_cand.gamma, 0});
                    ++accepted_bq;
                } else {
                    numerical_qt.push_back(Quartic{best_cand.alpha, best_cand.beta});
                    ++accepted_qt;
                }

                candidates.erase(candidates.begin() + static_cast<long>(best_idx));
            }

            remainder_q = std::move(Q_work);
            Q_q = remainder_q;
            Q_deg = static_cast<int>(Q_q.size()) - 1;

            unsigned n_bq_uc = 0, n_bq_off = 0;
            for (const auto& bq : numerical_bq) {
                if (std::abs(bq.gamma) <= 2.0 + 1e-9) ++n_bq_uc;
                else ++n_bq_off;
            }

            std::cerr << "  Step 3: accepted " << accepted_bq
                      << " biquads (" << n_bq_uc << " UC, "
                      << n_bq_off << " off-UC), "
                      << accepted_qt << " quartics"
                      << ", remainder deg " << Q_deg << "\n";
        }
    }

    // Add numerical sections to dec
    for (const auto& fo : numerical_fo)
        dec.first_order.push_back(fo);
    for (const auto& bq : numerical_bq)
        dec.biquads.push_back(bq);
    for (const auto& qt : numerical_qt)
        dec.quartics.push_back(qt);

    dec.remainder = q128_to_real_vector(remainder_q);
    dec.gain = 1.0;

    std::cerr << "  Step 4: coefficient remainder deg="
              << (dec.remainder.empty() ? 0 : dec.remainder.size() - 1);
    if (dec.remainder.size() == 1) {
        std::cerr << "  gain=" << std::scientific
                  << dec.remainder[0] << std::defaultfloat;
    }
    std::cerr << "\n";

    // ═════════════════════════════════════════════════════════
    //  STEP 5: Verification
    // ═════════════════════════════════════════════════════════

    std::vector<real_t> rebuilt = rebuild_from_sections(dec);

    double max_err = 0.0, max_hv = 0.0;
    for (size_t n = 0; n < std::max(h.size(), rebuilt.size()); ++n) {
        double ho = (n < h.size())      ? h[n]      : 0.0;
        double hr = (n < rebuilt.size()) ? rebuilt[n] : 0.0;
        double d  = std::abs(ho - hr);
        if (d > max_err) max_err = d;
        if (std::abs(ho) > max_hv) max_hv = std::abs(ho);
    }
    double rel_err = (max_hv > 1e-30) ? max_err / max_hv : max_err;

    unsigned total_zeros =
        static_cast<unsigned>(dec.first_order.size())
        + static_cast<unsigned>(dec.biquads.size()) * 2
        + static_cast<unsigned>(dec.quartics.size()) * 4;

    unsigned rem_deg = static_cast<unsigned>(dec.remainder.size()) - 1;

    std::cerr << "\n  ──────── decompose_v4 SUMMARY ────────\n"
              << "    N=" << N << "  order=" << (N - 1) << "\n"
              << "    Stopband biquads: " << n_stopband_bq << "\n"
              << "    Numerical biquads: " << numerical_bq.size() << "\n"
              << "    Quartics: " << numerical_qt.size() << "\n"
              << "    First-order: " << dec.first_order.size() << "\n"
              << "    Total biquads: " << dec.biquads.size() << "\n"
              << "    Zeros: " << total_zeros
              << " / " << (N - 1) << "\n"
              << "    Remainder deg: " << rem_deg << "\n"
              << "    Rebuild rel err: " << std::scientific
              << rel_err << std::defaultfloat << "\n";

    if (rel_err <= 1e-10)
        std::cerr << "    Quality: EXCELLENT\n";
    else if (rel_err <= 1e-6)
        std::cerr << "    Quality: GOOD\n";
    else if (rel_err <= 1e-3)
        std::cerr << "    Quality: ACCEPTABLE\n";
    else
        std::cerr << "    Quality: *** POOR ***\n";

    std::cerr << "  ========================================================\n\n";

    return dec;
}



