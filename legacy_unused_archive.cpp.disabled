// ═══════════════════════════════════════════════════════════════
//  liquid_reference.cpp
//  Эталонная фильтрация через библиотеку liquid-dsp.
//
//  liquid-dsp — открытая библиотека цифровой обработки сигналов
//  (https://github.com/jgaeddert/liquid-dsp), широко используемая
//  в задачах SDR и телекоммуникаций.  Реализация КИХ-фильтра
//  firfilt_rrrf (float → float) хорошо протестирована и служит
//  независимым эталоном для проверки корректности собственных
//  реализаций (прямой и каскадной).
//
//  API liquid-dsp для КИХ-фильтрации:
//    firfilt_rrrf_create(h, N)    — создать фильтр по коэффициентам
//    firfilt_rrrf_push(q, x)     — подать входной отсчёт
//    firfilt_rrrf_execute(q, &y) — вычислить выходной отсчёт
//    firfilt_rrrf_destroy(q)     — освободить ресурсы
//
//  Коэффициенты h[n] передаются в формате float, поэтому
//  выполняется преобразование из double (формат DirectFIR::h)
//  во float перед созданием фильтра.
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"
#include <liquid/liquid.h>

// ═══════════════════════════════════════════════════════════════
//  filter_liquid — пакетная фильтрация через liquid-dsp
//
//  Принимает:
//    fir  — спроектированный фильтр (коэффициенты в double)
//    x    — входной сигнал (float)
//
//  Возвращает:
//    y    — выходной сигнал (float), той же длины, что и x
//
//  Внутренняя реализация liquid-dsp использует прямую свёртку
//  с кольцевым буфером (аналогично нашей DirectFilterState,
//  но оптимизированную под конкретную платформу с учётом
//  SIMD-расширений, если они доступны).
//
//  Поскольку liquid-dsp работает с float, а наши коэффициенты
//  хранятся в double, неизбежна потеря точности при
//  преобразовании.  Эта потеря одинакова для всех трёх
//  реализаций (наша прямая, наша каскадная, liquid), поскольку
//  входной сигнал x тоже имеет формат float.
// ═══════════════════════════════════════════════════════════════

std::vector<sample_t> filter_liquid(const DirectFIR& fir,
                                    const std::vector<sample_t>& x)
{
    const unsigned N = fir.length();

    // ──────────────────────────────────────────────────────────
    //  1.  Преобразовать коэффициенты из double во float.
    //
    //  liquid-dsp ожидает массив float.  Порядок коэффициентов
    //  в liquid-dsp: h[0] соответствует самой старой задержке,
    //  т.е. h[0]·x[m−(N−1)] + … + h[N−1]·x[m].
    //  Это обратный порядок по сравнению с нашим соглашением
    //  H(z) = h[0] + h[1]·z⁻¹ + … + h[N−1]·z⁻⁽ᴺ⁻¹⁾,
    //  где h[0] умножается на x[m] (текущий отсчёт).
    //
    //  Поэтому передаём коэффициенты в обратном порядке.
    // ──────────────────────────────────────────────────────────

    std::vector<float> h_float(N);
    for (unsigned n = 0; n < N; ++n) {
        h_float[n] = static_cast<float>(fir.h[N - 1 - n]);
    }

    // ──────────────────────────────────────────────────────────
    //  2.  Создать объект фильтра liquid-dsp.
    //
    //  firfilt_rrrf — КИХ-фильтр: вещественные коэффициенты,
    //  вещественный вход, вещественный выход (float).
    // ──────────────────────────────────────────────────────────

    firfilt_rrrf q = firfilt_rrrf_create(h_float.data(), N);

    if (q == nullptr) {
        std::cerr << "  Ошибка: firfilt_rrrf_create вернул NULL.\n";
        return std::vector<sample_t>(x.size(), 0.0f);
    }

    // ──────────────────────────────────────────────────────────
    //  3.  Поотсчётная фильтрация.
    //
    //  Для каждого входного отсчёта x[m]:
    //    push   — загрузить отсчёт во внутренний буфер
    //    execute — вычислить свёртку и получить y[m]
    // ──────────────────────────────────────────────────────────

    std::vector<sample_t> y(x.size());

    for (size_t m = 0; m < x.size(); ++m) {
        firfilt_rrrf_push(q, x[m]);

        float out = 0.0f;
        firfilt_rrrf_execute(q, &out);

        y[m] = out;
    }

    // ──────────────────────────────────────────────────────────
    //  4.  Освободить ресурсы.
    // ──────────────────────────────────────────────────────────

    firfilt_rrrf_destroy(q);

    return y;
}


