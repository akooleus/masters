// ═══════════════════════════════════════════════════════════════
//  test_decompose.cpp
//  Юнит-тест каскадной декомпозиции КИХ-фильтра частотной
//  выборки.
//
//  Проверяет:
//    1. Корректность проектирования (симметрия h[n]).
//    2. Корректность декомпозиции (число выделенных нулей).
//    3. Корректность пересборки (h_recomposed ≈ h_original).
//    4. Совпадение АЧХ прямой и каскадной форм.
//    5. Масштабируемость: фильтры разной длины (N = 9..129).
//
//  Запускается без аргументов, выводит результаты в stdout.
//  Код возврата: 0 — все тесты пройдены, 1 — есть ошибки.
// ═══════════════════════════════════════════════════════════════

#include "cascade_fir.h"
#include <cstdlib>

// ─────────────────────────────────────────────────────────────
//  Вспомогательные функции
// ─────────────────────────────────────────────────────────────

static int g_tests_run    = 0;
static int g_tests_passed = 0;
static int g_tests_failed = 0;

static void report(const std::string& name, bool ok, const std::string& detail = "")
{
    ++g_tests_run;
    if (ok) {
        ++g_tests_passed;
        std::cout << "  [PASS] " << name;
    } else {
        ++g_tests_failed;
        std::cout << "  [FAIL] " << name;
    }
    if (!detail.empty()) {
        std::cout << "  (" << detail << ")";
    }
    std::cout << "\n";
}

// Проверить симметрию вектора: h[n] == h[N-1-n]
static double check_symmetry(const std::vector<real_t>& h)
{
    double max_asym = 0.0;
    const size_t N = h.size();
    for (size_t n = 0; n < N / 2; ++n) {
        double diff = std::abs(h[n] - h[N - 1 - n]);
        if (diff > max_asym) max_asym = diff;
    }
    return max_asym;
}

// В тестах используем ту же устойчивую половинную рекурсию,
// что и основная baseline-реализация декомпозиции.
static bool divide_by_biquad_half_for_test(const std::vector<real_t>& h,
                                           real_t gamma,
                                           std::vector<real_t>& quotient)
{
    const size_t len = h.size();
    if (len < 3) {
        return false;
    }

    if (len == 3) {
        quotient.resize(1);
        quotient[0] = h[0];
        const real_t rem_mid = std::abs(h[1] + gamma * quotient[0]);
        const real_t rem_sym = std::abs(h[2] - quotient[0]);
        if (rem_mid > 1e-6 || rem_sym > 1e-6) {
            quotient.clear();
            return false;
        }
        return true;
    }

    const size_t qlen = len - 2;
    quotient.resize(qlen);

    const size_t mid = (qlen - 1) / 2;

    quotient[0] = h[0];
    if (qlen >= 2) {
        quotient[1] = h[1] + gamma * quotient[0];
    }
    for (size_t n = 2; n <= mid; ++n) {
        quotient[n] = h[n] + gamma * quotient[n - 1] - quotient[n - 2];
    }

    if (qlen % 2 == 0 && qlen >= 4) {
        const size_t center = qlen / 2;
        if (center > mid) {
            quotient[center] = h[center] + gamma * quotient[center - 1]
                             - quotient[center - 2];
        }
    }

    for (size_t n = 0; n < qlen / 2; ++n) {
        quotient[qlen - 1 - n] = quotient[n];
    }

    return true;
}

// ─────────────────────────────────────────────────────────────
//  Тест 1: проектирование фильтра, проверка симметрии h[n]
// ─────────────────────────────────────────────────────────────

static void test_design_symmetry()
{
    std::cout << "\n--- Тест 1: проектирование и симметрия h[n] ---\n";

    struct TestCase {
        unsigned N;
        real_t fs, f_pass, f_stop;
    };

    TestCase cases[] = {
        {  9, 18000.0, 5000.0, 7000.0},
        { 15, 32000.0, 4000.0, 6000.0},
        { 29, 32000.0, 4000.0, 6000.0},
        { 33, 32000.0, 4000.0, 6000.0},
        { 65, 48000.0, 8000.0, 12000.0},
        {129, 48000.0, 8000.0, 12000.0},
    };

    for (const auto& tc : cases) {
        FilterSpec spec{tc.N, tc.fs, tc.f_pass, tc.f_stop};
        DirectFIR fir = design_freq_sampling(spec);

        // Проверка длины
        bool len_ok = (fir.h.size() == tc.N);
        report("N=" + std::to_string(tc.N) + " длина", len_ok,
               "ожидалось " + std::to_string(tc.N)
               + ", получено " + std::to_string(fir.h.size()));

        // Проверка симметрии
        double asym = check_symmetry(fir.h);
        bool sym_ok = (asym < 1e-15);
        report("N=" + std::to_string(tc.N) + " симметрия", sym_ok,
               "max|h[n]-h[N-1-n]| = " + std::to_string(asym));

        // Проверка, что h[n] не все нули
        double energy = 0.0;
        for (auto v : fir.h) energy += v * v;
        bool nonzero_ok = (energy > 1e-10);
        report("N=" + std::to_string(tc.N) + " ненулевая энергия", nonzero_ok,
               "||h||² = " + std::to_string(energy));
    }
}

// ─────────────────────────────────────────────────────────────
//  Тест 2: декомпозиция — число выделенных нулей
// ─────────────────────────────────────────────────────────────

static void test_decompose_count()
{
    std::cout << "\n--- Тест 2: декомпозиция — число нулей ---\n";

    // ФНЧ: N=33, fs=32000, f_pass=4000, f_stop=6000
    // k_pass = floor(4000 * 33 / 32000) = floor(4.125) = 4
    // k_stop = ceil(6000 * 33 / 32000)  = ceil(6.1875)  = 7
    // Нулевые выборки: k = 7, 8, …, 16  →  10 пар на окружности
    // (k=0 — полоса пропускания, k=16 = N/2 при N=33 нечётном
    //  → k_half = 16, и k=16 — это пара, не одиночный нуль)

    FilterSpec spec{33, 32000.0, 4000.0, 6000.0};
    DirectFIR fir = design_freq_sampling(spec);
    CascadeDecomposition dec = decompose(fir, true);

    unsigned expected_biquads = 10;  // k=7..16, все пары

    report("N=33 число biquad-звеньев",
           dec.biquads.size() == expected_biquads,
           "ожидалось " + std::to_string(expected_biquads)
           + ", получено " + std::to_string(dec.biquads.size()));

    unsigned expected_zeros = expected_biquads * 2;
    report("N=33 число выделенных нулей",
           dec.zeros_extracted() == expected_zeros,
           "ожидалось " + std::to_string(expected_zeros)
           + ", получено " + std::to_string(dec.zeros_extracted()));

    // Порядок остатка
    unsigned rem_order = static_cast<unsigned>(dec.remainder.size()) - 1;
    unsigned expected_rem_order = 33 - 1 - expected_zeros;
    report("N=33 порядок остатка",
           rem_order == expected_rem_order,
           "ожидалось " + std::to_string(expected_rem_order)
           + ", получено " + std::to_string(rem_order));

    print_decomposition(dec, spec);
}

// ─────────────────────────────────────────────────────────────
//  Тест 3: пересборка — h_recomposed ≈ h_original
// ─────────────────────────────────────────────────────────────

static void test_recompose()
{
    std::cout << "\n--- Тест 3: пересборка коэффициентов ---\n";

    struct TestCase {
        unsigned N;
        real_t fs, f_pass, f_stop;
        double max_abs_tol;
        double rel_l2_tol;
    };

    TestCase cases[] = {
        {  9, 18000.0,  5000.0,  7000.0, 1e-12, 1e-12},
        { 15, 32000.0,  4000.0,  6000.0, 1e-12, 1e-12},
        { 29, 32000.0,  4000.0,  6000.0, 1e-10, 1e-10},
        { 33, 32000.0,  4000.0,  6000.0, 1e-9,  1e-9},
        { 49, 32000.0,  4000.0,  6000.0, 1e-5,  1e-5},
        { 65, 48000.0,  8000.0, 12000.0, 1e-5,  2e-5},
        {129, 48000.0,  8000.0, 12000.0, 1e-5,  2e-5},
    };

    for (const auto& tc : cases) {
        FilterSpec spec{tc.N, tc.fs, tc.f_pass, tc.f_stop};
        DirectFIR fir = design_freq_sampling(spec);
        CascadeDecomposition dec = decompose(fir, true);

        // Пересобрать полином из каскадного представления
        std::vector<real_t> h_recomp = recompose(dec, tc.N);

        // Сравнить с оригиналом
        CoeffMetrics m = compare_coeffs(fir.h, h_recomp);
        m.print("N=" + std::to_string(tc.N));

        const bool abs_ok = (m.max_abs_err < tc.max_abs_tol);
        report("N=" + std::to_string(tc.N) + " max|Δh|",
               abs_ok,
               std::to_string(m.max_abs_err)
               + " < " + std::to_string(tc.max_abs_tol));

        report("N=" + std::to_string(tc.N) + " rel_L2",
               m.rel_l2_err < tc.rel_l2_tol,
               std::to_string(m.rel_l2_err)
               + " < " + std::to_string(tc.rel_l2_tol));

        // Также проверить, что длина совпадает
        bool len_ok = (h_recomp.size() == fir.h.size());
        report("N=" + std::to_string(tc.N) + " совпадение длины",
               len_ok,
               "orig=" + std::to_string(fir.h.size())
               + " recomp=" + std::to_string(h_recomp.size()));
    }
}

// ─────────────────────────────────────────────────────────────
//  Тест 4: пересборка сохраняет АЧХ исходного полинома
// ─────────────────────────────────────────────────────────────

static void test_magnitude_response()
{
    std::cout << "\n--- Тест 4: совпадение АЧХ ---\n";

    FilterSpec spec{33, 32000.0, 4000.0, 6000.0};
    DirectFIR fir = design_freq_sampling(spec);
    CascadeDecomposition dec = decompose(fir, true);

    std::vector<real_t> h_recomp = recompose(dec, fir.length());

    const unsigned NFFT = 4096;
    std::vector<real_t> mag_orig   = compute_magnitude_response(fir.h, NFFT);
    std::vector<real_t> mag_recomp = compute_magnitude_response(h_recomp, NFFT);

    double max_mag_err = 0.0;
    double rms_mag_err = 0.0;
    for (unsigned i = 0; i < NFFT; ++i) {
        double diff = std::abs(mag_orig[i] - mag_recomp[i]);
        if (diff > max_mag_err) max_mag_err = diff;
        rms_mag_err += diff * diff;
    }
    rms_mag_err = std::sqrt(rms_mag_err / NFFT);

    report("N=33 max|ΔH(ω)|",
           max_mag_err < 1e-8,
           "max|ΔH| = " + std::to_string(max_mag_err));

    report("N=33 RMS ΔH(ω)",
           rms_mag_err < 1e-9,
           "rms|ΔH| = " + std::to_string(rms_mag_err));
}

// ─────────────────────────────────────────────────────────────
//  Тест 5: импульсная характеристика через фильтрацию
//
//  Пропускаем δ[n] через прямой и каскадный фильтр.
//  Выход должен совпадать с h[n] (в пределах точности float).
// ─────────────────────────────────────────────────────────────

static void test_impulse_response()
{
    std::cout << "\n--- Тест 5: импульсная характеристика ---\n";

    FilterSpec spec{33, 32000.0, 4000.0, 6000.0};
    DirectFIR fir = design_freq_sampling(spec);
    CascadeDecomposition dec = decompose(fir, true);

    const size_t test_len = fir.length() * 2;
    std::vector<sample_t> impulse = generate_impulse(test_len);

    // Прямая фильтрация
    std::vector<sample_t> y_direct = filter_direct(fir, impulse);

    // Каскадная фильтрация
    std::vector<sample_t> y_cascade = filter_cascade(dec, impulse);

    // Сравнение прямой с h[n]
    double max_err_direct = 0.0;
    for (unsigned n = 0; n < fir.length(); ++n) {
        double diff = std::abs(static_cast<double>(y_direct[n])
                             - static_cast<double>(fir.h[n]));
        if (diff > max_err_direct) max_err_direct = diff;
    }
    // h[n] в double, y_direct в float → ошибка ≈ float eps
    report("прямая vs h[n]",
           max_err_direct < 1e-5,
           "max|Δ| = " + std::to_string(max_err_direct));

    // Сравнение каскадной с прямой
    CompareMetrics cm = compare_signals(y_direct, y_cascade);
    cm.print("прямая vs каскад (импульс)");

    report("каскад vs прямая max|Δ|",
           cm.max_abs_err < 1e-4,
           std::to_string(cm.max_abs_err));

    report("каскад vs прямая SNR",
           cm.snr_db > 60.0,
           std::to_string(cm.snr_db) + " dB");
}

// ─────────────────────────────────────────────────────────────
//  Тест 6: фильтрация белого шума — прямая vs каскадная
// ─────────────────────────────────────────────────────────────

static void test_white_noise()
{
    std::cout << "\n--- Тест 6: белый шум, прямая vs каскадная ---\n";

    FilterSpec spec{33, 32000.0, 4000.0, 6000.0};
    DirectFIR fir = design_freq_sampling(spec);
    CascadeDecomposition dec = decompose(fir, true);

    const size_t test_len = 100000;
    std::vector<sample_t> noise = generate_white_noise(test_len, 12345);

    std::vector<sample_t> y_direct  = filter_direct(fir, noise);
    std::vector<sample_t> y_cascade = filter_cascade(dec, noise);

    CompareMetrics cm = compare_signals(y_direct, y_cascade);
    cm.print("прямая vs каскад (шум)");

    report("max|Δ| < 1e-3",
           cm.max_abs_err < 1e-3,
           std::to_string(cm.max_abs_err));

    report("SNR > 50 dB",
           cm.snr_db > 50.0,
           std::to_string(cm.snr_db) + " dB");
}

// ─────────────────────────────────────────────────────────────
//  Тест 7: стабильность baseline-алгоритма при больших N
// ─────────────────────────────────────────────────────────────

static void test_scalability()
{
    std::cout << "\n--- Тест 7: масштабируемость ---\n";

    struct TestCase {
        unsigned N;
        real_t fs, f_pass, f_stop;
    };

    TestCase cases[] = {
        {  33,  32000.0,  4000.0,  6000.0},
        {  49,  32000.0,  4000.0,  6000.0},
        {  65,  48000.0,  8000.0, 12000.0},
        {  97,  48000.0,  8000.0, 12000.0},
        { 129,  48000.0,  8000.0, 12000.0},
        { 257,  96000.0, 16000.0, 24000.0},
    };

    for (const auto& tc : cases) {
        FilterSpec spec{tc.N, tc.fs, tc.f_pass, tc.f_stop};
        DirectFIR fir = design_freq_sampling(spec);
        CascadeDecomposition dec = decompose(fir, true);
        std::vector<real_t> h_recomp = recompose(dec, tc.N);

        CoeffMetrics m = compare_coeffs(fir.h, h_recomp);

        std::string tag = "N=" + std::to_string(tc.N);

        std::cout << "  " << tag
                  << "  biquads=" << dec.biquads.size()
                  << "  fo=" << dec.first_order.size()
                  << "  rem_order=" << (dec.remainder.size() - 1)
                  << "  max|Δh|=" << std::scientific
                  << std::setprecision(2) << m.max_abs_err
                  << "  rel_L2=" << m.rel_l2_err
                  << std::defaultfloat << "\n";

        report(tag + " max|Δh|",
               m.max_abs_err < 1e-5,
               "max|Δh| = " + std::to_string(m.max_abs_err));

        report(tag + " rel_L2",
               m.rel_l2_err < 2e-5,
               "rel_L2 = " + std::to_string(m.rel_l2_err));
    }
}

// ─────────────────────────────────────────────────────────────
//  Тест 8: делимость — проверка для заведомо делимых случаев
//
//  Конструируем полином вручную как произведение известных
//  сомножителей и проверяем, что decompose/recompose
//  восстанавливает его точно.
// ─────────────────────────────────────────────────────────────

static void test_known_factorization()
{
    std::cout << "\n--- Тест 8: известная факторизация ---\n";

    // Построим H(z) = (1 − γ₁z⁻¹ + z⁻²)(1 − γ₂z⁻¹ + z⁻²)(1 − γ₃z⁻¹ + z⁻²)
    // γ₁ = 2cos(2π·1/9),  γ₂ = 2cos(2π·2/9),  γ₃ = 2cos(2π·3/9)
    //
    // Это полином степени 6, длина N = 7, симметричный.
    // Затем «обернём» его в FilterSpec с N=9, добавив
    // нулевые коэффициенты — чтобы проверить через наш API.
    //
    // Вместо этого просто сконструируем вручную.

    const unsigned N_factors = 3;
    real_t gammas[N_factors];
    for (unsigned i = 0; i < N_factors; ++i) {
        gammas[i] = 2.0 * std::cos(2.0 * PI * (i + 1) / 9.0);
    }

    // Перемножим сомножители
    std::vector<real_t> h = {1.0};
    for (unsigned i = 0; i < N_factors; ++i) {
        std::vector<real_t> factor = {1.0, -gammas[i], 1.0};
        h = poly_multiply(h, factor);
    }

    // h теперь длины 7, степень 6, симметричный
    report("ручной полином: длина",
           h.size() == 7, std::to_string(h.size()));

    double asym = check_symmetry(h);
    report("ручной полином: симметрия",
           asym < 1e-14, std::to_string(asym));

    // Попробуем разделить на каждый сомножитель той же
    // половинной рекурсией, что использует baseline-алгоритм.
    std::vector<real_t> current = h;
    bool all_ok = true;

    unsigned extracted_factors = 0;
    for (unsigned i = 0; i + 1 < N_factors; ++i) {
        std::vector<real_t> quotient;
        real_t gamma = gammas[i];

        if (!divide_by_biquad_half_for_test(current, gamma, quotient)) {
            all_ok = false;
            break;
        }

        std::vector<real_t> factor = {1.0, -gamma, 1.0};
        std::vector<real_t> rebuilt = poly_multiply(quotient, factor);

        CoeffMetrics m = compare_coeffs(current, rebuilt);
        std::string tag = "γ=" + std::to_string(gamma);
        report(tag + " max|Q·D-H|", m.max_abs_err < 1e-12, std::to_string(m.max_abs_err));
        if (m.max_abs_err >= 1e-12) {
            all_ok = false;
        }

        current = quotient;
        ++extracted_factors;
    }

    report("все деления успешны", all_ok);

    report("выделено ожидаемое число звеньев",
           extracted_factors == N_factors - 1,
           std::to_string(extracted_factors));

    // После выделения двух звеньев должен остаться третий
    // исходный biquad-фактор.
    report("остаток — biquad",
           current.size() == 3,
           "длина остатка = " + std::to_string(current.size()));

    if (current.size() == 3) {
        const std::vector<real_t> expected_tail = {1.0, -gammas[N_factors - 1], 1.0};
        const CoeffMetrics tail_metrics = compare_coeffs(current, expected_tail);
        report("остаток совпадает с последним biquad",
               tail_metrics.max_abs_err < 1e-12,
               std::to_string(tail_metrics.max_abs_err));
    }
}

// ─────────────────────────────────────────────────────────────
//  Тест 9: делимость на (1+z⁻¹) и (1−z⁻¹)
//
//  Конструируем полиномы, заведомо имеющие нуль в z=−1
//  и/или z=+1, и проверяем деление.
// ─────────────────────────────────────────────────────────────

static void test_first_order_division()
{
    std::cout << "\n--- Тест 9: деление на (1±z⁻¹) ---\n";

    // H(z) = (1 + z⁻¹)(1 − 0.5z⁻¹ + z⁻²)
    //       = 1 + 0.5z⁻¹ + 0.5z⁻² + z⁻³
    // Нуль z = −1.
    std::vector<real_t> f1 = {1.0, 1.0};
    std::vector<real_t> f2 = {1.0, -0.5, 1.0};
    std::vector<real_t> h = poly_multiply(f1, f2);

    // Деление на (1 + z⁻¹): sign = +1
    // q[0] = h[0] = 1
    // q[n] = h[n] − (+1)·q[n−1]
    // q[0] = 1
    // q[1] = h[1] − q[0] = 0.5 − 1 = −0.5
    // q[2] = h[2] − q[1] = 0.5 − (−0.5) = 1.0
    // Остаток: h[3] − q[2] = 1.0 − 1.0 = 0  ✓

    size_t len = h.size();
    size_t qlen = len - 1;
    std::vector<real_t> q(qlen);
    q[0] = h[0];
    for (size_t n = 1; n < qlen; ++n) {
        q[n] = h[n] - q[n - 1];  // sign = +1 → вычитаем
    }
    double rem = std::abs(h[len - 1] - q[qlen - 1]);

    report("(1+z⁻¹) остаток", rem < 1e-14, std::to_string(rem));

    // Частное должно быть {1, −0.5, 1} = f2
    CoeffMetrics cm = compare_coeffs(q, f2);
    report("(1+z⁻¹) частное = f2", cm.max_abs_err < 1e-14,
           std::to_string(cm.max_abs_err));

    // Теперь H(z) = (1 − z⁻¹)(1 + 1.5z⁻¹ + z⁻²)
    // Нуль z = +1.
    std::vector<real_t> g1 = {1.0, -1.0};
    std::vector<real_t> g2 = {1.0, 1.5, 1.0};
    std::vector<real_t> h2 = poly_multiply(g1, g2);

    // Деление на (1 − z⁻¹): sign = −1
    // q[n] = h[n] − (−1)·q[n−1] = h[n] + q[n−1]
    len = h2.size();
    qlen = len - 1;
    std::vector<real_t> q2(qlen);
    q2[0] = h2[0];
    for (size_t n = 1; n < qlen; ++n) {
        q2[n] = h2[n] + q2[n - 1];
    }
    double rem2 = std::abs(h2[len - 1] + q2[qlen - 1]);

    report("(1−z⁻¹) остаток", rem2 < 1e-14, std::to_string(rem2));

    CoeffMetrics cm2 = compare_coeffs(q2, g2);
    report("(1−z⁻¹) частное = g2", cm2.max_abs_err < 1e-14,
           std::to_string(cm2.max_abs_err));
}

// ═══════════════════════════════════════════════════════════════
//  main
// ═══════════════════════════════════════════════════════════════

int main()
{
    std::cout << "╔══════════════════════════════════════════════╗\n"
              << "║  Тесты каскадной декомпозиции КИХ-фильтра   ║\n"
              << "╚══════════════════════════════════════════════╝\n";

    test_design_symmetry();
    test_decompose_count();
    test_recompose();
    test_magnitude_response();
    test_impulse_response();
    test_white_noise();
    test_scalability();
    test_known_factorization();
    test_first_order_division();

    std::cout << "\n══════════════════════════════════════════════\n"
              << "  Итого: " << g_tests_run << " тестов, "
              << g_tests_passed << " пройдено, "
              << g_tests_failed << " провалено.\n"
              << "══════════════════════════════════════════════\n";

    return (g_tests_failed > 0) ? 1 : 0;
}



